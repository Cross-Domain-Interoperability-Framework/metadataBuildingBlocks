{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DDE Imagery properties",
  "description": "Conditional extension for imagery resources with DDE-specific properties. Implements MD_Imagery entity (DDE spec Table 3 / XSD). All properties are optional.",
  "type": "object",
  "properties": {
    "schema:additionalProperty": {
      "type": "array",
      "description": "Additional properties for imagery resources using DDE propertyIDs.",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "description": "Type of sensor used to acquire the imagery.",
            "properties": {
              "@type": {"const": "schema:PropertyValue"},
              "schema:propertyID": {
                "type": "array",
                "contains": {"const": "dde:sensorType"},
                "minItems": 1
              },
              "schema:name": {"type": "string"},
              "schema:value": {"type": "string"}
            },
            "required": ["schema:propertyID", "schema:name", "schema:value"]
          },
          {
            "type": "object",
            "description": "Platform carrying the sensor.",
            "properties": {
              "@type": {"const": "schema:PropertyValue"},
              "schema:propertyID": {
                "type": "array",
                "contains": {"const": "dde:platform"},
                "minItems": 1
              },
              "schema:name": {"type": "string"},
              "schema:value": {"type": "string"}
            },
            "required": ["schema:propertyID", "schema:name", "schema:value"]
          },
          {
            "type": "object",
            "description": "Equipment used for imagery acquisition.",
            "properties": {
              "@type": {"const": "schema:PropertyValue"},
              "schema:propertyID": {
                "type": "array",
                "contains": {"const": "dde:equipment"},
                "minItems": 1
              },
              "schema:name": {"type": "string"},
              "schema:value": {"type": "string"}
            },
            "required": ["schema:propertyID", "schema:name", "schema:value"]
          },
          {
            "type": "object",
            "description": "Person or organization that collected the imagery.",
            "properties": {
              "@type": {"const": "schema:PropertyValue"},
              "schema:propertyID": {
                "type": "array",
                "contains": {"const": "dde:collector"},
                "minItems": 1
              },
              "schema:name": {"type": "string"},
              "schema:value": {"type": "string"}
            },
            "required": ["schema:propertyID", "schema:name", "schema:value"]
          },
          {
            "type": "object",
            "description": "Type of signal used (e.g. \"Passive solar\", \"Active radar\").",
            "properties": {
              "@type": {"const": "schema:PropertyValue"},
              "schema:propertyID": {
                "type": "array",
                "contains": {"const": "dde:signalGenerator"},
                "minItems": 1
              },
              "schema:name": {"type": "string"},
              "schema:value": {"type": "string"}
            },
            "required": ["schema:propertyID", "schema:name", "schema:value"]
          },
          {
            "type": "object",
            "description": "Wavelength range of the imagery.",
            "properties": {
              "@type": {"const": "schema:PropertyValue"},
              "schema:propertyID": {
                "type": "array",
                "contains": {"const": "dde:wavelength"},
                "minItems": 1
              },
              "schema:name": {"type": "string"},
              "schema:value": {"type": "string"}
            },
            "required": ["schema:propertyID", "schema:name", "schema:value"]
          },
          {
            "type": "object",
            "description": "Processing level of the imagery. Value from ProcessingLevelCode.",
            "properties": {
              "@type": {"const": "schema:PropertyValue"},
              "schema:propertyID": {
                "type": "array",
                "contains": {"const": "dde:processedLevel"},
                "minItems": 1
              },
              "schema:name": {"type": "string"},
              "schema:value": {
                "type": "string",
                "enum": ["Level0", "Level1", "Level2", "Level3", "Level4"]
              }
            },
            "required": ["schema:propertyID", "schema:name", "schema:value"]
          },
          {
            "type": "object",
            "title": "additionalProperty PropertyValue",
            "description": "PropertyValue values required to define a soft-typed property with a value. ",
            "properties": {
              "@type": {
                "type": "string",
                "const": "schema:PropertyValue"
              },
              "schema:propertyID": {
                "type": "array",
                "items": {
                  "anyOf": [
                    {"type": "string"},
                    {
                      "type": "object",
                      "properties": {
                        "@id": {"type": "string"}
                      }
                    },
                    {
                      "description": "schema.org Defined Term schema",
                      "type": "object",
                      "properties": {
                        "@type": {"const": "schema:DefinedTerm"},
                        "schema:name": {
                          "type": "string",
                          "description": "text label for the term that is useful to human user"
                        },
                        "schema:identifier": {
                          "anyOf": [
                            {"type": "string"},
                            {
                              "description": "Properties for a schema.org identifier",
                              "type": "object",
                              "properties": {
                                "@type": {"type": "string", "const": "schema:PropertyValue"},
                                "schema:propertyID": {"type": "string", "description": "identifier for the identifier schema, e.g. DOI, ARK"},
                                "schema:value": {"type": "string", "description": "the identifier string"},
                                "schema:url": {"type": "string", "format": "uri", "description": "web-resolveable string for the identifier"}
                              },
                              "required": ["@type"],
                              "anyOf": [
                                {"required": ["schema:value"]},
                                {"required": ["schema:url"]}
                              ]
                            }
                          ]
                        },
                        "schema:inDefinedTermSet": {"type": "string"},
                        "schema:termCode": {"type": "string"}
                      },
                      "required": ["@type"],
                      "anyOf": [
                        {"required": ["schema:name"]},
                        {"required": ["schema:identifier"]},
                        {"required": ["schema:termCode"]}
                      ]
                    }
                  ]
                },
                "minItems": 1,
                "description": "identifier or name for the property concept quantified by the values in this variable slot."
              },
              "schema:name": {"type": "string"},
              "schema:value": {"type": "string"}
            },
            "required": ["schema:name", "schema:value"]
          }
        ]
      }
    },
    "schema:startTime": {
      "type": "string",
      "description": "Start time of the imagery acquisition. ISO 8601 date-time format."
    },
    "schema:endTime": {
      "type": "string",
      "description": "End time of the imagery acquisition. ISO 8601 date-time format."
    }
  }
}
