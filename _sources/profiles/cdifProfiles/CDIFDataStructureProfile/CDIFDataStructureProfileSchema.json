{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "title": "CDIF Data Structure metadata profile",
    "description": "CDIF Data Structure profile. Extends the Data Description profile with full DDI-CDI structural complexity: composing cdifDataStructure (DataStructure + Dimensional/Long/Wide variants), cdifDataStructureComponent (component subclasses), cdifRepresentedVariable, and cdifValueDomain. Distributions are expected to carry cdi:isStructuredBy pointing at a Data Structure node.",
    "allOf": [
        {
            "$ref": "../../../cdifProperties/cdifCore/cdifCoreSchema.json"
        },
        {
            "$ref": "../../../cdifProperties/cdifDataDescription/cdifDataDescriptionSchema.json"
        },
        {
            "type": "object",
            "properties": {
                "@context": {
                    "type": "object",
                    "description": "Additional JSON-LD namespace prefixes for the data structure profile.",
                    "properties": {
                        "geosparql": {
                            "const": "http://www.opengis.net/ont/geosparql#"
                        },
                        "dqv": {
                            "const": "http://www.w3.org/ns/dqv#"
                        },
                        "cdi": {
                            "const": "http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/"
                        },
                        "cdif": {
                            "const": "https://cdif.org/0.1/"
                        }
                    }
                },
                "schema:variableMeasured": {
                    "items": {
                        "properties": {
                            "cdif:role": false,
                            "cdi:qualifies": false,
                            "cdi:hasIntendedDataType": false,
                            "cdi:describedUnitOfMeasure": false,
                            "cdif:simpleUnitOfMeasure": false,
                            "cdi:takesSentinelValuesFrom": false,
                            "cdi:takesSubstantiveValuesFrom": false
                        },
                        "description": "In the Data Structure profile, variable role is encoded by the component class type (IdentifierComponent, MeasureComponent, AttributeComponent, DimensionComponent, VariableValueComponent, VariableDescriptorComponent) on cdi:isStructuredBy, and the attribute-qualifies-measure relationship is encoded at the component level (AttributeComponent.cdi:qualifies pointing at the qualified component). Carrying cdif:role or cdi:qualifies on the InstanceVariable would be redundant and is therefore disallowed at this profile level. Likewise, the RepresentedVariable-level properties (cdi:hasIntendedDataType, cdi:describedUnitOfMeasure, cdif:simpleUnitOfMeasure, cdi:takesSentinelValuesFrom, cdi:takesSubstantiveValuesFrom) are disallowed here: when a distribution carries cdi:isStructuredBy, those properties live on the RepresentedVariable and are referenced from the InstanceVariable via cdif:uses rather than duplicated."
                    }
                },
                "schema:distribution": {
                    "items": {
                        "properties": {
                            "cdi:isStructuredBy": {
                                "description": "Points at the Data Structure node that describes how this distribution's bytes are organized. Inline cdifDataStructure or @id-reference to a node defined elsewhere in the document. This property is specific to the Data Structure profile - the Data Description profile does not carry it.",
                                "anyOf": [
                                    {
                                        "$ref": "../../../cdifProperties/cdifDataStructure/cdifDataStructureSchema.json"
                                    },
                                    {
                                        "type": "object",
                                        "properties": {
                                            "@id": {
                                                "type": "string"
                                            }
                                        },
                                        "required": [
                                            "@id"
                                        ]
                                    }
                                ]
                            }
                        },
                        "required": [
                            "cdi:isStructuredBy"
                        ],
                        "allOf": [
                            {
                                "if": {
                                    "properties": {
                                        "@type": {
                                            "anyOf": [
                                                {
                                                    "contains": {
                                                        "const": "cdi:TabularTextDataSet"
                                                    }
                                                },
                                                {
                                                    "contains": {
                                                        "const": "cdi:StructuredDataSet"
                                                    }
                                                }
                                            ]
                                        }
                                    }
                                },
                                "then": {
                                    "required": [
                                        "cdif:hasPhysicalMapping"
                                    ]
                                }
                            },
                            {
                                "if": {
                                    "allOf": [
                                        {
                                            "properties": {
                                                "@type": {
                                                    "contains": {
                                                        "const": "cdi:PhysicalDataSet"
                                                    }
                                                }
                                            }
                                        },
                                        {
                                            "properties": {
                                                "@type": {
                                                    "not": {
                                                        "contains": {
                                                            "const": "cdi:TabularTextDataSet"
                                                        }
                                                    }
                                                }
                                            }
                                        },
                                        {
                                            "properties": {
                                                "@type": {
                                                    "not": {
                                                        "contains": {
                                                            "const": "cdi:StructuredDataSet"
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    ]
                                },
                                "then": {
                                    "properties": {
                                        "cdi:isStructuredBy": {
                                            "properties": {
                                                "@type": {
                                                    "not": {
                                                        "anyOf": [
                                                            {
                                                                "contains": {
                                                                    "const": "cdi:LongDataStructure"
                                                                }
                                                            },
                                                            {
                                                                "contains": {
                                                                    "const": "cdi:DimensionalDataStructure"
                                                                }
                                                            },
                                                            {
                                                                "contains": {
                                                                    "const": "cdi:WideDataStructure"
                                                                }
                                                            }
                                                        ]
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        ]
                    }
                },
                "schema:subjectOf": {
                    "properties": {
                        "dcterms:conformsTo": {
                            "contains": {
                                "type": "object",
                                "properties": {
                                    "@id": {
                                        "const": "https://w3id.org/cdif/data_structure/1.0"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    ],
    "$defs": {
        "CdifDataStructure": {
            "$ref": "../../../cdifProperties/cdifDataStructure/cdifDataStructureSchema.json"
        },
        "CdifDataStructureComponent": {
            "$ref": "../../../cdifProperties/cdifDataStructureComponent/cdifDataStructureComponentSchema.json"
        },
        "CdifRepresentedVariable": {
            "$ref": "../../../cdifProperties/cdifRepresentedVariable/cdifRepresentedVariableSchema.json"
        },
        "CdifValueDomain": {
            "$ref": "../../../cdifProperties/cdifValueDomain/cdifValueDomainSchema.json"
        }
    }
}
