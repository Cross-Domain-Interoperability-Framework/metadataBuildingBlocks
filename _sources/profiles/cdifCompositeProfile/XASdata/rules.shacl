@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:          <http://www.w3.org/ns/shacl#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:      <http://schema.org/>.
@prefix cdifd: <https://cdif.org/validation/0.1/shacl#> .
@prefix dcterms: <http://purl.org/dc/terms/>.
@base <https://www.ogc.org/rules/template/> .

# rules are inherited from schemas cited in 'allOf'

cdifd:metadataProfileProperty
# An XASdata record must declare conformance to every CDIF profile component it
# composes (core + discovery + data_description + xasCore + xasDiscovery).
# Overrides the generic cdifCore metadataProfileProperty (core/1.0 only).
    a sh:PropertyShape ;
    sh:path  dcterms:conformsTo  ;
	sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:hasValue <https://w3id.org/cdif/core/1.0> ;
    sh:hasValue <https://w3id.org/cdif/discovery/1.0> ;
    sh:hasValue <https://w3id.org/cdif/data_description/1.0> ;
    sh:hasValue <https://w3id.org/cdif/xasCore/1.0> ;
    sh:hasValue <https://w3id.org/cdif/xasDiscovery/1.0> ;
    sh:message "a CDIF XASdata metadata record must declare conformance to core/1.0, discovery/1.0, data_description/1.0, xasCore/1.0 and xasDiscovery/1.0 (all under https://w3id.org/cdif/)"
    .

# Conformance declaration for the XASdata profile in the catalog record.
cdifd:CDIFXASdataConformsToShape a sh:NodeShape ;
    sh:target [
      a sh:SPARQLTarget ;
        sh:select  """
            PREFIX schema: <http://schema.org/>
            SELECT ?this
            WHERE {
            ?this a schema:Dataset ;
             schema:about ?parent ;
             schema:additionalType "dcat:CatalogRecord" .
            }
        """;
    ] ;
    sh:property [
        a sh:PropertyShape ;
        sh:path dcterms:conformsTo ;
        sh:hasValue <https://w3id.org/cdif/bbr/metadata/profiles/cdifCompositeProfile/XASdata> ;
        sh:severity sh:Warning ;
        sh:message "Metadata record for XASdata profile should declare conformance to https://w3id.org/cdif/bbr/metadata/profiles/cdifCompositeProfile/XASdata" ;
    ] .
