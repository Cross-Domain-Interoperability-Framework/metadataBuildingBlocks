@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:          <http://www.w3.org/ns/shacl#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:      <http://schema.org/>.
@prefix cdifd: <https://cdif.org/validation/0.1/shacl#> .
@prefix dcterms: <http://purl.org/dc/terms/>.
@base <https://www.ogc.org/rules/template/> .

# rules are inherited from schemas cited in 'allOf'

cdifd:metadataProfileProperty
# A BasicDataDescription record must declare conformance to every CDIF profile
# component it composes (core + discovery + data_description). Overrides the
# generic cdifCore metadataProfileProperty (which requires only core/1.0).
    a sh:PropertyShape ;
    sh:path  dcterms:conformsTo  ;
	sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:hasValue <https://w3id.org/cdif/core/1.0> ;
    sh:hasValue <https://w3id.org/cdif/discovery/1.0> ;
    sh:hasValue <https://w3id.org/cdif/data_description/1.0> ;
    sh:message "a CDIF BasicDataDescription metadata record must declare conformance to https://w3id.org/cdif/core/1.0, https://w3id.org/cdif/discovery/1.0 and https://w3id.org/cdif/data_description/1.0"
    .
    