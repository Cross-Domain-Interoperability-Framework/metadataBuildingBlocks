@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:          <http://www.w3.org/ns/shacl#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:      <http://schema.org/>.
@prefix cdifd: <https://cdif.org/validation/0.1/shacl#> .
@prefix xas: <https://xas.org/dictionary/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@base <https://www.ogc.org/rules/template/> .


cdifd:xasGeneratedByNode
	a sh:NodeShape;
	sh:targetClass xas:AnalysisEvent ;
	sh:property [
      sh:path rdf:type ;
      sh:hasValue prov:Activity ;
      sh:message "An XAS AnalysisEvent must also have rdf:type prov:Activity."
    ] ;
	sh:property [
      sh:path [sh:alternativePath ( prov:used schema:additionalProperty schema:location schema:object ) ] ;
      sh:minCount 1 ;
      sh:message "An XAS AnalysisEvent must specify at least one of prov:used, schema:additionalProperty, schema:location, or schema:object."
    ] .
