@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:          <http://www.w3.org/ns/shacl#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:      <http://schema.org/>.
@prefix dcterms:     <http://purl.org/dc/terms/> .
@prefix dcat:        <http://www.w3.org/ns/dcat#> .
@prefix cdifd: <https://cdif.org/validation/0.1/shacl#> .
@base <https://www.ogc.org/rules/template/> .


cdifd:xasSubjectNode
	a sh:NodeShape;
	    sh:target [
	  a sh:SPARQLTarget ;
      sh:select  """
      PREFIX schema: <http://schema.org/>
      PREFIX dcat: <http://www.w3.org/ns/dcat#>
      SELECT DISTINCT ?this
        WHERE {
          ?this a schema:Dataset .
          ?this schema:additionalType "dcat:CatalogRecord" .
          }""";
	] ;
    sh:property [
      sh:path dcterms:conformsTo ;
      sh:minCount 2 ;
      sh:message "An XAS catalog record must have at least 2 conformsTo entries (CDIF and CDIFxas profiles)."
    ] .
