                                  ]
                                },
                                {
                                  "required": [
                                    "schema:termCode"
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "enum": [
                        "xas:stoichiometry",
                        "xas:samplePreparation",
                        "nxs:Field/NXsample/mass",
                        "nxs:Field/NXsample/point_group",
                        "nxs:Field/NXsample/unit_cell",
                        "xas:parentSample",
                        "xas:materialState"
                      ]
                    }
                  ]
                }
              }
            }
          }
        ]
      }
    }
  },
  "required": [
    "@type",
    "schema:additionalType",
    "schema:name"
  ]
}
