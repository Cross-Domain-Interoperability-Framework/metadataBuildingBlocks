{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "CDIF Key",
    "description": "Profile of ddi-cdi Key/PrimaryKey: a CDIF Key is the role of an ordered set of cdi:InstanceVariables (referenced via cdifInstanceVariable) that uniquely identify a data instance. Composed of cdif:ComponentPosition wrappers giving each component variable an integer position.",
    "type": "object",
    "properties": {
        "@type": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "contains": {
                "const": "cdif:Key"
            },
            "minItems": 1
        },
        "@id": {
            "type": "string",
            "description": "Identifier for this Key node."
        },
        "cdif:isComposedOf": {
            "type": "array",
            "items": {
                "type": "object",
                "description": "Indexes the cdi:InstanceVariables (via cdifInstanceVariable) that compose this Key, using integers to indicate ordered position starting at 0 or 1.",
                "properties": {
                    "@type": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "contains": {
                            "const": "cdif:ComponentPosition"
                        },
                        "minItems": 1
                    },
                    "@id": {
                        "type": "string",
                        "description": "Identifier for this ComponentPosition node."
                    },
                    "cdif:indexes": {
                        "anyOf": [
                            {
                                "$ref": "../cdifInstanceVariable/schema.yaml#/$defs/CdifInstanceVariableNode"
                            },
                            {
                                "$ref": "../../ddiCDIFProperties/ddi-cdif-data-types/schema.yaml#/$defs/id-reference"
                            }
                        ]
                    },
                    "cdif:value": {
                        "type": "integer",
                        "description": "Index value of the member in an ordered array."
                    }
                },
                "required": [
                    "@type",
                    "cdif:indexes",
                    "cdif:value"
                ]
            },
            "minItems": 1
        }
    },
    "required": [
        "@type",
        "cdif:isComposedOf"
    ]
}
