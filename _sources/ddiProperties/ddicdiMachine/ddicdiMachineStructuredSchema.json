{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DDI-CDI Machine",
  "description": "DDI-CDI Machine agent (cls-Machine, extends Agent). Represents software or hardware with access location, function, and interface specifications.",
  "type": "object",
  "properties": {
    "@type": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "contains": {
        "const": "cdi:Machine"
      },
      "minItems": 1
    },
    "@id": {
      "type": "string",
      "description": "Identifier for this machine node"
    },
    "cdi:accessLocation": {
      "type": "object",
      "description": "Network or physical access point for this machine",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:AccessLocation"
          },
          "minItems": 1
        },
        "cdi:uri": {
          "type": "string",
          "format": "uri",
          "description": "URI of the access endpoint"
        },
        "cdi:mimeType": {
          "$ref": "#/$defs/ControlledVocabularyEntry",
          "description": "MIME type of the resource at this location"
        },
        "cdi:physicalLocation": {
          "type": "object",
          "description": "Physical location description",
          "properties": {
            "@type": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "contains": {
                "const": "cdi:InternationalString"
              },
              "minItems": 1
            },
            "cdi:languageSpecificString": {
              "description": "Language-tagged string value(s)",
              "anyOf": [
                {
                  "$ref": "#/$defs/LanguageString"
                },
                {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/LanguageString"
                  }
                }
              ]
            }
          }
        }
      }
    },
    "cdi:function": {
      "$ref": "#/$defs/ControlledVocabularyEntry",
      "description": "Function performed by this machine"
    },
    "cdi:machineInterface": {
      "$ref": "#/$defs/ControlledVocabularyEntry",
      "description": "Interface type for this machine"
    },
    "cdi:name": {
      "description": "Name(s) of this machine",
      "anyOf": [
        {
          "type": "object",
          "description": "DDI-CDI structured name wrapper (dt-ObjectName)",
          "properties": {
            "@type": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "contains": {
                "const": "cdi:ObjectName"
              },
              "minItems": 1
            },
            "cdi:name": {
              "type": "string",
              "description": "The name string"
            },
            "cdi:context": {
              "$ref": "#/$defs/ControlledVocabularyEntry",
              "description": "Context or usage of this name"
            }
          },
          "required": [
            "cdi:name"
          ]
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "description": "DDI-CDI structured name wrapper (dt-ObjectName)",
            "properties": {
              "@type": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "contains": {
                  "const": "cdi:ObjectName"
                },
                "minItems": 1
              },
              "cdi:name": {
                "type": "string",
                "description": "The name string"
              },
              "cdi:context": {
                "$ref": "#/$defs/ControlledVocabularyEntry",
                "description": "Context or usage of this name"
              }
            },
            "required": [
              "cdi:name"
            ]
          }
        }
      ]
    },
    "cdi:ownerOperatorContact": {
      "type": "object",
      "description": "Contact information for the owner or operator",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:ContactInformation"
          },
          "minItems": 1
        },
        "cdi:address": {
          "description": "Postal address(es)",
          "anyOf": [
            {
              "type": "object",
              "description": "DDI-CDI postal address (dt-Address)",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:Address"
                  },
                  "minItems": 1
                },
                "cdi:line": {
                  "description": "Address line(s)",
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "cdi:cityPlaceLocal": {
                  "type": "string",
                  "description": "City, town, or locality"
                },
                "cdi:stateProvince": {
                  "type": "string",
                  "description": "State, province, or region"
                },
                "cdi:postalCode": {
                  "type": "string",
                  "description": "Postal or ZIP code"
                },
                "cdi:countryCode": {
                  "$ref": "#/$defs/ControlledVocabularyEntry",
                  "description": "Country code"
                },
                "cdi:typeOfAddress": {
                  "$ref": "#/$defs/ControlledVocabularyEntry",
                  "description": "Type of address (e.g. home, work, mailing)"
                },
                "cdi:isPreferred": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether this is the preferred address"
                }
              }
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "description": "DDI-CDI postal address (dt-Address)",
                "properties": {
                  "@type": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "contains": {
                      "const": "cdi:Address"
                    },
                    "minItems": 1
                  },
                  "cdi:line": {
                    "description": "Address line(s)",
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "cdi:cityPlaceLocal": {
                    "type": "string",
                    "description": "City, town, or locality"
                  },
                  "cdi:stateProvince": {
                    "type": "string",
                    "description": "State, province, or region"
                  },
                  "cdi:postalCode": {
                    "type": "string",
                    "description": "Postal or ZIP code"
                  },
                  "cdi:countryCode": {
                    "$ref": "#/$defs/ControlledVocabularyEntry",
                    "description": "Country code"
                  },
                  "cdi:typeOfAddress": {
                    "$ref": "#/$defs/ControlledVocabularyEntry",
                    "description": "Type of address (e.g. home, work, mailing)"
                  },
                  "cdi:isPreferred": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether this is the preferred address"
                  }
                }
              }
            }
          ]
        },
        "cdi:email": {
          "description": "Email address(es)",
          "anyOf": [
            {
              "type": "object",
              "description": "DDI-CDI email address (dt-Email)",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:Email"
                  },
                  "minItems": 1
                },
                "cdi:internetEmail": {
                  "type": "string",
                  "description": "Email address string"
                },
                "cdi:typeOfEmail": {
                  "$ref": "#/$defs/ControlledVocabularyEntry",
                  "description": "Type of email (e.g. personal, work)"
                },
                "cdi:isPreferred": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether this is the preferred email"
                }
              }
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "description": "DDI-CDI email address (dt-Email)",
                "properties": {
                  "@type": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "contains": {
                      "const": "cdi:Email"
                    },
                    "minItems": 1
                  },
                  "cdi:internetEmail": {
                    "type": "string",
                    "description": "Email address string"
                  },
                  "cdi:typeOfEmail": {
                    "$ref": "#/$defs/ControlledVocabularyEntry",
                    "description": "Type of email (e.g. personal, work)"
                  },
                  "cdi:isPreferred": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether this is the preferred email"
                  }
                }
              }
            }
          ]
        },
        "cdi:emessaging": {
          "description": "Electronic messaging contact(s)",
          "anyOf": [
            {
              "type": "object",
              "description": "DDI-CDI electronic messaging system contact (dt-ElectronicMessageSystem)",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:ElectronicMessageSystem"
                  },
                  "minItems": 1
                },
                "cdi:contactAddress": {
                  "type": "string",
                  "description": "Messaging address or handle"
                },
                "cdi:typeOfService": {
                  "$ref": "#/$defs/ControlledVocabularyEntry",
                  "description": "Type of messaging service (e.g. Slack, Teams)"
                },
                "cdi:isPreferred": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether this is the preferred messaging service"
                }
              }
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "description": "DDI-CDI electronic messaging system contact (dt-ElectronicMessageSystem)",
                "properties": {
                  "@type": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "contains": {
                      "const": "cdi:ElectronicMessageSystem"
                    },
                    "minItems": 1
                  },
                  "cdi:contactAddress": {
                    "type": "string",
                    "description": "Messaging address or handle"
                  },
                  "cdi:typeOfService": {
                    "$ref": "#/$defs/ControlledVocabularyEntry",
                    "description": "Type of messaging service (e.g. Slack, Teams)"
                  },
                  "cdi:isPreferred": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether this is the preferred messaging service"
                  }
                }
              }
            }
          ]
        },
        "cdi:telephone": {
          "description": "Telephone number(s)",
          "anyOf": [
            {
              "type": "object",
              "description": "DDI-CDI telephone number (dt-Telephone)",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:Telephone"
                  },
                  "minItems": 1
                },
                "cdi:telephoneNumber": {
                  "type": "string",
                  "description": "Telephone number string"
                },
                "cdi:typeOfTelephone": {
                  "$ref": "#/$defs/ControlledVocabularyEntry",
                  "description": "Type of telephone (e.g. mobile, office, fax)"
                },
                "cdi:isPreferred": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether this is the preferred telephone"
                }
              }
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "description": "DDI-CDI telephone number (dt-Telephone)",
                "properties": {
                  "@type": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "contains": {
                      "const": "cdi:Telephone"
                    },
                    "minItems": 1
                  },
                  "cdi:telephoneNumber": {
                    "type": "string",
                    "description": "Telephone number string"
                  },
                  "cdi:typeOfTelephone": {
                    "$ref": "#/$defs/ControlledVocabularyEntry",
                    "description": "Type of telephone (e.g. mobile, office, fax)"
                  },
                  "cdi:isPreferred": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether this is the preferred telephone"
                  }
                }
              }
            }
          ]
        },
        "cdi:website": {
          "description": "Website link(s)",
          "anyOf": [
            {
              "type": "object",
              "description": "DDI-CDI website link (dt-WebLink)",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:WebLink"
                  },
                  "minItems": 1
                },
                "cdi:uri": {
                  "type": "string",
                  "format": "uri",
                  "description": "URI of the website"
                },
                "cdi:typeOfWebsite": {
                  "$ref": "#/$defs/ControlledVocabularyEntry",
                  "description": "Type of website (e.g. homepage, documentation)"
                },
                "cdi:isPreferred": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether this is the preferred website"
                }
              }
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "description": "DDI-CDI website link (dt-WebLink)",
                "properties": {
                  "@type": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "contains": {
                      "const": "cdi:WebLink"
                    },
                    "minItems": 1
                  },
                  "cdi:uri": {
                    "type": "string",
                    "format": "uri",
                    "description": "URI of the website"
                  },
                  "cdi:typeOfWebsite": {
                    "$ref": "#/$defs/ControlledVocabularyEntry",
                    "description": "Type of website (e.g. homepage, documentation)"
                  },
                  "cdi:isPreferred": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether this is the preferred website"
                  }
                }
              }
            }
          ]
        }
      }
    },
    "cdi:typeOfMachine": {
      "$ref": "#/$defs/ControlledVocabularyEntry",
      "description": "Classification of this machine"
    },
    "cdi:identifier": {
      "type": "object",
      "description": "Formal identifier for this agent",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:Identifier"
          },
          "minItems": 1
        },
        "cdi:ddiIdentifier": {
          "type": "object",
          "description": "DDI-specific IRDI identifier",
          "properties": {
            "@type": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "contains": {
                "const": "cdi:InternationalRegistrationDataIdentifier"
              },
              "minItems": 1
            },
            "cdi:dataIdentifier": {
              "type": "string"
            },
            "cdi:registrationAuthorityIdentifier": {
              "type": "string"
            },
            "cdi:versionIdentifier": {
              "type": "string"
            }
          },
          "required": [
            "cdi:dataIdentifier",
            "cdi:registrationAuthorityIdentifier",
            "cdi:versionIdentifier"
          ]
        },
        "cdi:uri": {
          "type": "string",
          "format": "uri",
          "description": "URI form of the identifier"
        },
        "cdi:nonDdiIdentifier": {
          "description": "Non-DDI identifier",
          "anyOf": [
            {
              "type": "object",
              "description": "Non-DDI identifier (dt-NonDdiIdentifier)",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:NonDdiIdentifier"
                  },
                  "minItems": 1
                },
                "cdi:identifierContent": {
                  "type": "string",
                  "description": "The identifier value"
                },
                "cdi:managingAgency": {
                  "type": "string",
                  "description": "Agency managing this identifier scheme"
                }
              },
              "required": [
                "cdi:identifierContent"
              ]
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "description": "Non-DDI identifier (dt-NonDdiIdentifier)",
                "properties": {
                  "@type": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "contains": {
                      "const": "cdi:NonDdiIdentifier"
                    },
                    "minItems": 1
                  },
                  "cdi:identifierContent": {
                    "type": "string",
                    "description": "The identifier value"
                  },
                  "cdi:managingAgency": {
                    "type": "string",
                    "description": "Agency managing this identifier scheme"
                  }
                },
                "required": [
                  "cdi:identifierContent"
                ]
              }
            }
          ]
        }
      }
    },
    "cdi:image": {
      "type": "object",
      "description": "Image associated with this agent",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:PrivateImage"
          },
          "minItems": 1
        },
        "cdi:effectiveDates": {
          "type": "object",
          "description": "Date range when this image is effective",
          "properties": {
            "@type": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "contains": {
                "const": "cdi:DateRange"
              },
              "minItems": 1
            },
            "cdi:startDate": {
              "type": "object",
              "description": "Start date of the range",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:CombinedDate"
                  },
                  "minItems": 1
                },
                "cdi:isoDate": {
                  "type": "string",
                  "format": "date-time",
                  "description": "ISO 8601 date-time value"
                },
                "cdi:historicDate": {
                  "type": "string",
                  "description": "Free-text historic date"
                }
              }
            },
            "cdi:endDate": {
              "type": "object",
              "description": "End date of the range",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:CombinedDate"
                  },
                  "minItems": 1
                },
                "cdi:isoDate": {
                  "type": "string",
                  "format": "date-time",
                  "description": "ISO 8601 date-time value"
                },
                "cdi:historicDate": {
                  "type": "string",
                  "description": "Free-text historic date"
                }
              }
            }
          }
        },
        "cdi:privacy": {
          "$ref": "#/$defs/ControlledVocabularyEntry",
          "description": "Privacy classification"
        }
      }
    },
    "cdi:purpose": {
      "type": "object",
      "description": "Purpose or role of this agent",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:InternationalString"
          },
          "minItems": 1
        },
        "cdi:languageSpecificString": {
          "description": "Language-tagged string value(s)",
          "anyOf": [
            {
              "$ref": "#/$defs/LanguageString"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/LanguageString"
              }
            }
          ]
        }
      }
    }
  },
  "required": [
    "@type"
  ],
  "$defs": {
    "ControlledVocabularyEntry": {
      "type": "object",
      "description": "DDI-CDI controlled vocabulary entry (dt-ControlledVocabularyEntry). Allows for unstructured content which may be an entry from an externally maintained controlled vocabulary. When the content is from a controlled vocabulary, provide the code value of the entry along with a reference to the vocabulary from which the value is taken.",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:ControlledVocabularyEntry"
          },
          "minItems": 1
        },
        "cdi:entryReference": {
          "description": "A reference to the specific item in the vocabulary referenced by cdi:vocabulary, using a URI or other resolvable identifier.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          },
          "minItems": 1
        },
        "cdi:entryValue": {
          "description": "The value of the entry of the controlled vocabulary. If no controlled vocabulary is used the term is entered here and none of the properties defining the controlled vocabulary location are used.",
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "cdi:name": {
          "type": "string",
          "description": "The name of the code list (controlled vocabulary)."
        },
        "cdi:valueForOther": {
          "type": "string",
          "description": "If the value of the string is \"Other\" or the equivalent from the codelist, this attribute can provide a more specific value not found in the codelist."
        },
        "cdi:vocabulary": {
          "$ref": "#/$defs/Reference",
          "description": "A reference to the external controlled vocabulary, using a URI or other resolvable identifier."
        }
      }
    },
    "Reference": {
      "type": "object",
      "description": "DDI-CDI reference to an entity (dt-Reference)",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:Reference"
          },
          "minItems": 1
        },
        "cdi:uri": {
          "type": "string",
          "format": "uri",
          "description": "URI of the referenced entity"
        },
        "cdi:description": {
          "type": "string",
          "description": "Human-readable description of the reference"
        },
        "cdi:ddiReference": {
          "type": "object",
          "description": "DDI IRDI reference",
          "properties": {
            "@type": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "contains": {
                "const": "cdi:InternationalRegistrationDataIdentifier"
              },
              "minItems": 1
            },
            "cdi:dataIdentifier": {
              "type": "string"
            },
            "cdi:registrationAuthorityIdentifier": {
              "type": "string"
            },
            "cdi:versionIdentifier": {
              "type": "string"
            }
          },
          "required": [
            "cdi:dataIdentifier",
            "cdi:registrationAuthorityIdentifier",
            "cdi:versionIdentifier"
          ]
        },
        "cdi:semantic": {
          "$ref": "#/$defs/ControlledVocabularyEntry",
          "description": "Semantic role of this reference"
        }
      }
    },
    "LanguageString": {
      "type": "object",
      "description": "DDI-CDI language-tagged string (dt-LanguageString)",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:LanguageString"
          },
          "minItems": 1
        },
        "cdi:content": {
          "type": "string",
          "description": "The text content"
        },
        "cdi:language": {
          "type": "string",
          "description": "ISO language code (e.g. en, fr, de)"
        }
      },
      "required": [
        "cdi:content"
      ]
    }
  }
}
