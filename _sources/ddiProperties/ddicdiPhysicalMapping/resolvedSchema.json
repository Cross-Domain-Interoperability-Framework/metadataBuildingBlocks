                },
                {
                  "type": "array",
                  "items": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "$ref": "#/$defs/LanguageTaggedValue"
                      }
                    ]
                  }
                }
              ]
            },
            "skos:example": {
              "description": "Example of use of this concept.",
