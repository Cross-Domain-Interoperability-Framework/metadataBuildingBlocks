                    "$ref": "#/$defs/ConceptRef"
                  },
                  {
                    "$comment": "circular-ref"
                  }
                ]
              }
            },
            "skos:narrower": {
              "description": "Narrower (child) concepts in the hierarchy. Items are inline concept objects or @id references.",
              "type": "array",
