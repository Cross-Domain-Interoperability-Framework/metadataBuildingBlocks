@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:          <http://www.w3.org/ns/shacl#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix cdi:         <http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/> .
@prefix cdifd: <https://cdif.org/validation/0.1/shacl#> .
@base <https://www.ogc.org/rules/template/> .


# ------------------------------------------------------------
# SubstantiveValueDomain shape
# ------------------------------------------------------------

cdifd:ddicdiSubstantiveValueDomainShape
	a sh:NodeShape ;
	sh:targetClass cdi:SubstantiveValueDomain ;

	# -- INFORMATIONAL (Info) --

	sh:property [
		sh:path cdi:identifier ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI SubstantiveValueDomain may include a cdi:identifier" ;
	] ;

	sh:property [
		sh:path cdi:displayLabel ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI SubstantiveValueDomain may include a cdi:displayLabel (LabelForDisplay)" ;
	] ;

	sh:property [
		sh:path cdi:recommendedDataType ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI SubstantiveValueDomain may specify a cdi:recommendedDataType (ControlledVocabularyEntry)" ;
	] ;

	sh:property [
		sh:path cdi:isDescribedBy ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI SubstantiveValueDomain may be described by a ValueAndConceptDescription via cdi:isDescribedBy" ;
	] ;

	sh:property [
		sh:path cdi:takesValuesFrom ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI SubstantiveValueDomain may take values from an EnumerationDomain via cdi:takesValuesFrom" ;
	] ;

	sh:property [
		sh:path cdi:takesConceptsFrom ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI SubstantiveValueDomain may take concepts from a SubstantiveConceptualDomain via cdi:takesConceptsFrom" ;
	] ;
	.


# ------------------------------------------------------------
# SentinelValueDomain shape
# ------------------------------------------------------------

cdifd:ddicdiSentinelValueDomainShape
	a sh:NodeShape ;
	sh:targetClass cdi:SentinelValueDomain ;

	# -- INFORMATIONAL (Info) --

	sh:property [
		sh:path cdi:identifier ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI SentinelValueDomain may include a cdi:identifier" ;
	] ;

	sh:property [
		sh:path cdi:displayLabel ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI SentinelValueDomain may include a cdi:displayLabel (LabelForDisplay)" ;
	] ;

	sh:property [
		sh:path cdi:recommendedDataType ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI SentinelValueDomain may specify a cdi:recommendedDataType (ControlledVocabularyEntry)" ;
	] ;

	sh:property [
		sh:path cdi:platformType ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI SentinelValueDomain may specify a cdi:platformType (e.g., SASNumeric, SPSSstyle, Rstyle)" ;
	] ;

	sh:property [
		sh:path cdi:isDescribedBy ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI SentinelValueDomain may be described by a ValueAndConceptDescription via cdi:isDescribedBy" ;
	] ;

	sh:property [
		sh:path cdi:takesValuesFrom ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI SentinelValueDomain may take values from an EnumerationDomain via cdi:takesValuesFrom" ;
	] ;

	sh:property [
		sh:path cdi:takesConceptsFrom ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI SentinelValueDomain may take concepts from a SentinelConceptualDomain via cdi:takesConceptsFrom" ;
	] ;
	.


# ------------------------------------------------------------
# ValueAndConceptDescription shape
# ------------------------------------------------------------

cdifd:ddicdiValueAndConceptDescriptionShape
	a sh:NodeShape ;
	sh:targetClass cdi:ValueAndConceptDescription ;

	# -- INFORMATIONAL (Info) --

	sh:property [
		sh:path cdi:description ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI ValueAndConceptDescription may include a cdi:description (InternationalString)" ;
	] ;

	sh:property [
		sh:path cdi:classificationLevel ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI ValueAndConceptDescription may specify a cdi:classificationLevel (Continuous, Interval, Nominal, Ordinal, Ratio)" ;
	] ;
	.


# ------------------------------------------------------------
# DescriptorValueDomain shape
# ------------------------------------------------------------

cdifd:ddicdiDescriptorValueDomainShape
	a sh:NodeShape ;
	sh:targetClass cdi:DescriptorValueDomain ;

	sh:property [
		sh:path cdi:takesValuesFrom ;
		sh:severity sh:Info ;
		sh:message "cdi:takesValuesFrom may reference an EnumerationDomain (or id-reference) supplying the descriptor codes" ;
	] ;

	sh:property [
		sh:path cdi:takesConceptsFrom ;
		sh:severity sh:Info ;
		sh:message "cdi:takesConceptsFrom may reference a SubstantiveConceptualDomain (or id-reference)" ;
	] ;

	sh:property [
		sh:path cdi:isDescribedBy ;
		sh:severity sh:Info ;
		sh:message "cdi:isDescribedBy may reference a ValueAndConceptDescription (or id-reference)" ;
	] ;

	sh:property [
		sh:path cdi:displayLabel ;
		sh:severity sh:Info ;
		sh:message "cdi:displayLabel may carry one or more LabelForDisplay entries" ;
	] ;
	.


# ------------------------------------------------------------
# Descriptor shape -- per the canonical DDI-CDI XMI:
# identifies -> ReferenceVariable. The ddi-cdif profile uses
# InstanceVariable instead; see ddi-cdif-descriptor BB.
# ------------------------------------------------------------

cdifd:ddicdiDescriptorShape
	a sh:NodeShape ;
	sh:targetClass cdi:Descriptor ;

	# -- RECOMMENDED (Warning) --

	sh:property [
		sh:path cdi:identifies ;
		sh:minCount 1 ;
		sh:severity sh:Warning ;
		sh:message "A DDI-CDI Descriptor should identify the ReferenceVariable it is associated with (or id-reference)" ;
	] ;

	sh:property [
		sh:path cdi:hasValueFrom ;
		sh:severity sh:Warning ;
		sh:message "A DDI-CDI Descriptor should reference the DescriptorValueDomain that provides its codes" ;
	] ;

	# -- INFORMATIONAL (Info) --

	sh:property [
		sh:path cdi:refersTo ;
		sh:severity sh:Info ;
		sh:message "cdi:refersTo may carry one or more ReferenceValue references (or id-references)" ;
	] ;

	sh:property [
		sh:path cdi:isBasedOn ;
		sh:severity sh:Info ;
		sh:message "cdi:isBasedOn may reference the ConceptualVariable / RepresentedVariable on which this Descriptor is patterned" ;
	] ;

	sh:property [
		sh:path cdi:content ;
		sh:datatype xsd:string ;
		sh:severity sh:Info ;
		sh:message "cdi:content may carry the descriptor code value as a simple string" ;
	] ;
	.
