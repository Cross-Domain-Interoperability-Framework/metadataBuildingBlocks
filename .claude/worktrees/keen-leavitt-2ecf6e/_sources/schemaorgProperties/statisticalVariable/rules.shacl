@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:          <http://www.w3.org/ns/shacl#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:      <http://schema.org/>.
@prefix cdifd: <https://cdif.org/validation/0.1/shacl#> .
@base <https://www.ogc.org/rules/template/> .


cdifd:statisticalVariableNode
	a sh:NodeShape;
	sh:targetClass schema:StatisticalVariable ;
    sh:property [
      sh:path schema:name ;
      sh:minCount 1 ;
      sh:datatype xsd:string ;
      sh:minLength 3 ;
      sh:message "A StatisticalVariable must have a name (schema:name) with at least 3 characters."
    ] ;
    sh:property [
      sh:path schema:measuredProperty ;
      sh:minCount 1 ;
      sh:message "A StatisticalVariable must specify the property being measured (schema:measuredProperty)."
    ] ;
    sh:property [
      sh:path schema:statType ;
      sh:severity sh:Warning ;
      sh:or (
        [sh:nodeKind sh:IRI]
        [sh:datatype xsd:string]
        [sh:class schema:DefinedTerm]
      ) ;
      sh:message "A StatisticalVariable should specify a statType as a string, IRI, or DefinedTerm."
    ] .
