@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:          <http://www.w3.org/ns/shacl#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix cdi:         <http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/> .
@prefix cdifd: <https://cdif.org/validation/0.1/shacl#> .
@base <https://www.ogc.org/rules/template/> .

# ------------------------------------------------------------
# DataStructureComponent shapes -- this BB is polymorphic over the
# six concrete component subclasses. Each concrete class has its
# own NodeShape; the parent cdi:DataStructureComponent itself is
# abstract and is not targeted directly. Per CDIF DD Appendix 4,
# isDefinedBy / refersTo are Required associations on each role.
# ------------------------------------------------------------

# -- IdentifierComponent ------------------------------------------------------

cdifd:ddi-cdif-identifier-componentShape
	a sh:NodeShape ;
	sh:targetClass cdi:IdentifierComponent ;

	sh:property [
		sh:path cdi:isDefinedBy ;
		sh:minCount 1 ;
		sh:severity sh:Warning ;
		sh:message "A DDI-CDI IdentifierComponent should specify cdi:isDefinedBy - the InstanceVariable / RepresentedVariable that defines it (Required per CDIF DD Appendix 4)" ;
	] ;

	sh:property [
		sh:path cdi:identifier ;
		sh:severity sh:Info ;
		sh:message "cdi:identifier may carry an Identifier for the IdentifierComponent" ;
	] ;

	sh:property [
		sh:path cdi:semantic ;
		sh:severity sh:Info ;
		sh:message "cdi:semantic may carry one or more PairedControlledVocabularyEntry values qualifying the component's purpose" ;
	] ;

	sh:property [
		sh:path cdi:specialization ;
		sh:severity sh:Info ;
		sh:message "cdi:specialization may identify a SpecializationRole (e.g. geographic, temporal) for harmonisation" ;
	] ;
	.

# -- MeasureComponent ---------------------------------------------------------

cdifd:ddi-cdif-measure-componentShape
	a sh:NodeShape ;
	sh:targetClass cdi:MeasureComponent ;

	sh:property [
		sh:path cdi:isDefinedBy ;
		sh:minCount 1 ;
		sh:severity sh:Warning ;
		sh:message "A DDI-CDI MeasureComponent should specify cdi:isDefinedBy - the InstanceVariable / RepresentedVariable that defines it (Required per CDIF DD Appendix 4)" ;
	] ;

	sh:property [
		sh:path cdi:name ;
		sh:severity sh:Info ;
		sh:message "cdi:name may carry one or more ObjectName values for the MeasureComponent" ;
	] ;

	sh:property [
		sh:path cdi:identifier ;
		sh:severity sh:Info ;
		sh:message "cdi:identifier may carry an Identifier for the MeasureComponent" ;
	] ;

	sh:property [
		sh:path cdi:semantic ;
		sh:severity sh:Info ;
		sh:message "cdi:semantic may carry one or more PairedControlledVocabularyEntry values qualifying the component's purpose" ;
	] ;

	sh:property [
		sh:path cdi:specialization ;
		sh:severity sh:Info ;
		sh:message "cdi:specialization may identify a SpecializationRole (e.g. geographic, temporal) for harmonisation" ;
	] ;
	.

# -- AttributeComponent -------------------------------------------------------

cdifd:ddi-cdif-attribute-componentShape
	a sh:NodeShape ;
	sh:targetClass cdi:AttributeComponent ;

	sh:property [
		sh:path cdi:isDefinedBy ;
		sh:minCount 1 ;
		sh:severity sh:Warning ;
		sh:message "A DDI-CDI AttributeComponent should specify cdi:isDefinedBy - the InstanceVariable / RepresentedVariable that defines it (Required per CDIF DD Appendix 4)" ;
	] ;

	sh:property [
		sh:path cdi:qualifies ;
		sh:severity sh:Info ;
		sh:message "cdi:qualifies may reference one or more DataStructureComponents that this AttributeComponent qualifies" ;
	] ;

	sh:property [
		sh:path cdi:identifier ;
		sh:severity sh:Info ;
		sh:message "cdi:identifier may carry an Identifier for the AttributeComponent" ;
	] ;

	sh:property [
		sh:path cdi:semantic ;
		sh:severity sh:Info ;
		sh:message "cdi:semantic may carry one or more PairedControlledVocabularyEntry values qualifying the component's purpose" ;
	] ;

	sh:property [
		sh:path cdi:specialization ;
		sh:severity sh:Info ;
		sh:message "cdi:specialization may identify a SpecializationRole (e.g. geographic, temporal) for harmonisation" ;
	] ;
	.

# -- DimensionComponent -------------------------------------------------------

cdifd:ddi-cdif-dimension-componentShape
	a sh:NodeShape ;
	sh:targetClass cdi:DimensionComponent ;

	sh:property [
		sh:path cdi:isDefinedBy ;
		sh:minCount 1 ;
		sh:severity sh:Warning ;
		sh:message "A DDI-CDI DimensionComponent should specify cdi:isDefinedBy - the InstanceVariable / RepresentedVariable that defines it (Required per CDIF DD Appendix 4)" ;
	] ;

	sh:property [
		sh:path cdi:categoricalAdditivity ;
		sh:datatype xsd:boolean ;
		sh:severity sh:Info ;
		sh:message "cdi:categoricalAdditivity indicates whether categories at one level can be summed to yield a parent category" ;
	] ;

	sh:property [
		sh:path cdi:isStructuredBy ;
		sh:severity sh:Info ;
		sh:message "cdi:isStructuredBy may reference a ValueDomain structuring the dimension (or an id-reference)" ;
	] ;

	sh:property [
		sh:path cdi:identifier ;
		sh:severity sh:Info ;
		sh:message "cdi:identifier may carry an Identifier for the DimensionComponent" ;
	] ;

	sh:property [
		sh:path cdi:semantic ;
		sh:severity sh:Info ;
		sh:message "cdi:semantic may carry one or more PairedControlledVocabularyEntry values qualifying the component's purpose" ;
	] ;

	sh:property [
		sh:path cdi:specialization ;
		sh:severity sh:Info ;
		sh:message "cdi:specialization may identify a SpecializationRole (e.g. geographic, temporal) for harmonisation" ;
	] ;
	.

# -- VariableValueComponent ---------------------------------------------------

cdifd:ddi-cdif-variable-value-componentShape
	a sh:NodeShape ;
	sh:targetClass cdi:VariableValueComponent ;

	sh:property [
		sh:path cdi:isDefinedBy ;
		sh:minCount 1 ;
		sh:severity sh:Warning ;
		sh:message "A DDI-CDI VariableValueComponent should specify cdi:isDefinedBy - a reference to the ReferenceVariable that defines it (Required per CDIF DD Appendix 4)" ;
	] ;

	sh:property [
		sh:path cdi:identifier ;
		sh:severity sh:Info ;
		sh:message "cdi:identifier may carry an Identifier for the VariableValueComponent" ;
	] ;

	sh:property [
		sh:path cdi:semantic ;
		sh:severity sh:Info ;
		sh:message "cdi:semantic may carry one or more PairedControlledVocabularyEntry values qualifying the component's purpose" ;
	] ;

	sh:property [
		sh:path cdi:specialization ;
		sh:severity sh:Info ;
		sh:message "cdi:specialization may identify a SpecializationRole (e.g. geographic, temporal) for harmonisation" ;
	] ;
	.

# -- VariableDescriptorComponent ---------------------------------------------

cdifd:ddi-cdif-variable-descriptor-componentShape
	a sh:NodeShape ;
	sh:targetClass cdi:VariableDescriptorComponent ;

	sh:property [
		sh:path cdi:refersTo ;
		sh:minCount 1 ;
		sh:severity sh:Warning ;
		sh:message "A DDI-CDI VariableDescriptorComponent should specify cdi:refersTo - a reference to the DescriptorVariable / VariableValueComponent it refers to (Required per CDIF DD Appendix 4)" ;
	] ;

	sh:property [
		sh:path cdi:isDefinedBy ;
		sh:severity sh:Info ;
		sh:message "cdi:isDefinedBy may reference the DescriptorVariable that defines this VariableDescriptorComponent" ;
	] ;

	sh:property [
		sh:path cdi:identifier ;
		sh:severity sh:Info ;
		sh:message "cdi:identifier may carry an Identifier for the VariableDescriptorComponent" ;
	] ;

	sh:property [
		sh:path cdi:semantic ;
		sh:severity sh:Info ;
		sh:message "cdi:semantic may carry one or more PairedControlledVocabularyEntry values qualifying the component's purpose" ;
	] ;

	sh:property [
		sh:path cdi:specialization ;
		sh:severity sh:Info ;
		sh:message "cdi:specialization may identify a SpecializationRole (e.g. geographic, temporal) for harmonisation" ;
	] ;
	.
