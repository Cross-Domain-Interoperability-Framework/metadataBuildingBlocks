@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:          <http://www.w3.org/ns/shacl#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:      <http://schema.org/>.
@prefix cdifd: <https://cdif.org/validation/0.1/shacl#> .
@prefix xas: <https://xas.org/dictionary/> .
@base <https://www.ogc.org/rules/template/> .


cdifd:xasFacilityNode
	a sh:NodeShape;
	    sh:target [
	  a sh:SPARQLTarget ;
      sh:select  """
      PREFIX schema: <http://schema.org/>
      PREFIX xas: <https://xas.org/dictionary/>
      SELECT DISTINCT ?this
        WHERE {
          ?this a schema:Place .
          ?this schema:additionalType "xas:Facility" .
          }""";
	] ;
    sh:property [
      sh:path schema:additionalType ;
      sh:hasValue "xas:Facility" ;
      sh:minCount 1 ;
      sh:message "An XAS facility must have additionalType xas:Facility."
    ] ;
    sh:property [
      sh:path schema:name ;
      sh:minCount 1 ;
      sh:datatype xsd:string ;
	  sh:minLength 3 ;
      sh:message "A facility must have a name with at least 3 characters."
    ] .
