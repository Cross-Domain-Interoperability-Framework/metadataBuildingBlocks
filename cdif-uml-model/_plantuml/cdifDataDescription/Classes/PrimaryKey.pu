@startuml
title PrimaryKey
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "PrimaryKey" as PrimaryKey #FEFECE {
  +identifier : XsdAnyUri [0..1]
}
class "Dataset" as Dataset #EEEEEE
Dataset *-- "0..1" PrimaryKey : hasPrimaryKey
class "XsdAnyUri" as XsdAnyUri <<dataType>> #FAE5D3
PrimaryKey ..> XsdAnyUri : identifier

@enduml