@startuml
title StructuredDataSet
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam ranksep 250
skinparam nodesep 20
skinparam defaultFontSize 36
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 36
  AttributeFontSize 30
}

class "StructuredDataSet" as StructuredDataSet #FEFECE {
  +encoding : string [0..1]
}
abstract class "AbstractDataSet" as AbstractDataSet #D6EAF8
AbstractDataSet <|-- StructuredDataSet

@enduml