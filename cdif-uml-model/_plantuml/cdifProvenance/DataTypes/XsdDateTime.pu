@startuml
title XsdDateTime
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "XsdDateTime" as XsdDateTime <<dataType>> #FAE5D3
class "ProvActivity" as ProvActivity #EEEEEE
ProvActivity ..> XsdDateTime : startTime
ProvActivity ..> XsdDateTime : endTime

@enduml