@startuml
title DataStructureComponent
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "DataStructureComponent" as DataStructureComponent #FEFECE {
  +identifier : Identifier [1]
  +semantic : Concept [1..*]
}
class "ForeignKeyComponent" as ForeignKeyComponent #EEEEEE
ForeignKeyComponent "1" <-- DataStructureComponent : correspondsTo

@enduml