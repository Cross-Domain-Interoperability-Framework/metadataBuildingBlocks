@startuml
title Statistic
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "Statistic" as Statistic #FEFECE {
  +identifier : Identifier [1]
  +statistic : Statistic [1..*]
  +typeOfStatistic : Concept [1]
}
class "Dataset" as Dataset #EEEEEE
Dataset "0..*" <-- Statistic : statistics

@enduml