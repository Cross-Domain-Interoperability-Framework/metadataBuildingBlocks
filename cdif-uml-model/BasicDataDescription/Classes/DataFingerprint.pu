@startuml
title DataFingerprint
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "DataFingerprint" as DataFingerprint #FEFECE {
  +value : string [1]
  +algorithmSpecification : string [0..1]
  +algorithmVersion : string [0..1]
  +typeOfFingerprint : string [0..1]
}

@enduml