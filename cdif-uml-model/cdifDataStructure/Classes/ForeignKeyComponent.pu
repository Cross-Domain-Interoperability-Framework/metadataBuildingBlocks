@startuml
title ForeignKeyComponent
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "ForeignKeyComponent" as ForeignKeyComponent #FEFECE {
  +type : String [1..*]
  +identifier : String [0..1]
}

class "Identifier" as Identifier #D6EAF8

class "PrimaryKeyComponent" as PrimaryKeyComponent #FEFECE

class "id-reference" as id-reference #FEFECE

ForeignKeyComponent --> "0..1" Identifier : identifier
ForeignKeyComponent --> "0..1" PrimaryKeyComponent : references
ForeignKeyComponent --> "0..1" id-reference : correspondsTo
@enduml
