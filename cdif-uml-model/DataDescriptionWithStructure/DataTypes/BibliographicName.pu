@startuml
title BibliographicName
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "BibliographicName" as BibliographicName <<dataType>> #FAE5D3 {
  +affiliation : string [1]
}

@enduml