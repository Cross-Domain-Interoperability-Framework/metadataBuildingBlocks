@startuml
title CDIFDataDescription — overview
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "Dataset" as Dataset #FEFECE
class "CatalogRecord" as CatalogRecord #FEFECE
class "DataDownload" as DataDownload #FEFECE
class "WebAPI" as WebAPI #FCF3CF
class "ActionResult" as ActionResult #FCF3CF
class "InstanceVariable" as InstanceVariable #FAE5D3
abstract class "AbstractMapping" as AbstractMapping #FCF3CF
class "PhysicalMapping" as PhysicalMapping #FCF3CF
class "TextMapping" as TextMapping #FCF3CF
class "LocatorMapping" as LocatorMapping #FCF3CF
abstract class "AbstractDataSet" as AbstractDataSet #FCF3CF
class "TabularTextDataSet" as TabularTextDataSet #FCF3CF
class "StructuredDataSet" as StructuredDataSet #FCF3CF
class "DataFingerprint" as DataFingerprint #FCF3CF
class "PrimaryKey" as PrimaryKey #FAE5D3
class "Statistics" as Statistics #FCF3CF
class "SubstantiveValueDomain" as SubstantiveValueDomain #FCF3CF
class "SentinelValueDomain" as SentinelValueDomain #FCF3CF
AbstractMapping <|-- PhysicalMapping
AbstractMapping <|-- TextMapping
AbstractMapping <|-- LocatorMapping
AbstractDataSet <|-- TabularTextDataSet
AbstractDataSet <|-- StructuredDataSet
Dataset *-- "1" CatalogRecord : subjectOf
Dataset *-- "1..*" InstanceVariable : variableMeasured
Dataset *-- "0..1" PrimaryKey : hasPrimaryKey
Dataset *-- "0..*" Statistics : statistics
Dataset *-- "0..*" DataDownload : distribution
Dataset *-- "0..*" WebAPI : distribution
DataDownload *-- "0..*" AbstractMapping : hasPhysicalMapping
DataDownload o-- "0..1" AbstractDataSet : alsoTypedAs
DataDownload *-- "0..1" DataFingerprint : fingerprint
WebAPI *-- "0..*" ActionResult : potentialActionResult
ActionResult *-- "0..*" AbstractMapping : hasPhysicalMapping
InstanceVariable --> "0..1" SubstantiveValueDomain : takesSubstantiveValuesFrom
InstanceVariable --> "0..*" SentinelValueDomain : takesSentinelValuesFrom
AbstractMapping --> "1" InstanceVariable : formats

@enduml