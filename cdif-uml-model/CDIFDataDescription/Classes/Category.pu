@startuml
title Category
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "Category" as Category #FEFECE {
  +name : string [0..*]
  +descriptiveText : string [0..1]
  +definition : string [0..1]
  +displayLabel : string [0..*]
}
class "CategoryStatistics" as CategoryStatistics #EEEEEE
CategoryStatistics "1" <-- Category : for

@enduml