@startuml
title DataFingerprint
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "DataFingerprint" as DataFingerprint #FEFECE {
  +algorithm : string [1]
  +value : string [1]
}
class "DataDownload" as DataDownload #EEEEEE
DataDownload *-- "0..1" DataFingerprint : fingerprint

@enduml