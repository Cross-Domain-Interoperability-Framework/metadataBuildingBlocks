@startuml
title GeoCoordinates
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "GeoCoordinates" as GeoCoordinates #FEFECE {
  +latitude : string [1]
  +longitude : string [1]
  +elevation : string [0..1]
}
abstract class "AbstractGeometry" as AbstractGeometry #D6EAF8
AbstractGeometry <|-- GeoCoordinates

@enduml