{"defs":{},"properties":[{"path":["schema:additionalType"],"id":"http://schema.org/additionalType","description":"additional type assertions for the catalog record node. dcat:CatalogRecord is required.","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifCatalogRecord"],"effectiveId":"http://schema.org/additionalType"},{"path":["schema:about"],"id":"http://schema.org/about","required":true,"schema_type":"object","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifCatalogRecord"],"effectiveId":"http://schema.org/about"},{"path":["dcterms:conformsTo"],"id":"http://purl.org/dc/terms/conformsTo","description":"uri for specifications that this metadata record conforms to. Minimimally should specify uri for CDIF discovery profile.","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifCatalogRecord"],"effectiveId":"http://purl.org/dc/terms/conformsTo"},{"path":["schema:maintainer"],"id":"http://schema.org/maintainer","description":"Identification of the agent that maintains the metadata, with contact information. Should include person name and affiliation, or position name and affiliation, or just organization name. e-mail address is preferred contact information.","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifCatalogRecord"],"effectiveId":"http://schema.org/maintainer"},{"path":["schema:sdDatePublished"],"id":"http://schema.org/sdDatePublished","description":"date of most recent update to the metadata content","schema_type":"string","format":"date","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifCatalogRecord"],"effectiveId":"http://schema.org/sdDatePublished"},{"path":["schema:includedInDataCatalog"],"id":"http://schema.org/includedInDataCatalog","description":"identify the source for the origin the metadata record.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifCatalogRecord"],"effectiveId":"http://schema.org/includedInDataCatalog"},{"path":["schema:includedInDataCatalog","schema:name"],"id":"http://schema.org/name","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifCatalogRecord"],"effectiveId":"http://schema.org/name"},{"path":["schema:includedInDataCatalog","schema:url"],"id":"http://schema.org/url","description":"locator to access a landing page for the collection or catalog","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifCatalogRecord"],"effectiveId":"http://schema.org/url"},{"path":["schema:includedInDataCatalog","schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for the collection or catalog; use identifier_type to provide information on identifier scheme and context for identifier","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifCatalogRecord"],"effectiveId":"http://schema.org/identifier"},{"path":["schema:maintainer","schema:sameAs"],"id":"http://schema.org/sameAs","description":"other identifiers for the person","schema_type":"array","effectiveId":"http://schema.org/sameAs"},{"path":["schema:maintainer","schema:contactPoint"],"id":"http://schema.org/contactPoint","description":"restrict to email only. Schema.org allows telephone and postal contacts as well","schema_type":"object","effectiveId":"http://schema.org/contactPoint"},{"path":["schema:maintainer","schema:contactPoint","schema:email"],"id":"http://schema.org/email","required":true,"schema_type":"string","effectiveId":"http://schema.org/email"},{"path":["schema:maintainer","schema:affiliation"],"id":"http://schema.org/affiliation","description":"if affiliation is present, value must be a schema:Organization.","effectiveId":"http://schema.org/affiliation"},{"path":["schema:maintainer","schema:affiliation","schema:sameAs"],"id":"http://schema.org/sameAs","description":"other identifiers for the organization","schema_type":"array","effectiveId":"http://schema.org/sameAs"},{"path":["schema:maintainer","schema:affiliation","schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for organization","effectiveId":"http://schema.org/identifier"},{"path":["schema:maintainer","schema:affiliation","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:maintainer","schema:affiliation","schema:alternateName"],"id":"http://schema.org/alternateName","description":"other labels by which the organization might be known","schema_type":"string","effectiveId":"http://schema.org/alternateName"},{"path":["schema:maintainer","schema:affiliation","schema:name"],"id":"http://schema.org/name","description":"string label for organization that is meaningful for human users","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:maintainer","schema:affiliation","schema:additionalType"],"id":"http://schema.org/additionalType","schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["schema:maintainer","schema:affiliation","schema:additionalType","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:maintainer","schema:affiliation","schema:additionalType","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:maintainer","schema:affiliation","schema:additionalType","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["schema:maintainer","schema:affiliation","schema:additionalType","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["schema:maintainer","schema:alternateName"],"id":"http://schema.org/alternateName","description":"other labels by which the person might be known","schema_type":"string","effectiveId":"http://schema.org/alternateName"},{"path":["schema:maintainer","schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for person, recommend ORCID","effectiveId":"http://schema.org/identifier"},{"path":["schema:maintainer","schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["schema:maintainer","schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["schema:maintainer","schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:maintainer","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:maintainer","schema:name"],"id":"http://schema.org/name","description":"string label for person that is meaningful for human users, should format consistently. Recommend 'Family Name, Given name' format.","schema_type":"string","effectiveId":"http://schema.org/name"}]}