{"defs":{},"properties":[{"path":["cdif:isComposedOf"],"id":"https://cdif.org/0.1/isComposedOf","description":"Ordered list of cdi:ComponentPosition wrappers. Each wrapper carries cdi:indexes (an inline cdifInstanceVariable or @id-reference to one declared elsewhere in the dataset) and cdi:value (the integer position in the key, 0- or 1-based).","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifKey"],"effectiveId":"https://cdif.org/0.1/isComposedOf"},{"path":["cdif:isComposedOf","cdi:indexes"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/indexes","required":true,"sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifKey"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/indexes"},{"path":["cdif:isComposedOf","cdi:value"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/value","description":"Index value (position) of the variable in the ordered key.","required":true,"schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifKey"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/value"},{"path":["cdif:isComposedOf","cdi:indexes","cdi:qualifies"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/qualifies","description":"reference to an instance variable defined for this dataset","schema_type":"object","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/qualifies"},{"path":["cdif:isComposedOf","cdi:indexes","cdi:describedUnitOfMeasure"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/describedUnitOfMeasure","description":"The unit in which the data values are measured, expressed as a controlled-vocabulary entry (RepresentedVariable.describedUnitOfMeasure). For a plain-string unit, use cdif:simpleUnitOfMeasure instead.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/describedUnitOfMeasure"},{"path":["cdif:isComposedOf","cdi:indexes","cdi:hasIntendedDataType"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasIntendedDataType","description":"The data type intended to be used by this variable, independent of its physical representation (RepresentedVariable.hasIntendedDataType).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasIntendedDataType"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection"],"id":"https://cdif.org/0.1/isDescribedBy_StatisticsCollection","description":"The StatisticsCollection holding summary / category statistics for this InstanceVariable (InstanceVariable.isDescribedBy). cdif: namespaced and target-suffixed because the DDI-CDI isDescribedBy association is polymorphic.","effectiveId":"https://cdif.org/0.1/isDescribedBy_StatisticsCollection"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdi:hasWeight"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight","description":"The InstanceVariable whose values were used as weights (inline cdifInstanceVariable node or an @id-reference).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics"],"id":"https://cdif.org/0.1/has_Statistics","description":"Statistics nodes carried by this collection (inline or @id-ref). cdif: namespaced and target-suffixed because the DDI-CDI cdi:has association is polymorphic.","required":true,"schema_type":"array","effectiveId":"https://cdif.org/0.1/has_Statistics"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics"],"id":"https://cdif.org/0.1/has_CategoryStatistics","description":"CategoryStatistics entries breaking this Statistics bundle down by Category. cdif: namespaced and target-suffixed because the DDI-CDI cdi:has association is polymorphic.","schema_type":"array","effectiveId":"https://cdif.org/0.1/has_CategoryStatistics"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:hasWeight"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight","description":"The InstanceVariable whose values were used as weights (inline cdifInstanceVariable node or an @id-reference).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:statistic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/statistic","description":"Per-category Statistic value objects.","required":true,"schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/statistic"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:typeOfStatistic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfStatistic","description":"Controlled-vocabulary entry naming the kind of statistic.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfStatistic"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/for","description":"The Category this CategoryStatistics is for (inline Category node or an @id-reference).","required":true,"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/for"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for","cdif:name"],"id":"https://cdif.org/0.1/name","description":"Human-understandable name(s). CDIF-simplified from DDI-CDI Category.name (ObjectName) to plain strings.","schema_type":"array","effectiveId":"https://cdif.org/0.1/name"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for","cdif:descriptiveText"],"id":"https://cdif.org/0.1/descriptiveText","description":"Short natural-language account of the category. CDIF-simplified from DDI-CDI Category.descriptiveText (InternationalString).","schema_type":"string","effectiveId":"https://cdif.org/0.1/descriptiveText"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for","cdif:definition"],"id":"https://cdif.org/0.1/definition","description":"Natural-language definition of the category. CDIF-simplified from DDI-CDI Category.definition (InternationalString).","schema_type":"string","effectiveId":"https://cdif.org/0.1/definition"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for","cdif:displayLabel"],"id":"https://cdif.org/0.1/displayLabel","description":"Human-readable display label(s). CDIF-simplified from DDI-CDI Category.displayLabel (LabelForDisplay).","schema_type":"array","effectiveId":"https://cdif.org/0.1/displayLabel"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:appliesTo"],"id":"https://cdif.org/0.1/appliesTo","description":"CDIF addition (not in canonical DDI-CDI): the InstanceVariable(s) this Statistics bundle summarizes \u2014 the per-bundle \"what these numbers describe\" link. When a Statistics node sits inside a StatisticsCollection that indexes more than one variable, cdif:appliesTo disambiguates which variable each bundle describes.","schema_type":"array","effectiveId":"https://cdif.org/0.1/appliesTo"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:hasWeight"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight","description":"The InstanceVariable whose values were used as weights when computing the Statistic entries (inline cdifInstanceVariable node or an @id-reference).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/statistic","description":"Ordered list of Statistic value objects carried by this bundle. Order is significant \u2014 consumers MAY rely on array position.","required":true,"schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/statistic"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic","cdi:typeOfNumericValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfNumericValue","description":"The type of numeric value carried in cdi:content \u2014 decimal, float, or double.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfNumericValue"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic","cdi:isWeighted"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isWeighted","description":"True if the statistic was computed using a weighting variable.","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isWeighted"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic","cdi:content"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content","description":"The value of the statistic expressed as a real number.","schema_type":"number","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic","cdi:computationBase"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/computationBase","description":"The cases included in determining the statistic \u2014 Total (all cases, valid and missing), ValidOnly (valid values only), MissingOnly (invalid cases only).","schema_type":"string","enum":["MissingOnly","Total","ValidOnly"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/computationBase"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:typeOfStatistic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfStatistic","description":"Controlled-vocabulary entry naming the kind of statistic \u2014 e.g. mean, median, count, sum, stdDev.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfStatistic"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:indexedBy"],"id":"https://cdif.org/0.1/indexedBy","description":"CDIF addition (not in canonical DDI-CDI): the InstanceVariable(s) the contained Statistics index \u2014 the collection-level coordinate space.","schema_type":"array","effectiveId":"https://cdif.org/0.1/indexedBy"},{"path":["cdif:isComposedOf","cdi:indexes","cdi:source"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/source","description":"Reference capturing provenance information for this InstanceVariable (InstanceVariable.source).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/source"},{"path":["cdif:isComposedOf","cdi:indexes","cdi:platformType"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/platformType","description":"The application or technical system context in which the variable has been realized - typically a statistical processing package or processing environment (InstanceVariable.platformType).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/platformType"},{"path":["cdif:isComposedOf","cdi:indexes","cdi:function"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/function","description":"Immutable characteristic of the variable such as geographic designator, weight, temporal designation, etc. (InstanceVariable.function).","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/function"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:uses"],"id":"https://cdif.org/0.1/uses","description":"Essentially the same as schema:propertyID. References to concepts that this variable measures or represents. When the dataset's distribution carries cdi:isStructuredBy (CDIF Data Structure profile), cdif:uses references the RepresentedVariable that supplies the represented-variable-level properties below, which are then NOT duplicated on the InstanceVariable.","schema_type":"array","effectiveId":"https://cdif.org/0.1/uses"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:simpleUnitOfMeasure"],"id":"https://cdif.org/0.1/simpleUnitOfMeasure","effectiveId":"https://cdif.org/0.1/simpleUnitOfMeasure"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:role"],"id":"https://cdif.org/0.1/role","description":"Specifies the role this variable plays in a data structure. UnitIdentifier names the unit a row describes; Measure holds observed/derived values; Attribute qualifies an observation; Dimension addresses a cell in a multi-dimensional cube; Descriptor names the variable that a Reference column records values for (long format); ReferenceVariable holds those recorded values.","schema_type":"string","enum":["UnitIdentifier","Measure","Attribute","Dimension","Descriptor","ReferenceVariable"],"effectiveId":"https://cdif.org/0.1/role"},{"path":["cdif:isComposedOf","cdi:indexes","cdif:physicalDataType"],"id":"https://cdif.org/0.1/physicalDataType","description":"identifier or name for the data type concept.","schema_type":"array","effectiveId":"https://cdif.org/0.1/physicalDataType"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url"],"id":"http://schema.org/url","effectiveId":"http://schema.org/url"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","schema:url"],"id":"http://schema.org/url","required":true,"schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole"],"id":"http://www.w3.org/ns/dcat#hadRole","description":"Role of the related resource as a SKOS Concept (DCAT canonical role slot).","effectiveId":"http://www.w3.org/ns/dcat#hadRole"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning of this concept.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying meaning and/or intended use.","effectiveId":"http://www.w3.org/2004/02/skos/core#scopeNote"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:historyNote"],"id":"http://www.w3.org/2004/02/skos/core#historyNote","description":"Note about past state or use.","effectiveId":"http://www.w3.org/2004/02/skos/core#historyNote"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:changeNote"],"id":"http://www.w3.org/2004/02/skos/core#changeNote","description":"Note documenting a change.","effectiveId":"http://www.w3.org/2004/02/skos/core#changeNote"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:editorialNote"],"id":"http://www.w3.org/2004/02/skos/core#editorialNote","description":"Note for editors and maintainers.","effectiveId":"http://www.w3.org/2004/02/skos/core#editorialNote"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:inScheme"],"id":"http://www.w3.org/2004/02/skos/core#inScheme","description":"Concept scheme(s) this concept belongs to.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#inScheme"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:topConceptOf"],"id":"http://www.w3.org/2004/02/skos/core#topConceptOf","description":"Concept scheme(s) for which this is a top concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#topConceptOf"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:broader"],"id":"http://www.w3.org/2004/02/skos/core#broader","description":"Broader (parent) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#broader"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:narrower"],"id":"http://www.w3.org/2004/02/skos/core#narrower","description":"Narrower (child) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#narrower"},{"path":["cdif:isComposedOf","cdi:indexes","schema:url","dcterms:relation"],"id":"http://purl.org/dc/terms/relation","description":"URI of the related resource (DCAT canonical pointer to what is being related to; distinct from schema:url which is the presentation URL inherited from labeledLink).","schema_type":"string","format":"uri","effectiveId":"http://purl.org/dc/terms/relation"},{"path":["cdif:isComposedOf","cdi:indexes","schema:maxValue"],"id":"http://schema.org/maxValue","description":"maximum numeric value in the dataset","schema_type":"number","effectiveId":"http://schema.org/maxValue"},{"path":["cdif:isComposedOf","cdi:indexes","schema:minValue"],"id":"http://schema.org/minValue","description":"minimum numeric value in the dataset","schema_type":"number","effectiveId":"http://schema.org/minValue"},{"path":["cdif:isComposedOf","cdi:indexes","schema:unitCode"],"id":"http://schema.org/unitCode","description":"URI or code identifying the unit of measure","effectiveId":"http://schema.org/unitCode"},{"path":["cdif:isComposedOf","cdi:indexes","schema:unitText"],"id":"http://schema.org/unitText","description":"unit of measurement as text","schema_type":"string","effectiveId":"http://schema.org/unitText"},{"path":["cdif:isComposedOf","cdi:indexes","schema:propertyID"],"id":"http://schema.org/propertyID","description":"identifier or name for the property concept","schema_type":"array","effectiveId":"http://schema.org/propertyID"},{"path":["cdif:isComposedOf","cdi:indexes","schema:measurementTechnique"],"id":"http://schema.org/measurementTechnique","description":"Text description or URI specifying how values for the variable were obtained.","effectiveId":"http://schema.org/measurementTechnique"},{"path":["cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["cdif:isComposedOf","cdi:indexes","schema:alternateName"],"id":"http://schema.org/alternateName","schema_type":"array","effectiveId":"http://schema.org/alternateName"},{"path":["cdif:isComposedOf","cdi:indexes","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["cdif:isComposedOf","cdi:indexes","schema:name"],"id":"http://schema.org/name","description":"string label associated with the variable in the dataset serialization","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"}]}