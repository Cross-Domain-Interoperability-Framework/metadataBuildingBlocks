{"defs":{},"properties":[{"path":["_oneOf"],"sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"keyword":"oneOf"},{"path":["_oneOf","0"],"title":"a","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"keyword":"branch"},{"path":["_oneOf","0","cdi:isDelimited"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited","required":true,"const":true,"sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited"},{"path":["_oneOf","0","cdi:isFixedWidth"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth","const":false,"sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth"},{"path":["_oneOf","1"],"title":"b","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"keyword":"branch"},{"path":["_oneOf","1","cdi:isDelimited"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited","const":false,"sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited"},{"path":["_oneOf","1","cdi:isFixedWidth"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth","required":true,"const":true,"sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth"},{"path":["cdi:arrayBase"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/arrayBase","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/arrayBase"},{"path":["csvw:commentPrefix"],"description":"An atomic property that sets the comment prefix flag to the single provided value, which MUST be a string. The default is '#'.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["csvw:delimiter"],"description":"Sets the delimiter flag to the single provided value, which MUST be a string. The default is ','.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["csvw:header"],"description":"If true, sets the header row count flag to 1, and if false to 0, unless headerRowCount is provided, in which case the value provided for the header property is ignored. The default is true.","schema_type":"boolean","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["csvw:headerRowCount"],"description":"A numeric atomic property that sets the header row count flag to the single provided value, which MUST be a non-negative integer.","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["cdi:isDelimited"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited","description":"Schema constraint is that one of {'isDelimited','isFixedWidth'} must be present with a True value; the other one may be present or omitted, but if present must have a false value.","schema_type":"boolean","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited"},{"path":["cdi:isFixedWidth"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth","schema_type":"boolean","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth"},{"path":["csvw:lineTerminators"],"schema_type":"string","enum":["CRLF","LF","\r\n","\n"],"sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["csvw:quoteChar"],"description":"Same as DDI-CDI quoteCharacter. The string that is used around escaped cells.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["csvw:skipBlankRows"],"schema_type":"boolean","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["csvw:skipColumns"],"description":"The number of columns to skip at the beginning of each row.","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["csvw:skipInitialSpace"],"schema_type":"boolean","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["csvw:skipRows"],"description":"The number of rows to skip at the beginning of the file, before a header row or tabular data.","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["cdi:escapeCharacter"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/escapeCharacter","description":"The character used to escape special characters in the data. From DDI-CDI PhysicalSegmentLayout.escapeCharacter.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/escapeCharacter"},{"path":["cdi:headerIsCaseSensitive"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/headerIsCaseSensitive","description":"Whether column header names are case-sensitive. From DDI-CDI PhysicalSegmentLayout.headerIsCaseSensitive.","schema_type":"boolean","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/headerIsCaseSensitive"},{"path":["cdi:treatConsecutiveDelimitersAsOne"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/treatConsecutiveDelimitersAsOne","description":"Whether consecutive delimiters should be treated as a single delimiter. From DDI-CDI PhysicalSegmentLayout.treatConsecutiveDelimitersAsOne.","schema_type":"boolean","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/treatConsecutiveDelimitersAsOne"},{"path":["csvw:tableDirection"],"description":"Indicates the direction of the table layout (left-to-right or right-to-left). From DDI-CDI PhysicalSegmentLayout.tableDirection.","schema_type":"string","enum":["Ltr","Rtl"],"sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["csvw:textDirection"],"description":"Indicates whether the text within cells should be displayed as left-to-right, right-to-left, according to content, or inherited from the table direction. From DDI-CDI PhysicalSegmentLayout.textDirection.","schema_type":"string","enum":["Auto","Inherit","Ltr","Rtl"],"sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["csvw:trim"],"description":"Indicates whether to trim whitespace around cells. 'true' corresponds to DDI-CDI 'both' value, 'false' corresponds to DDI-CDI 'neither' value.","schema_type":"string","enum":["true","end","false","start"],"sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["cdif:hasPhysicalMapping"],"id":"https://cdif.org/0.1/hasPhysicalMapping","description":"Links variables to their physical representation in this dataset.","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"],"effectiveId":"https://cdif.org/0.1/hasPhysicalMapping"},{"path":["cdif:hasPhysicalMapping","cdif:index"],"id":"https://cdif.org/0.1/index","description":"Non-negative integer that orders the fields in the data structure (column number).","schema_type":"integer","effectiveId":"https://cdif.org/0.1/index"},{"path":["cdif:hasPhysicalMapping","cdif:format"],"id":"https://cdif.org/0.1/format","description":"A format for number expressed as a string, or date format like YYYY/MM or MM-DD-YY.","schema_type":"string","effectiveId":"https://cdif.org/0.1/format"},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType"],"id":"https://cdif.org/0.1/physicalDataType","description":"identifier or name for the data type concept.","effectiveId":"https://cdif.org/0.1/physicalDataType"},{"path":["cdif:hasPhysicalMapping","cdi:numberPattern"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/numberPattern","description":"Number format pattern for the field (PhysicalMapping.numberPattern). Text-format properties (column width, decimal/digit-group separators, display label) live on cdifTextMapping.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/numberPattern"},{"path":["cdif:hasPhysicalMapping","cdi:nullSequence"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence","description":"The value of this property becomes the null annotation for the described column.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence"},{"path":["cdif:hasPhysicalMapping","cdi:defaultValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue","description":"A default string indicating the value to substitute for an empty string.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue"},{"path":["cdif:hasPhysicalMapping","cdi:scale"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale"},{"path":["cdif:hasPhysicalMapping","cdi:decimalPositions"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions"},{"path":["cdif:hasPhysicalMapping","cdi:minimumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength"},{"path":["cdif:hasPhysicalMapping","cdi:maximumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumLength","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumLength"},{"path":["cdif:hasPhysicalMapping","cdi:isRequired"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isRequired","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isRequired"},{"path":["cdif:hasPhysicalMapping","cdif:formats_InstanceVariable"],"id":"https://cdif.org/0.1/formats_InstanceVariable","description":"Reference to a variable defined in schema:variableMeasured.","schema_type":"object","effectiveId":"https://cdif.org/0.1/formats_InstanceVariable"},{"path":["countRows"],"schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["countColumns"],"schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifTabularData"]},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:narrower"],"description":"Narrower (child) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array"},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:broader"],"description":"Broader (parent) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array"},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:broader","skos:prefLabel"],"description":"Preferred lexical label for the concept scheme. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:broader","skos:altLabel"],"description":"Alternative lexical labels (acronyms, abbreviations, spelling variants)."},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:broader","skos:definition"],"description":"Formal explanation of the meaning or purpose of this concept scheme.","required":true},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:broader","skos:notation"],"description":"Classification code or notation for this concept scheme.","schema_type":"array"},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:broader","skos:note"],"description":"General note about the concept scheme."},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:broader","skos:hasTopConcept"],"description":"Top-level concepts in this scheme. Each item is a skos:Concept (inline or @id reference).","required":true,"schema_type":"array"},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:broader","schema:version"],"description":"Version identifier for the concept scheme.","schema_type":["string","number"]},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:broader","schema:subjectOf"],"schema_type":"array"},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:inScheme"],"description":"Concept scheme(s) this concept belongs to."},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:note"],"description":"General note about this concept."},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:definition"],"description":"Formal explanation of the meaning of this concept."},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:notation"],"description":"Classification code for this concept within a scheme.","required":true,"schema_type":"array"},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_anyOf","2","skos:prefLabel"],"description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType","_a