{"defs":{},"properties":[{"path":["cdi:value"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/value","description":"The fingerprint value (e.g., the hex digest). DataFingerprint.value.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifDataFingerprint"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/value"},{"path":["cdi:algorithmSpecification"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/algorithmSpecification","description":"Identifier or name of the algorithm specification (e.g., SHA-256, MD5). DataFingerprint.algorithmSpecification.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifDataFingerprint"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/algorithmSpecification"},{"path":["cdi:algorithmVersion"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/algorithmVersion","description":"Version of the fingerprint algorithm/specification. DataFingerprint.algorithmVersion.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifDataFingerprint"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/algorithmVersion"},{"path":["cdi:typeOfFingerprint"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfFingerprint","description":"The kind of fingerprint (e.g., checksum, hash, digest). DataFingerprint.typeOfFingerprint.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifDataFingerprint"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfFingerprint"}]}