schema.org/identifier"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","_anyOf","0","cdi:describedUnitOfMeasure","_anyOf","1","schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","_anyOf","0","cdi:describedUnitOfMeasure","_anyOf","1","schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","_anyOf","0","cdi:describedUnitOfMeasure","_anyOf","1","schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","_anyOf","0","cdi:describedUnitOfMeasure","_anyOf","1","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdif:uses_Concept"],"id":"https://cdif.org/0.1/uses_Concept","schema_type":"array","effectiveId":"https://cdif.org/0.1/uses_Concept"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdif:name"],"id":"https://cdif.org/0.1/name","description":"Human understandable name (linguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.","schema_type":"array","effectiveId":"https://cdif.org/0.1/name"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:externalDefinition"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/externalDefinition","description":"A reference to an external definition of a concept (that is, a concept which is described outside the content of the DDI-CDI metadata description). An example is a SKOS concept. The definition property is assumed to duplicate the external one referenced if externalDefinition is used. Other corresponding properties are assumed to be included unchanged if used.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/externalDefinition"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdif:displayLabel"],"id":"https://cdif.org/0.1/displayLabel","description":"A human-readable display label for the object. Supports the use of multiple languages. Repeat for labels with different content, for example, labels with differing length limitations.","schema_type":"array","effectiveId":"https://cdif.org/0.1/displayLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdif:definition"],"id":"https://cdif.org/0.1/definition","description":"Natural language statement conveying the meaning of a concept, differentiating it from other concepts. Supports the use of multiple languages and structured text. 'externalDefinition' can't be used if 'definition' is used.","schema_type":"string","effectiveId":"https://cdif.org/0.1/definition"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:unitOfMeasureKind"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/unitOfMeasureKind","description":"Kind of unit of measure, so that it may be prone to translation to equivalent UOMs. Example values include \"acceleration,\" \"temperature,\" \"salinity\", etc. This description exists at the conceptual level, indicating a limitation on the type of representations which may be used for the variable as it is made more concrete.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/unitOfMeasureKind"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:measures"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/measures","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/measures"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:measures","cdif:descriptiveText"],"id":"https://cdif.org/0.1/descriptiveText","description":"A short natural language account of the characteristics of the object.","schema_type":"string","effectiveId":"https://cdif.org/0.1/descriptiveText"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:measures","cdif:definition"],"id":"https://cdif.org/0.1/definition","description":"Natural language statement conveying the meaning of a concept, differentiating it from other concepts. Supports the use of multiple languages and structured text. 'externalDefinition' can't be used if 'definition' is used.","schema_type":"string","effectiveId":"https://cdif.org/0.1/definition"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:measures","cdif:displayLabel"],"id":"https://cdif.org/0.1/displayLabel","description":"A human-readable display label for the object. Supports the use of multiple languages. Repeat for labels with different content, for example, labels with differing length limitations.","schema_type":"array","effectiveId":"https://cdif.org/0.1/displayLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:measures","cdi:externalDefinition"],"id":"h