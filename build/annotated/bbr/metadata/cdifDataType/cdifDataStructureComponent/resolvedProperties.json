tiveText","description":"A short natural language account of the characteristics of the object.","schema_type":"string","effectiveId":"https://cdif.org/0.1/descriptiveText"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:simpleUnitOfMeasure"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/simpleUnitOfMeasure","description":"The unit in which the data values are measured (kg, pound, euro), expressed as a simple string, in cases where no additional information is available (in the legacy system) or needed (as in the case of broad agreement within the community of use [i.e., ISO country codes, currencies, etc. in SDMX])","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/simpleUnitOfMeasure"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveValuesFrom"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesSubstantiveValuesFrom","description":"The substantive value domain for this RepresentedVariable - the set of valid, meaningful values (RepresentedVariable.takesSubstantiveValuesFrom).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesSubstantiveValuesFrom"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveValuesFrom","cdif:takesValuesFrom"],"id":"https://cdif.org/0.1/takesValuesFrom","effectiveId":"https://cdif.org/0.1/takesValuesFrom"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveValuesFrom","cdif:displayLabel"],"id":"https://cdif.org/0.1/displayLabel","description":"A human-readable display label for the object. ","schema_type":"string","effectiveId":"https://cdif.org/0.1/displayLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveValuesFrom","cdif:recommendedDataType"],"id":"https://cdif.org/0.1/recommendedDataType","description":"The data types that are recommended for use with this domain.","schema_type":"array","effectiveId":"https://cdif.org/0.1/recommendedDataType"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveValuesFrom","cdi:isDescribedBy"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDescribedBy","description":"A ValueAndConceptDescription giving the formal description (ranges, patterns, classification level, expressions) of the values this domain admits.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDescribedBy"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesSentinelValuesFrom","description":"Sentinel (missing / not-applicable) value domain(s) for this RepresentedVariable (RepresentedVariable.takesSentinelValuesFrom).","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesSentinelValuesFrom"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom"],"id":"https://cdif.org/0.1/takesValuesFrom","effectiveId":"https://cdif.org/0.1/takesValuesFrom"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:purpose"],"id":"https://cdif.org/0.1/purpose","description":"Intent or reason for the object/the description of the object.","schema_type":"string","effectiveId":"https://cdif.org/0.1/purpose"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references"],"id":"https://cdif.org/0.1/references","description":"CDIF codelist (skos:ConceptScheme) whose concepts define the allowed values of this enumeration domain.","required":true,"effectiveId":"https://cdif.org/0.1/references"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:identifier"],"id":"http://schema.org/identifier","description":"Primary identifier for the codelist. May be a string URI or a structured PropertyValue.","required":true,"effectiveId":"http://schema.org/identifier"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:identifier","schema:url"],"id":"http://schema.org/url","schema_type":"string","effectiveId":"http://schema.org/url"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:identifier","schema:value"],"id":"http://schema.org/value","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:dateModified"],"id":"http://schema.org/dateModified","description":"ISO 8601 date when the codelist was last modified.","required":true,"schema_type":"string","effectiveId":"http://schema.org/dateModified"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:url"],"id":"http://schema.org/url","description":"Web location of a page describing the codelist.","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:license"],"id":"http://schema.org/license","description":"License for the codelist.","schema_type":"array","effectiveId":"http://schema.org/license"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:conditionsOfAccess"],"id":"http://schema.org/conditionsOfAccess","description":"Text statement of access conditions for the codelist.","schema_type":"array","effectiveId":"http://schema.org/conditionsOfAccess"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for the concept scheme. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"schema_type":"string","effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning or purpose of this concept scheme.","schema_type":"string","effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about the concept scheme.","schema_type":"string","effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept"],"id":"http://www.w3.org/2004/02/skos/core#hasTopConcept","description":"Top-level concepts that have no skos:broader in this scheme. Required for hierarchical codelists.","required":true,"schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#hasTopConcept"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept","skos:inScheme"],"id":"http://www.w3.org/2004/02/skos/core#inScheme","description":"The concept scheme this concept belongs to. Required for CDIF codelist concepts.","required":true,"schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#inScheme"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"schema_type":"string","effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept","skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","required":true,"schema_type":"string","effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal definition of this concept. Optional for CDIF codelist concepts. A plain string.","schema_type":"string","effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept","skos:narrower"],"id":"http://www.w3.org/2004/02/skos/core#narrower","description":"Narrower (child) concepts. If present, each inline concept must also declare skos:broader pointing back to the parent concept. Both skos:narrower and skos:broader must be explicit in CDIF codelists.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#narrower"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept","skos:broader"],"id":"http://www.w3.org/2004/02/skos/core#broader","description":"Broader (parent) concepts. Required on any concept that appears as a skos:narrower value of another concept. CDIF requires both directions to be explicit for hierarchy traversal.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#broader"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:subjectOf"],"id":"http://schema.org/subjectOf","description":"Catalog record describing this codelist as CDIF-conformant metadata. Must declare conformance to the cdifCodelist profile via dcterms:conformsTo and be typed as schema:Dataset with schema:additionalType including dcat:CatalogRecord.","schema_type":"object","effectiveId":"http://schema.org/subjectOf"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:subjectOf","schema:additionalType"],"id":"http://schema.org/additionalType","required":true,"schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:subjectOf","dcterms:conformsTo"],"id":"http://purl.org/dc/terms/conformsTo","required":true,"schema_type":"array","effectiveId":"http://purl.org/dc/terms/conformsTo"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:subjectOf","schema:about"],"id":"http://schema.org/about","schema_type":"object","effectiveId":"http://schema.org/about"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","schema:name"],"id":"http://schema.org/name","description":"Human understandable name (liguistic signifier, word, phrase, or mnemonic).","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:identifier"],"id":"https://cdif.org/0.1/identifier","description":"Identifier for this enumerated (categorical) domain.","effectiveId":"https://cdif.org/0.1/identifier"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:displayLabel"],"id":"https://cdif.org/0.1/displayLabel","description":"A human-readable display label for the object. Supports the use of multiple languages. Repeat for labels with different content, for example, labels with differing length limitations.","schema_type":"string","effectiveId":"https://cdif.org/0.1/displayLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:recommendedDataType"],"id":"https://cdif.org/0.1/recommendedDataType","description":"The data types that are recommended for use with this domain.","schema_type":"array","effectiveId":"https://cdif.org/0.1/recommendedDataType"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdi:isDescribedBy"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDescribedBy","description":"A ValueAndConceptDescription giving the formal description (ranges, patterns, classification level, expressions) of the values this domain admits.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDescribedBy"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdi:isDescribedBy","cdi:regularExpression"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/regularExpression","description":"A regular expression where strings matching the expression belong to the set of valid values.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/regularExpression"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdi:isDescribedBy","cdi:minimumValueInclusive"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumValueInclusive","description":"A string denoting the minimum possible value. From the W3C Recommendation \"Metadata Vocabulary for Tabular Data\" (https://www.w3.org/TR/tabular-metadata/) 5.11.2: \"minimum: An atomic property that contains a single number or string that is the minimum valid value (inclusive); equivalent to minInclusive. The value of this property becomes the minimum annotation for the described datatype. See Value Constraints in [tabular-data-model] for details.\"","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumValueInclusive"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdi:isDescribedBy","cdi:minimumValueExclusive"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumValueExclusive","description":"A string denoting the minimum possible value (excluding this value). From the W3C Recommendation \"Metadata Vocabulary for Tabular Data\" (https://www.w3.org/TR/tabular-metadata/) 5.11.2: \"minExclusive: An atomic property that contains a single number or string that is the minimum valid value (exclusive). The value of this property becomes the minimum exclusive annotation for the described datatype. See Value Constraints in [tabular-data-model] for details.\"","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumValueExclusive"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdi:isDescribedBy","cdi:maximumValueInclusive"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumValueInclusive","description":"A string denoting the maximum possible value. From the W3C Recommendation \"Metadata Vocabulary for Tabular Data\" (https://www.w3.org/TR/tabular-metadata/) 5.11.2: \"maximum: An atomic property that contains a single number or string that is the maximum valid value (inclusive); equivalent to maxInclusive. The value of this property becomes the maximum annotation for the described datatype. See Value Constraints in [tabular-data-model] for details.\"","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumValueInclusive"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdi:isDescribedBy","cdi:maximumValueExclusive"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumValueExclusive","description":"A string denoting the maximum possible value (excluding this value). From the W3C Recommendation \"Metadata Vocabulary for Tabular Data\" (https://www.w3.org/TR/tabular-metadata/) 5.11.2: \"maxExclusive: An atomic property that contains a single number or string that is the maximum valid value (exclusive). The value of this property becomes the maximum exclusive annotation for the described datatype. See Value Constraints in [tabular-data-model] for details.\"","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumValueExclusive"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdi:isDescribedBy","cdi:logicalExpression"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/logicalExpression","description":"A logical expression where the values of \"x\" making the expression true are the members of the set of valid values. For example, \"(all reals x such that x > 0)\" describes the real numbers greater than 0.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/logicalExpression"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdi:isDescribedBy","cdi:formatPattern"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/formatPattern","description":"A pattern for a number as described in Unicode Locale Data Markup Language (LDML) (http://www.unicode.org/reports/tr35/tr35.html) Part 3: Numbers (http://www.unicode.org/reports/tr35/tr35-numbers.html#Number_Format_Patterns) and Part 4. Dates (http://www.unicode.org/reports/tr35/tr35-dates.html#Date_Format_Patterns) . Examples would be #,##0.### to describe the pattern for a decimal number, or yyyy.MM.dd G 'at' HH:mm:ss zzz for a datetime pattern.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/formatPattern"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdi:isDescribedBy","cdi:description"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description","description":"A formal description of the set of values in human-readable language.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdi:isDescribedBy","cdi:classificationLevel"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/classificationLevel","description":"Indicates the type of relationship, nominal, ordinal, interval, ratio, or continuous. Use where appropriate for the representation type.","schema_type":"string","enum":["Continuous","Interval","Nominal","Ordinal","Ratio"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/classificationLevel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:hasIntendedDataType"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasIntendedDataType","description":"The data type intended to be used by this variable. Supports the optional use of an external controlled vocabulary.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasIntendedDataType"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/describedUnitOfMeasure","description":"The unit in which the data values are measured (kg, pound, euro), expressed as a value from a controlled system of entries (i.e., QDT). Supports the provision of an identifier for the entry in the authoritative source (a URI, etc.), and the specific vocabulary.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/describedUnitOfMeasure"},{"path":["_anyOf","2","cdi:qualifies","cdi:semantic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic","description":"Qualifies the purpose or use expressed as a paired external controlled vocabulary.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic"},{"path":["_anyOf","2","cdi:qualifies","cdif:isDefinedBy_RepresentedVariable"],"id":"https://cdif.org/0.1/isDefinedBy_RepresentedVariable","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifDataStructureComponent"],"effectiveId":"https://cdif.org/0.1/isDefinedBy_RepresentedVariable"},{"path":["_anyOf","2","cdi:qualifies","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","sources":["bblocks://cdif.bbr.metadata.cdifDataType.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"}]}