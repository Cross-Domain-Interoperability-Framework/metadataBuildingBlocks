.org/name"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for person, recommend ORCID","effectiveId":"http://schema.org/identifier"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:alternateName"],"id":"http://schema.org/alternateName","description":"other labels by which the person might be known","schema_type":"string","effectiveId":"http://schema.org/alternateName"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:affiliation"],"id":"http://schema.org/affiliation","description":"if affiliation is present, value must be a schema:Organization.","effectiveId":"http://schema.org/affiliation"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:affiliation","schema:additionalType"],"id":"http://schema.org/additionalType","schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:affiliation","schema:name"],"id":"http://schema.org/name","description":"string label for organization that is meaningful for human users","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:affiliation","schema:alternateName"],"id":"http://schema.org/alternateName","description":"other labels by which the organization might be known","schema_type":"string","effectiveId":"http://schema.org/alternateName"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:affiliation","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:affiliation","schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for organization","effectiveId":"http://schema.org/identifier"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:affiliation","schema:sameAs"],"id":"http://schema.org/sameAs","description":"other identifiers for the organization","schema_type":"array","effectiveId":"http://schema.org/sameAs"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:contactPoint"],"id":"http://schema.org/contactPoint","description":"restrict to email only. Schema.org allows telephone and postal contacts as well","schema_type":"object","effectiveId":"http://schema.org/contactPoint"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:contactPoint","schema:email"],"id":"http://schema.org/email","required":true,"schema_type":"string","effectiveId":"http://schema.org/email"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:sameAs"],"id":"http://schema.org/sameAs","description":"other identifiers for the person","schema_type":"array","effectiveId":"http://schema.org/sameAs"},{"path":["prov:wasAssociatedWith","_anyOf","2"],"title":"b","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"keyword":"branch"},{"path":["prov:wasAssociatedWith","_anyOf","2","schema:roleName"],"id":"http://schema.org/roleName","required":true,"effectiveId":"http://schema.org/roleName"},{"path":["prov:wasAssociatedWith","_anyOf","2","schema:contributor"],"id":"http://schema.org/contributor","required":true,"effectiveId":"http://schema.org/contributor"},{"path":["prov:wasInformedBy"],"id":"http://www.w3.org/ns/prov#wasInformedBy","description":"Other activities that communicated information to this one (PROV-O activity-to-activity chain -- maps to schema:object in cdifProvActivity)","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://www.w3.org/ns/prov#wasInformedBy"},{"path":["prov:startedAtTime"],"id":"http://www.w3.org/ns/prov#startedAtTime","description":"ISO8601 date-time when the activity started (PROV-O native -- maps to schema:startTime in cdifProvActivity)","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://www.w3.org/ns/prov#startedAtTime"},{"path":["prov:endedAtTime"],"id":"http://www.w3.org/ns/prov#endedAtTime","description":"ISO8601 date-time when the activity ended (PROV-O native -- maps to schema:endTime in cdifProvActivity)","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://www.w3.org/ns/prov#endedAtTime"},{"path":["prov:atLocation"],"id":"http://www.w3.org/ns/prov#atLocation","description":"Location where the activity occurred (PROV-O expanded term -- maps to schema:location in cdifProvActivity)","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://www.w3.org/ns/prov#atLocation"},{"path":["prov:wasStartedBy"],"id":"http://www.w3.org/ns/prov#wasStartedBy","description":"Entity that triggered the start of this activity (PROV-O expanded term)","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://www.w3.org/ns/prov#wasStartedBy"},{"path":["prov:wasEndedBy"],"id":"http://www.w3.org/ns/prov#wasEndedBy","description":"Entity that triggered the end of this activity (PROV-O expanded term)","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://www.w3.org/ns/prov#wasEndedBy"},{"path":["schema:actionStatus"],"id":"http://schema.org/actionStatus","description":"Status of this activity (schema.org fallback -- no PROV-O equivalent)","schema_type":"string","enum":["schema:CompletedActionStatus","schema:ActiveActionStatus","schema:PotentialActionStatus","schema:FailedActionStatus"],"sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://schema.org/actionStatus"},{"path":["schema:actionProcess"],"id":"http://schema.org/actionProcess","description":"Methodology or protocol for this activity (schema.org fallback -- PROV-O has prov:hadPlan only inside qualified Association)","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://schema.org/actionProcess"},{"path":["schema:error"],"id":"http://schema.org/error","description":"Error description for failed activities (schema.org fallback -- no PROV-O equivalent)","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://schema.org/error"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:affiliation","schema:additionalType","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:affiliation","schema:additionalType","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:affiliation","schema:additionalType","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:affiliation","schema:additionalType","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["prov:wasAssociatedWith","_anyOf","0","schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["prov:atLocation","geosparql:hasGeometry"],"description":"Optional geographic extent using wkt geometry, see Ocean InfoHub (https://book.oceaninfohub.org/thematics/spatial/README.html#simple-geosparql-wkt). Other geometry schemes might be specified in a specific domain profile, e.g. for atmospheric, subsurface data, or local coordinate systems. NOTE that the location specified here should be the same as the schema.org point or contained within the specified bounding box.","schema_type":"object"},{"path":["prov:atLocation","geosparql:hasGeometry","geosparql:crs"],"schema_type":"object"},{"path":["prov:atLocation","geosparql:hasGeometry","geosparql:asWKT"],"schema_type":"object"},{"path":["prov:atLocation","schema:geo"],"id":"http://schema.org/geo","description":"Either a bounding box or a point location.","effectiveId":"http://schema.org/geo"},{"path":["prov:atLocation","schema:geo","_anyOf"],"keyword":"anyOf"},{"path":["prov:atLocation","schema:geo","_anyOf","2"],"title":"c","keyword":"branch"},{"path":["prov:atLocation","schema:geo","_anyOf","2","schema:line"],"id":"http://schema.org/line","description":"A GeoShape box defines a curvilinear geometry as a string of latitude-longitude coordinates. A space should be used to separate the latitude and longitude values. The coordinate point pairs are also separated by a space. 'East longitude' means positive longitude values are east of the prime (Greenwich) meridian. e.g. '39.33 120.77 40.44 123.96 41.00 121.34' ","required":true,"schema_type":"string","effectiveId":"http://schema.org/line"},{"path":["prov:atLocation","schema:geo","_anyOf","1"],"title":"b","keyword":"branch"},{"path":["prov:atLocation","schema:geo","_anyOf","1","schema:box"],"id":"http://schema.org/box","description":"A GeoShape box defines an area on the surface of the earth defined by point locations of the southwest corner and northeast corner of the rectangle in latitude-longitude coordinates. A space should be used to separate the latitude and longitude values. The two corner coordinate points are separated by a space. 'East longitude' means positive longitude values are east of the prime (Greenwich) meridian.","required":true,"schema_type":"string","effectiveId":"http://schema.org/box"},{"path":["prov:atLocation","schema:geo","_anyOf","0"],"title":"a","keyword":"branch"},{"path":["prov:atLocation","schema:geo","_anyOf","0","schema:longitude"],"id":"http://schema.org/longitude","required":true,"schema_type":"number","effectiveId":"http://schema.org/longitude"},{"path":["prov:atLocation","schema:geo","_anyOf","0","schema:latitude"],"id":"http://schema.org/latitude","required":true,"schema_type":"number","effectiveId":"http://schema.org/latitude"},{"path":["prov:atLocation","schema:alternateName"],"id":"http://schema.org/alternateName","description":"Alternate or abbreviated name(s) for this place.","schema_type":"array","effectiveId":"http://schema.org/alternateName"},{"path":["prov:atLocation","schema:identifier"],"id":"http://schema.org/identifier","description":"Formal identifier for this place (e.g. ROR identifier for a facility).","effectiveId":"http://schema.org/identifier"},{"path":["prov:atLocation","schema:name"],"id":"http://schema.org/name","description":"A place name for the location, either as a string or a DefinedTerm from a gazetteer.","effectiveId":"http://schema.org/name"},{"path":["prov:atLocation","schema:additionalType"],"id":"http://schema.org/additionalType","description":"Domain-specific type classifications for this place (e.g. facility type,laboratory classification, feature type).","schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["schema:actionProcess","schema:step"],"id":"http://schema.org/step","description":"Ordered steps in this methodology","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://schema.org/step"},{"path":["schema:actionProcess","schema:step","schema:position"],"id":"http://schema.org/position","description":"Ordinal position of this step","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://schema.org/position"},{"path":["schema:actionProcess","schema:step","schema:url"],"id":"http://schema.org/url","description":"URL to documentation for this step","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://schema.org/url"},{"path":["schema:actionProcess","schema:step","schema:description"],"id":"http://schema.org/description","description":"Description of what this step involves","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://schema.org/description"},{"path":["schema:actionProcess","schema:step","schema:name"],"id":"http://schema.org/name","description":"Name of this step","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://schema.org/name"},{"path":["schema:actionProcess","schema:url"],"id":"http://schema.org/url","description":"URL to a published methodology or protocol document","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://schema.org/url"},{"path":["schema:actionProcess","schema:description"],"id":"http://schema.org/description","description":"Description of the methodology","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://schema.org/description"},{"path":["schema:actionProcess","schema:name"],"id":"http://schema.org/name","description":"Name of the methodology or protocol","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.provProperties.provActivity"],"effectiveId":"http://schema.org/name"}]}