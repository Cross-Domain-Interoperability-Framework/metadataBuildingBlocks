{"defs":{},"properties":[{"path":["skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for the concept scheme. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["skos:altLabel"],"id":"http://www.w3.org/2004/02/skos/core#altLabel","description":"Alternative lexical labels (acronyms, abbreviations, spelling variants).","effectiveId":"http://www.w3.org/2004/02/skos/core#altLabel"},{"path":["skos:hiddenLabel"],"id":"http://www.w3.org/2004/02/skos/core#hiddenLabel","description":"Labels accessible to free-text search but not displayed.","effectiveId":"http://www.w3.org/2004/02/skos/core#hiddenLabel"},{"path":["skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning or purpose of this concept scheme.","effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code or notation for this concept scheme.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about the concept scheme.","effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying the intended scope of the concept scheme.","effectiveId":"http://www.w3.org/2004/02/skos/core#scopeNote"},{"path":["skos:historyNote"],"id":"http://www.w3.org/2004/02/skos/core#historyNote","description":"Note about the history of the concept scheme.","effectiveId":"http://www.w3.org/2004/02/skos/core#historyNote"},{"path":["skos:changeNote"],"id":"http://www.w3.org/2004/02/skos/core#changeNote","description":"Note documenting a change to the concept scheme.","effectiveId":"http://www.w3.org/2004/02/skos/core#changeNote"},{"path":["skos:editorialNote"],"id":"http://www.w3.org/2004/02/skos/core#editorialNote","description":"Note for editors, translators, and maintainers.","effectiveId":"http://www.w3.org/2004/02/skos/core#editorialNote"},{"path":["skos:example"],"id":"http://www.w3.org/2004/02/skos/core#example","description":"Example of the use of this concept scheme.","effectiveId":"http://www.w3.org/2004/02/skos/core#example"},{"path":["skos:hasTopConcept"],"id":"http://www.w3.org/2004/02/skos/core#hasTopConcept","description":"Top-level concepts in this scheme. Each item is a skos:Concept (inline or @id reference).","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://www.w3.org/2004/02/skos/core#hasTopConcept"},{"path":["dcterms:creator"],"id":"http://purl.org/dc/terms/creator","description":"Agent(s) who created this concept scheme.","effectiveId":"http://purl.org/dc/terms/creator"},{"path":["dcterms:creator","_anyOf"],"keyword":"anyOf"},{"path":["dcterms:creator","_anyOf","1"],"title":"a","keyword":"branch"},{"path":["dcterms:creator","_anyOf","1","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["dcterms:creator","_anyOf","2"],"title":"b","keyword":"branch"},{"path":["dcterms:created"],"id":"http://purl.org/dc/terms/created","description":"Date the concept scheme was created (ISO 8601).","schema_type":"string","effectiveId":"http://purl.org/dc/terms/created"},{"path":["dcterms:modified"],"id":"http://purl.org/dc/terms/modified","description":"Date the concept scheme was last modified (ISO 8601).","schema_type":"string","effectiveId":"http://purl.org/dc/terms/modified"},{"path":["dcterms:title"],"id":"http://purl.org/dc/terms/title","description":"Title of the concept scheme (Dublin Core). Prefer skos:prefLabel for the SKOS label; dcterms:title may be used for additional metadata.","effectiveId":"http://purl.org/dc/terms/title"},{"path":["dcterms:description"],"id":"http://purl.org/dc/terms/description","description":"Description of the concept scheme (Dublin Core).","effectiveId":"http://purl.org/dc/terms/description"},{"path":["dcterms:license"],"id":"http://purl.org/dc/terms/license","description":"License for the concept scheme.","effectiveId":"http://purl.org/dc/terms/license"},{"path":["dcterms:rights"],"id":"http://purl.org/dc/terms/rights","description":"Rights statement for the concept scheme.","schema_type":"string","effectiveId":"http://purl.org/dc/terms/rights"},{"path":["schema:version"],"id":"http://schema.org/version","description":"Version identifier for the concept scheme.","schema_type":["string","number"],"effectiveId":"http://schema.org/version"},{"path":["schema:identifier"],"id":"http://schema.org/identifier","description":"Primary identifier for the codelist. May be a string URI or a structured PropertyValue.","required":true,"sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://schema.org/identifier"},{"path":["schema:dateModified"],"id":"http://schema.org/dateModified","description":"ISO 8601 date when the codelist was last modified.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://schema.org/dateModified"},{"path":["schema:url"],"id":"http://schema.org/url","description":"Web location of a page describing the codelist.","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://schema.org/url"},{"path":["schema:license"],"id":"http://schema.org/license","description":"License for the codelist.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://schema.org/license"},{"path":["schema:conditionsOfAccess"],"id":"http://schema.org/conditionsOfAccess","description":"Text statement of access conditions for the codelist.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://schema.org/conditionsOfAccess"},{"path":["skos:hasTopConcept","skos:inScheme"],"id":"http://www.w3.org/2004/02/skos/core#inScheme","description":"The concept scheme this concept belongs to. Required for CDIF codelist concepts.","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://www.w3.org/2004/02/skos/core#inScheme"},{"path":["skos:hasTopConcept","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["skos:hasTopConcept","skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","required":true,"sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["skos:hasTopConcept","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal definition of this concept. Required for CDIF codelist concepts. String or language-tagged values.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["skos:hasTopConcept","skos:narrower"],"id":"http://www.w3.org/2004/02/skos/core#narrower","description":"Narrower (child) concepts. If present, each inline concept must also declare skos:broader pointing back to the parent concept. Both skos:narrower and skos:broader must be explicit in CDIF codelists.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://www.w3.org/2004/02/skos/core#narrower"},{"path":["skos:hasTopConcept","skos:broader"],"id":"http://www.w3.org/2004/02/skos/core#broader","description":"Broader (parent) concepts. Required on any concept that appears as a skos:narrower value of another concept. CDIF requires both directions to be explicit for hierarchy traversal.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://www.w3.org/2004/02/skos/core#broader"},{"path":["dcterms:creator","_anyOf","2","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["skos:hasTopConcept","skos:topConceptOf"],"id":"http://www.w3.org/2004/02/skos/core#topConceptOf","description":"Concept scheme(s) for which this is a top concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#topConceptOf"},{"path":["skos:hasTopConcept","skos:editorialNote"],"id":"http://www.w3.org/2004/02/skos/core#editorialNote","description":"Note for editors and maintainers.","effectiveId":"http://www.w3.org/2004/02/skos/core#editorialNote"},{"path":["skos:hasTopConcept","skos:changeNote"],"id":"http://www.w3.org/2004/02/skos/core#changeNote","description":"Note documenting a change.","effectiveId":"http://www.w3.org/2004/02/skos/core#changeNote"},{"path":["skos:hasTopConcept","skos:historyNote"],"id":"http://www.w3.org/2004/02/skos/core#historyNote","description":"Note about past state or use.","effectiveId":"http://www.w3.org/2004/02/skos/core#historyNote"},{"path":["skos:hasTopConcept","skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["skos:hasTopConcept","skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying meaning and/or intended use.","effectiveId":"http://www.w3.org/2004/02/skos/core#scopeNote"},{"path":["schema:identifier","schema:url"],"id":"http://schema.org/url","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://schema.org/url"},{"path":["schema:identifier","schema:value"],"id":"http://schema.org/value","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://schema.org/value"},{"path":["schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfiles.CDIFCodelistProfile"],"effectiveId":"http://schema.org/propertyID"}]}