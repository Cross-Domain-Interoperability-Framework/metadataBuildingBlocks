{"defs":{"0":[{"path":["time:hasTRS"],"id":"http://www.w3.org/2006/time#hasTRS","description":"identifier for a temporal reference system; default is million years before prsent as a decimal number","required":true,"schema_type":"string","effectiveId":"http://www.w3.org/2006/time#hasTRS"},{"path":["time:numericPosition"],"id":"http://www.w3.org/2006/time#numericPosition","required":true,"schema_type":"number","effectiveId":"http://www.w3.org/2006/time#numericPosition"}]},"properties":[{"path":["schema:measurementTechnique"],"description":"The technique, technology, or methodology used for measurement or determination of the dataset values.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifDiscovery"]},{"path":["schema:variableMeasured"],"description":"What does the dataset measure? (e.g., temperature, pressure)","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifDiscovery"]},{"path":["schema:variableMeasured","schema:name"],"id":"http://schema.org/name","description":"string label associated with the variable in the dataset serialization","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:variableMeasured","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:variableMeasured","schema:alternateName"],"id":"http://schema.org/alternateName","schema_type":"array","effectiveId":"http://schema.org/alternateName"},{"path":["schema:variableMeasured","schema:measurementTechnique"],"id":"http://schema.org/measurementTechnique","description":"Text description or URI specifying how values for the variable were obtained.","effectiveId":"http://schema.org/measurementTechnique"},{"path":["schema:variableMeasured","schema:propertyID"],"id":"http://schema.org/propertyID","description":"identifier or name for the property concept","schema_type":"array","effectiveId":"http://schema.org/propertyID"},{"path":["schema:variableMeasured","schema:unitText"],"id":"http://schema.org/unitText","description":"unit of measurement as text","schema_type":"string","effectiveId":"http://schema.org/unitText"},{"path":["schema:variableMeasured","schema:unitCode"],"id":"http://schema.org/unitCode","description":"URI or code identifying the unit of measure","effectiveId":"http://schema.org/unitCode"},{"path":["schema:variableMeasured","schema:minValue"],"id":"http://schema.org/minValue","description":"minimum numeric value in the dataset","schema_type":"number","effectiveId":"http://schema.org/minValue"},{"path":["schema:variableMeasured","schema:maxValue"],"id":"http://schema.org/maxValue","description":"maximum numeric value in the dataset","schema_type":"number","effectiveId":"http://schema.org/maxValue"},{"path":["schema:variableMeasured","schema:url"],"id":"http://schema.org/url","effectiveId":"http://schema.org/url"},{"path":["schema:spatialCoverage"],"description":"Geographic extent of resource content.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifDiscovery"]},{"path":["schema:spatialCoverage","schema:additionalType"],"id":"http://schema.org/additionalType","description":"Domain-specific type classifications for this place (e.g. facility type,laboratory classification, feature type).","schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["schema:spatialCoverage","schema:name"],"id":"http://schema.org/name","description":"A place name for the location, either as a string or a DefinedTerm from a gazetteer.","effectiveId":"http://schema.org/name"},{"path":["schema:spatialCoverage","schema:identifier"],"id":"http://schema.org/identifier","description":"Formal identifier for this place (e.g. ROR identifier for a facility).","effectiveId":"http://schema.org/identifier"},{"path":["schema:spatialCoverage","schema:alternateName"],"id":"http://schema.org/alternateName","description":"Alternate or abbreviated name(s) for this place.","schema_type":"array","effectiveId":"http://schema.org/alternateName"},{"path":["schema:spatialCoverage","schema:geo"],"id":"http://schema.org/geo","description":"Either a bounding box or a point location.","effectiveId":"http://schema.org/geo"},{"path":["schema:spatialCoverage","schema:geo","_anyOf"],"keyword":"anyOf"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","0"],"title":"a","keyword":"branch"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","0","schema:latitude"],"id":"http://schema.org/latitude","required":true,"schema_type":"number","effectiveId":"http://schema.org/latitude"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","0","schema:longitude"],"id":"http://schema.org/longitude","required":true,"schema_type":"number","effectiveId":"http://schema.org/longitude"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","1"],"title":"b","keyword":"branch"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","1","schema:box"],"id":"http://schema.org/box","description":"A GeoShape box defines an area on the surface of the earth defined by point locations of the southwest corner and northeast corner of the rectangle in latitude-longitude coordinates. A space should be used to separate the latitude and longitude values. The two corner coordinate points are separated by a space. 'East longitude' means positive longitude values are east of the prime (Greenwich) meridian.","required":true,"schema_type":"string","effectiveId":"http://schema.org/box"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","2"],"title":"c","keyword":"branch"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","2","schema:line"],"id":"http://schema.org/line","description":"A GeoShape box defines a curvilinear geometry as a string of latitude-longitude coordinates. A space should be used to separate the latitude and longitude values. The coordinate point pairs are also separated by a space. 'East longitude' means positive longitude values are east of the prime (Greenwich) meridian. e.g. '39.33 120.77 40.44 123.96 41.00 121.34' ","required":true,"schema_type":"string","effectiveId":"http://schema.org/line"},{"path":["schema:spatialCoverage","geosparql:hasGeometry"],"description":"Optional geographic extent using wkt geometry, see Ocean InfoHub (https://book.oceaninfohub.org/thematics/spatial/README.html#simple-geosparql-wkt). Other geometry schemes might be specified in a specific domain profile, e.g. for atmospheric, subsurface data, or local coordinate systems. NOTE that the location specified here should be the same as the schema.org point or contained within the specified bounding box.","schema_type":"object"},{"path":["schema:spatialCoverage","geosparql:hasGeometry","geosparql:asWKT"],"schema_type":"object"},{"path":["schema:spatialCoverage","geosparql:hasGeometry","geosparql:crs"],"schema_type":"object"},{"path":["schema:temporalCoverage"],"description":"Temporal extent of resource content.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifDiscovery"]},{"path":["schema:temporalCoverage","_anyOf"],"keyword":"anyOf"},{"path":["schema:temporalCoverage","_anyOf","0"],"title":"a","keyword":"branch"},{"path":["schema:temporalCoverage","_anyOf","0","schema:description"],"id":"http://schema.org/description","description":"free text description of the temporal interval","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:temporalCoverage","_anyOf","0","time:intervalStartedBy"],"id":"http://www.w3.org/2006/time#intervalStartedBy","description":"identifier for a named time ordinal era that is older bound of time interval, e.g. 'isc:LowerDevonian' ","schema_type":"string","format":"uri","effectiveId":"http://www.w3.org/2006/time#intervalStartedBy"},{"path":["schema:temporalCoverage","_anyOf","0","time:intervalFinishedBy"],"id":"http://www.w3.org/2006/time#intervalFinishedBy","description":"identifier for a named time ordinal era that is younger bound of time interval, e.g. 'isc:LowerDevonian' ","schema_type":"string","format":"uri","effectiveId":"http://www.w3.org/2006/time#intervalFinishedBy"},{"path":["schema:temporalCoverage","_anyOf","1"],"title":"b","keyword":"branch"},{"path":["schema:temporalCoverage","_anyOf","1","schema:description"],"id":"http://schema.org/description","description":"free text description of the temporal interval","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:temporalCoverage","_anyOf","1","time:hasBeginning"],"id":"http://www.w3.org/2006/time#hasBeginning","schema_type":"object","effectiveId":"http://www.w3.org/2006/time#hasBeginning"},{"path":["schema:temporalCoverage","_anyOf","1","time:hasBeginning","time:inTimePosition"],"id":"http://www.w3.org/2006/time#inTimePosition","ref":"0","effectiveId":"http://www.w3.org/2006/time#inTimePosition"},{"path":["schema:temporalCoverage","_anyOf","1","time:hasEnd"],"id":"http://www.w3.org/2006/time#hasEnd","schema_type":"object","effectiveId":"http://www.w3.org/2006/time#hasEnd"},{"path":["schema:temporalCoverage","_anyOf","1","time:hasEnd","time:inTimePosition"],"id":"http://www.w3.org/2006/time#inTimePosition","ref":"0","effectiveId":"http://www.w3.org/2006/time#inTimePosition"},{"path":["dqv:hasQualityMeasurement"],"description":"Quality measurements reported to assess the resource.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifDiscovery"]},{"path":["dqv:hasQualityMeasurement","dqv:isMeasurementOf"],"description":"specify the quality measure that is reported, by name, with an ID ref, or as a Defined Term","required":true},{"path":["dqv:hasQualityMeasurement","dqv:value"],"description":"the reported result of the quality measure, either as a string or a defined term from a vocabulary","required":true},{"path":["schema:subjectOf"],"sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifDiscovery"]},{"path":["schema:subjectOf","dcterms:conformsTo"],"sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifDiscovery"]},{"path":["schema:variableMeasured","schema:url","schema:url"],"id":"http://schema.org/url","required":true,"schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:variableMeasured","schema:url","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:variableMeasured","schema:url","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:measurementTechnique","_anyOf","2"],"title":"a","keyword":"branch"},{"path":["schema:measurementTechnique","_anyOf","2","skos:narrower"],"description":"Narrower (child) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array"},{"path":["schema:measurementTechnique","_anyOf","2","skos:broader"],"description":"Broader (parent) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array"},{"path":["schema:measurementTechnique","_anyOf","2","skos:broader","skos:prefLabel"],"description":"Preferred lexical label for the concept scheme. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true},{"path":["schema:measurementTechnique","_anyOf","2","skos:broader","skos:altLabel"],"description":"Alternative lexical labels (acronyms, abbreviations, spelling variants)."},{"path":["schema:measurementTechnique","_anyOf","2","skos:broader","skos:definition"],"description":"Formal explanation of the meaning or purpose of this concept scheme.","required":true},{"path":["schema:measurementTechnique","_anyOf","2","skos:broader","skos:notation"],"description":"Classification code or notation for this concept scheme.","schema_type":"array"},{"path":["schema:measurementTechnique","_anyOf","2","skos:broader","skos:note"],"description":"General note about the concept scheme."},{"path":["schema:measurementTechnique","_anyOf","2","skos:broader","skos:hasTopConcept"],"description":"Top-level concepts in this scheme. Each item is a skos:Concept (inline or @id reference).","required":true,"schema_type":"array"},{"path":["schema:measurementTechnique","_anyOf","2","skos:broader","schema:version"],"description":"Version identifier for the concept scheme.","schema_type":["string","number"]},{"path":["schema:measurementTechnique","_anyOf","2","skos:broader","schema:subjectOf"],"description":"Catalog record describing this concept scheme as CDIF-conformant metadata. Must declare conformance to the cdifConceptScheme profile via dcterms:conformsTo and be typed as schema:Dataset with schema:additionalType including dcat:CatalogRecord.","schema_type":"object"},{"path":["schema:measurementTechnique","_anyOf","2","skos:broader","schema:subjectOf","schema:additionalType"],"required":true,"schema_type":"array"},{"path":["schema:measurementTechnique","_anyOf","2","skos:broader","schema:subjectOf","dcterms:conformsTo"],"required":true,"schema_type":"array"},{"path":["schema:measurementTechnique","_anyOf","2","skos:broader","schema:subjectOf","schema:about"],"schema_type":"object"},{"path":["schema:measurementTechnique","_anyOf","2","skos:inScheme"],"description":"Concept scheme(s) this concept belongs to."},{"path":["schema:measurementTechnique","_anyOf","2","skos:note"],"description":"General note about this concept."},{"path":["schema:measurementTechnique","_anyOf","2","skos:definition"],"description":"Formal explanation of the meaning of this concept."},{"path":["schema:measurementTechnique","_anyOf","2","skos:notation"],"description":"Classification code for this concept within a scheme.","required":true,"schema_type":"array"},{"path":["schema:measurementTechnique","_anyOf","2","skos:prefLabel"],"description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true},{"path":["schema:measurementTechnique","_anyOf","1","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["schema:measurementTechnique","_anyOf","1","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["schema:measurementTechnique","_anyOf","1","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:measurementTechnique","_anyOf","1","schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["schema:measurementTechnique","_anyOf","1","schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["schema:measurementTechnique","_anyOf","1","schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:measurementTechnique","_anyOf","1","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"}]}