{"defs":{"0":[{"path":["cdi:decimalPositions"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions"},{"path":["cdi:defaultValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue","description":"A default string indicating the value to substitute for an empty string.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue"},{"path":["cdi:isRequired"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isRequired","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isRequired"},{"path":["cdi:locator"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/locator","description":"String that can be used by software to locate values of the variable in this physical dataset (DDI-CDI LocatorMapping.locator).","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/locator"},{"path":["cdi:maximumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumLength","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumLength"},{"path":["cdi:minimumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength"},{"path":["cdi:nullSequence"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence","description":"The value of this property becomes the null annotation for the described column.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence"},{"path":["cdi:numberPattern"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/numberPattern","description":"Number format pattern for the field (PhysicalMapping.numberPattern). Text-format properties (column width, decimal/digit-group separators, display label) live on cdifTextMapping.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/numberPattern"},{"path":["cdi:scale"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale"},{"path":["cdif:format"],"id":"https://cdif.org/0.1/format","description":"A format for number expressed as a string, or date format like YYYY/MM or MM-DD-YY.","schema_type":"string","effectiveId":"https://cdif.org/0.1/format"},{"path":["cdif:formats_InstanceVariable"],"id":"https://cdif.org/0.1/formats_InstanceVariable","description":"Reference to a variable defined in schema:variableMeasured.","schema_type":"object","effectiveId":"https://cdif.org/0.1/formats_InstanceVariable"},{"path":["cdif:index"],"id":"https://cdif.org/0.1/index","description":"Non-negative integer that orders the fields in the data structure (column number).","schema_type":"integer","effectiveId":"https://cdif.org/0.1/index"},{"path":["cdif:physicalDataType"],"id":"https://cdif.org/0.1/physicalDataType","schema_type":"string","effectiveId":"https://cdif.org/0.1/physicalDataType"}]},"properties":[{"path":["schema:subjectOf"],"sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:subjectOf","dcterms:conformsTo"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:distribution"],"sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:distribution","schema:hasPart"],"description":"For archive-style distributions (e.g. ZIP files containing multiple component files), describes the component files. Each component is typed as schema:MediaObject and may include CDIF data description extensions (cdifTabularData, cdifDataCube) to describe its internal structure.","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:distribution","schema:hasPart","schema:name"],"description":"Filename of the component file within the archive.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:distribution","schema:hasPart","schema:description"],"description":"Description of the file content. May include checksum information.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:distribution","schema:hasPart","schema:encodingFormat"],"description":"MIME type(s) for this file.","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:distribution","schema:hasPart","schema:size"],"description":"File size as a QuantitativeValue.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:distribution","schema:hasPart","schema:size","schema:value"],"description":"Numeric size value.","schema_type":"number","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:distribution","schema:hasPart","schema:size","schema:unitText"],"description":"Unit of measure for size (e.g. 'byte').","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:distribution","schema:hasPart","schema:about"],"description":"For metadata sidecar files, references the data file this metadata describes.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:distribution","schema:hasPart","spdx:checksum"],"description":"Checksum for integrity verification of this component file.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:distribution","schema:hasPart","spdx:checksum","spdx:algorithm"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:distribution","schema:hasPart","spdx:checksum","spdx:checksumValue"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"]},{"path":["schema:distribution","schema:hasPart","_anyOf"],"sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"],"keyword":"anyOf"},{"path":["schema:distribution","schema:hasPart","_anyOf","0"],"title":"a","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"],"keyword":"branch"},{"path":["schema:distribution","schema:hasPart","_anyOf","0","cdif:hasPhysicalMapping"],"id":"https://cdif.org/0.1/hasPhysicalMapping","description":"Links variables to their physical representation in this dataset.","schema_type":"array","ref":"0","effectiveId":"https://cdif.org/0.1/hasPhysicalMapping"},{"path":["schema:distribution","schema:hasPart","_anyOf","1"],"title":"b","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"],"keyword":"branch"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","_oneOf"],"keyword":"oneOf"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","_oneOf","0"],"title":"a","keyword":"branch"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","_oneOf","0","cdi:isDelimited"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited","required":true,"const":true,"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","_oneOf","0","cdi:isFixedWidth"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth","const":false,"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","_oneOf","1"],"title":"b","keyword":"branch"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","_oneOf","1","cdi:isDelimited"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited","const":false,"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","_oneOf","1","cdi:isFixedWidth"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth","required":true,"const":true,"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","cdi:arrayBase"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/arrayBase","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/arrayBase"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","csvw:commentPrefix"],"description":"An atomic property that sets the comment prefix flag to the single provided value, which MUST be a string. The default is '#'.","schema_type":"string"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","csvw:delimiter"],"description":"Sets the delimiter flag to the single provided value, which MUST be a string. The default is ','.","schema_type":"string"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","csvw:header"],"description":"If true, sets the header row count flag to 1, and if false to 0, unless headerRowCount is provided, in which case the value provided for the header property is ignored. The default is true.","schema_type":"boolean"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","csvw:headerRowCount"],"description":"A numeric atomic property that sets the header row count flag to the single provided value, which MUST be a non-negative integer.","schema_type":"integer"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","cdi:isDelimited"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited","description":"Schema constraint is that one of {'isDelimited','isFixedWidth'} must be present with a True value; the other one may be present or omitted, but if present must have a false value.","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","cdi:isFixedWidth"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","csvw:lineTerminators"],"schema_type":"string","enum":["CRLF","LF","\r\n","\n"]},{"path":["schema:distribution","schema:hasPart","_anyOf","1","csvw:quoteChar"],"description":"Same as DDI-CDI quoteCharacter. The string that is used around escaped cells.","schema_type":"string"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","csvw:skipBlankRows"],"schema_type":"boolean"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","csvw:skipColumns"],"description":"The number of columns to skip at the beginning of each row.","schema_type":"integer"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","csvw:skipInitialSpace"],"schema_type":"boolean"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","csvw:skipRows"],"description":"The number of rows to skip at the beginning of the file, before a header row or tabular data.","schema_type":"integer"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","cdi:escapeCharacter"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/escapeCharacter","description":"The character used to escape special characters in the data. From DDI-CDI PhysicalSegmentLayout.escapeCharacter.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/escapeCharacter"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","cdi:headerIsCaseSensitive"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/headerIsCaseSensitive","description":"Whether column header names are case-sensitive. From DDI-CDI PhysicalSegmentLayout.headerIsCaseSensitive.","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/headerIsCaseSensitive"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","cdi:treatConsecutiveDelimitersAsOne"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/treatConsecutiveDelimitersAsOne","description":"Whether consecutive delimiters should be treated as a single delimiter. From DDI-CDI PhysicalSegmentLayout.treatConsecutiveDelimitersAsOne.","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/treatConsecutiveDelimitersAsOne"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","csvw:tableDirection"],"description":"Indicates the direction of the table layout (left-to-right or right-to-left). From DDI-CDI PhysicalSegmentLayout.tableDirection.","schema_type":"string","enum":["Ltr","Rtl"]},{"path":["schema:distribution","schema:hasPart","_anyOf","1","csvw:textDirection"],"description":"Indicates whether the text within cells should be displayed as left-to-right, right-to-left, according to content, or inherited from the table direction. From DDI-CDI PhysicalSegmentLayout.textDirection.","schema_type":"string","enum":["Auto","Inherit","Ltr","Rtl"]},{"path":["schema:distribution","schema:hasPart","_anyOf","1","csvw:trim"],"description":"Indicates whether to trim whitespace around cells. 'true' corresponds to DDI-CDI 'both' value, 'false' corresponds to DDI-CDI 'neither' value.","schema_type":"string","enum":["true","end","false","start"]},{"path":["schema:distribution","schema:hasPart","_anyOf","1","cdif:hasPhysicalMapping"],"id":"https://cdif.org/0.1/hasPhysicalMapping","description":"Links variables to their physical representation in this dataset.","required":true,"schema_type":"array","ref":"0","effectiveId":"https://cdif.org/0.1/hasPhysicalMapping"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","countRows"],"schema_type":"integer"},{"path":["schema:distribution","schema:hasPart","_anyOf","1","countColumns"],"schema_type":"integer"},{"path":["schema:distribution","_then"],"sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifManifest"],"keyword":"then"}]}