{"defs":{},"properties":[{"path":["schema:identifier"],"id":"http://schema.org/identifier","description":"Primary identifier for the codelist. May be a string URI or a structured PropertyValue.","required":true,"sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://schema.org/identifier"},{"path":["schema:dateModified"],"id":"http://schema.org/dateModified","description":"ISO 8601 date when the codelist was last modified.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://schema.org/dateModified"},{"path":["schema:url"],"id":"http://schema.org/url","description":"Web location of a page describing the codelist.","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://schema.org/url"},{"path":["schema:license"],"id":"http://schema.org/license","description":"License for the codelist.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://schema.org/license"},{"path":["schema:conditionsOfAccess"],"id":"http://schema.org/conditionsOfAccess","description":"Text statement of access conditions for the codelist.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://schema.org/conditionsOfAccess"},{"path":["skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for the concept scheme. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning or purpose of this concept scheme.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about the concept scheme.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["skos:hasTopConcept"],"id":"http://www.w3.org/2004/02/skos/core#hasTopConcept","description":"Top-level concepts that have no skos:broader in this scheme. Required for hierarchical codelists.","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://www.w3.org/2004/02/skos/core#hasTopConcept"},{"path":["skos:hasTopConcept","skos:inScheme"],"id":"http://www.w3.org/2004/02/skos/core#inScheme","description":"The concept scheme this concept belongs to. Required for CDIF codelist concepts.","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://www.w3.org/2004/02/skos/core#inScheme"},{"path":["skos:hasTopConcept","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["skos:hasTopConcept","skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["skos:hasTopConcept","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal definition of this concept. Optional for CDIF codelist concepts. A plain string.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["skos:hasTopConcept","skos:narrower"],"id":"http://www.w3.org/2004/02/skos/core#narrower","description":"Narrower (child) concepts. If present, each inline concept must also declare skos:broader pointing back to the parent concept. Both skos:narrower and skos:broader must be explicit in CDIF codelists.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://www.w3.org/2004/02/skos/core#narrower"},{"path":["skos:hasTopConcept","skos:broader"],"id":"http://www.w3.org/2004/02/skos/core#broader","description":"Broader (parent) concepts. Required on any concept that appears as a skos:narrower value of another concept. CDIF requires both directions to be explicit for hierarchy traversal.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://www.w3.org/2004/02/skos/core#broader"},{"path":["schema:subjectOf"],"id":"http://schema.org/subjectOf","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://schema.org/subjectOf"},{"path":["schema:identifier","schema:url"],"id":"http://schema.org/url","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://schema.org/url"},{"path":["schema:identifier","schema:value"],"id":"http://schema.org/value","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://schema.org/value"},{"path":["schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.profiles.cdifProfile.cdifCodelist"],"effectiveId":"http://schema.org/propertyID"}]}