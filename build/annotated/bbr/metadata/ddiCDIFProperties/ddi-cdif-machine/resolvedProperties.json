nce.org/Specification/DDI-CDI/1.0/RDF/function","description":"Function performed by this machine","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-machine"],"ref":"1","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/function"},{"path":["cdi:machineInterface"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/machineInterface","description":"Interface type for this machine","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-machine"],"ref":"1","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/machineInterface"},{"path":["cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"Name(s) of this machine","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-machine"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["cdi:ownerOperatorContact"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ownerOperatorContact","description":"Contact information for the owner or operator","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-machine"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ownerOperatorContact"},{"path":["cdi:ownerOperatorContact","cdi:address"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/address","description":"Postal address(es)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/address"},{"path":["cdi:ownerOperatorContact","cdi:email"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/email","description":"Email address(es)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/email"},{"path":["cdi:ownerOperatorContact","cdi:emessaging"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/emessaging","description":"Electronic messaging contact(s)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/emessaging"},{"path":["cdi:ownerOperatorContact","cdi:telephone"],"id":"http://