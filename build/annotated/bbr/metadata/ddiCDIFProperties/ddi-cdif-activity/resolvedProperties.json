{"defs":{},"properties":[{"path":["cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"Structured name for the activity (ObjectName)","required":true,"sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["cdi:description"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description","description":"Plain text description of the activity","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description"},{"path":["cdi:definition"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/definition","description":"Formal multilingual definition (InternationalString)","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/definition"},{"path":["cdi:displayLabel"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/displayLabel","description":"Multilingual display label","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/displayLabel"},{"path":["cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Formal identifier for this activity","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["cdi:identifier","cdi:ddiIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiIdentifier","description":"DDI-specific IRDI identifier","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiIdentifier"},{"path":["cdi:identifier","cdi:uri"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri","description":"URI form of t