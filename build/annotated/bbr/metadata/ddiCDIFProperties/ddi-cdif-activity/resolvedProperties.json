CDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/end"},{"path":["cdi:hasSubActivity"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasSubActivity","description":"Nested sub-activities (cdi:Activity). @id references.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasSubActivity"},{"path":["cdi:has_Step"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/has_Step","description":"Ordered steps within this activity (cdi:Step)","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/has_Step"},{"path":["cdi:hasInternal"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasInternal","description":"Internal control logic elements (cdi:ControlLogic). @id references.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasInternal"},{"path":["cdi:identifier","cdi:nonDdiIdentifier","cdi:managingAgency"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/managingAgency","description":"Agency managing this identifier scheme","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/managingAgency"},{"path":["cdi:identifier","cdi:nonDdiIdentifier","cdi:identifierContent"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifierContent","description":"The identifier value","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifierContent"},{"path":["cdi:name","cdi:context"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/context","description":"Context or usage of this name","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/context"},{"path":["cdi:name","cdi:context","cdi:vocabulary"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary","description":"A reference to the external controlled vocabulary, using a URI or other resolvable identifier.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary"},{"path":["cdi:name","cdi:context","cdi:valueForOther"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther","description":"If the value of the string is \"Other\" or the equivalent from the codelist, this attribute can provide a more specific value not found in the codelist.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther"},{"path":["cdi:name","cdi:context","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"The name of the code list (controlled vocabulary).","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["cdi:name","cdi:context","cdi:entryValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue","description":"The value of the entry of the controlled vocabulary. If no controlled vocabulary is used the term is entered here and none of the properties defining the controlled vocabulary location are used.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue"},{"path":["cdi:name","cdi:context","cdi:entryReference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference","description":"A reference to the specific item in the vocabulary referenced by cdi:vocabulary, using a URI or other resolvable identifier.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference"},{"path":["cdi:name","cdi:context","cdi:entryReference","cdi:semantic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic","description":"Semantic role of this reference","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic"},{"path":["cdi:name","cdi:context","cdi:entryReference","cdi:ddiReference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiReference","description":"DDI IRDI reference","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiReference"},{"path":["cdi:name","cdi:context","cdi:entryReference","cdi:ddiReference","cdi:versionIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/versionIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/versionIdentifier"},{"path":["cdi:name","cdi:context","cdi:entryReference","cdi:ddiReference","cdi:registrationAuthorityIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/registrationAuthorityIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/registrationAuthorityIdentifier"},{"path":["cdi:name","cdi:context","cdi:entryReference","cdi:ddiReference","cdi:dataIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/dataIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/dataIdentifier"},{"path":["cdi:name","cdi:context","cdi:entryReference","cdi:description"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description","description":"Human-readable description of the reference","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description"},{"path":["cdi:name","cdi:context","cdi:entryReference","cdi:uri"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri","description":"URI of the referenced entity","schema_type":"string","format":"uri","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri"},{"path":["cdi:name","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RD