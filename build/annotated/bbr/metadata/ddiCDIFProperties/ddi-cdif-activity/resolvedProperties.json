cification/DDI-CDI/1.0/RDF/end"},{"path":["cdi:has_Step","cdi:start"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/start","description":"Start date-time of the step (xsd:dateTime)","schema_type":"string","format":"date-time","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/start"},{"path":["cdi:has_Step","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["cdi:has_Step","cdi:definition"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/definition","description":"Formal multilingual definition (InternationalString)","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/definition"},{"path":["cdi:has_Step","cdi:description"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description","description":"Plain text description of the step","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description"},{"path":["cdi:has_Step","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"Structured name for the step","required":true,"sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-activity"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"}]}