{"defs":{"0":[{"path":["cdi:ddiReference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiReference","description":"DDI IRDI reference","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiReference"},{"path":["cdi:ddiReference","cdi:dataIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/dataIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/dataIdentifier"},{"path":["cdi:ddiReference","cdi:registrationAuthorityIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/registrationAuthorityIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/registrationAuthorityIdentifier"},{"path":["cdi:ddiReference","cdi:versionIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/versionIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/versionIdentifier"},{"path":["cdi:description"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description","description":"Human-readable description of the reference","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description"},{"path":["cdi:semantic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic","description":"Semantic role of this reference","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic"},{"path":["cdi:semantic","cdi:entryReference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference","description":"A reference to the specific item in the vocabulary referenced by cdi:vocabulary, using a URI or other resolvable identifier.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference"},{"path":["cdi:semantic","cdi:entryValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue","description":"The value of the entry of the controlled vocabulary. If no controlled vocabulary is used the term is entered here and none of the properties defining the controlled vocabulary location are used.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue"},{"path":["cdi:semantic","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"The name of the code list (controlled vocabulary).","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["cdi:semantic","cdi:valueForOther"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther","description":"If the value of the string is \"Other\" or the equivalent from the codelist, this attribute can provide a more specific value not found in the codelist.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther"},{"path":["cdi:semantic","cdi:vocabulary"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary","description":"A reference to the external controlled vocabulary, using a URI or other resolvable identifier.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary"},{"path":["cdi:uri"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri","description":"URI of the referenced entity","schema_type":"string","format":"uri","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri"}]},"properties":[{"path":["cdi:entryReference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference","description":"A reference to the specific item in the vocabulary referenced in the vocabulary attribute, using a URI or other resolvable identifier.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-controlled-vocabulary-entry"],"ref":"0","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference"},{"path":["cdi:entryValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue","description":"The value of the entry of the controlled vocabulary. If no controlled vocabulary is used the term is entered here and none of the properties defining the controlled vocabulary location are used.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-controlled-vocabulary-entry"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue"},{"path":["cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"The name of the code list (controlled vocabulary).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-controlled-vocabulary-entry"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["cdi:valueForOther"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther","description":"If the value of the string is \"Other\" or the equivalent from the codelist, this attribute can provide a more specific value not found in the codelist.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-controlled-vocabulary-entry"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther"},{"path":["cdi:vocabulary"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary","description":"A reference to the external controlled vocabulary, using a URI or other resolvable identifier.","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-controlled-vocabulary-entry"],"ref":"0","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary"}]}