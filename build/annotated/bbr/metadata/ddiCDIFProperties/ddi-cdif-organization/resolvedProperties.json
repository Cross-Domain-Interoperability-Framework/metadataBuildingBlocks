{"defs":{},"properties":[{"path":["cdi:organizationName"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/organizationName","description":"Name(s) of this organization","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-organization"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/organizationName"},{"path":["cdi:contactInformation"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/contactInformation","description":"Contact details for this organization","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-organization"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/contactInformation"},{"path":["cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Formal identifier for this agent","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-organization"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["cdi:identifier","cdi:ddiIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiIdentifier","description":"DDI-specific IRDI identifier","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiIdentifier"},{"path":["cdi:identifier","cdi:uri"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri","description":"URI form of the identifier","schema_type":"string","format":"uri","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri"},{"path":["cdi:identifier","cdi:nonDdiIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nonDdiIdentifier","description":"Non-DDI identifier","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nonDdiIdentifier"},{"path":["cdi:image"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/image","description":"Image associated with this agent","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-organization"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/image"},{"path":["cdi:image","cdi:effectiveDates"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/effectiveDates","description":"Date range when this image is effective","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/effectiveDates"},{"path":["cdi:image","cdi:privacy"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/privacy","description":"Privacy classification","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/privacy"},{"path":["cdi:purpose"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose","description":"Purpose or role of this agent","sources":["bblocks://cdif.bbr.metadata.ddiCDIFProperties.ddi-cdif-organization"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose"},{"path":["cdi:identifier","cdi:nonDdiIdentifier","cdi:managingAgency"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/managingAgency","description":"Agency managing this identifier scheme","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/managingAgency"},{"path":["cdi:identifier","cdi:nonDdiIdentifier","cdi:identifierContent"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifierContent","description":"The identifier value","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifierContent"},{"path":["cdi:organizationName","cdi:typeOfOrganizationName"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfOrganizationName","description":"Classification of this name (e.g. legal, trade, acronym)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfOrganizationName"},{"path":["cdi:organizationName","cdi:isFormal"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFormal","description":"Whether this is the formal/legal name","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFormal"},{"path":["cdi:organizationName","cdi:effectiveDates"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/effectiveDates","description":"Date range when this name is/was effective","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/effectiveDates"},{"path":["cdi:organizationName","cdi:effectiveDates","cdi:endDate"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/endDate","description":"End date of the range","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/endDate"},{"path":["cdi:organizationName","cdi:effectiveDates","cdi:startDate"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/startDate","description":"Start date of the range","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/startDate"},{"path":["cdi:organizationName","cdi:effectiveDates","cdi:startDate","cdi:historicDate"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/historicDate","description":"Free-text historic date","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/historicDate"},{"path":["cdi:organizationName","cdi:effectiveDates","cdi:startDate","cdi:isoDate"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isoDate","description":"ISO 8601 date-time value","schema_type":"string","format":"date-time","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isoDate"},{"path":["cdi:organizationName","cdi:abbreviation"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/abbreviation","description":"Abbreviated form of the name","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/abbreviation"},{"path":["cdi:organizationName","cdi:abbreviation","cdi:languageSpecificString"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/languageSpecificString","description":"Language-tagged string value(s)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/languageSpecificString"},{"path":["cdi:organizationName","cdi:abbreviation","cdi:languageSpecificString","cdi:content"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content","description":"The text content","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content"},{"path":["cdi:organizationName","cdi:abbreviation","cdi:languageSpecificString","cdi:language"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/language","description":"ISO language code (e.g. en, fr, de)","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/language"},{"path":["cdi:organizationName","cdi:context"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/context","description":"Context or usage of this name","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/context"},{"path":["cdi:organizationName","cdi:context","cdi:vocabulary"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary","description":"A reference to the external controlled vocabulary, using a URI or other resolvable identifier.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary"},{"path":["cdi:organizationName","cdi:context","cdi:valueForOther"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther","description":"If the value of the string is \"Other\" or the equivalent from the codelist, this attribute can provide a more specific value not found in the codelist.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther"},{"path":["cdi:organizationName","cdi:context","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"The name of the code list (controlled vocabulary).","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["cdi:organizationName","cdi:context","cdi:entryValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue","description":"The value of the entry of the controlled vocabulary. If no controlled vocabulary is used the term is entered here and none of the properties defining the controlled vocabulary location are used.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue"},{"path":["cdi:organizationName","cdi:context","cdi:entryReference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference","description":"A reference to the specific item in the vocabulary referenced by cdi:vocabulary, using a URI or other resolvable identifier.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference"},{"path":["cdi:organizationName","cdi:context","cdi:entryReference","cdi:semantic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic","description":"Semantic role of this reference","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic"},{"path":["cdi:organizationName","cdi:context","cdi:entryReference","cdi:ddiReference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiReference","description":"DDI IRDI reference","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiReference"},{"path":["cdi:organizationName","cdi:context","cdi:entryReference","cdi:ddiReference","cdi:versionIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/versionIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/versionIdentifier"},{"path":["cdi:organizationName","cdi:context","cdi:entryReference","cdi:ddiReference","cdi:registrationAuthorityIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/registrationAuthorityIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/registrationAuthorityIdentifier"},{"path":["cdi:organizationName","cdi:context","cdi:entryReference","cdi:ddiReference","cdi:dataIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/dataIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/dataIdentifier"},{"path":["cdi:organizationName","cdi:context","cdi:entryReference","cdi:description"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description","description":"Human-readable description of the reference","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description"},{"path":["cdi:organizationName","cdi:context","cdi:entryReference","cdi:uri"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri","description":"URI of the referenced entity","schema_type":"string","format":"uri","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri"},{"path":["cdi:organizationName","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"The name string","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["cdi:contactInformation","cdi:website"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/website","description":"Website link(s)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/website"},{"path":["cdi:contactInformation","cdi:website","cdi:uri"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri","description":"URI of the website","schema_type":"string","format":"uri","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri"},{"path":["cdi:contactInformation","cdi:website","cdi:typeOfWebsite"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfWebsite","description":"Type of website (e.g. homepage, documentation)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfWebsite"},{"path":["cdi:contactInformation","cdi:website","cdi:isPreferred"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isPreferred","description":"Whether this is the preferred website","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isPreferred"},{"path":["cdi:contactInformation","cdi:telephone"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/telephone","description":"Telephone number(s)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/telephone"},{"path":["cdi:contactInformation","cdi:telephone","cdi:telephoneNumber"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/telephoneNumber","description":"Telephone number string","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/telephoneNumber"},{"path":["cdi:contactInformation","cdi:telephone","cdi:typeOfTelephone"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfTelephone","description":"Type of telephone (e.g. mobile, office, fax)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfTelephone"},{"path":["cdi:contactInformation","cdi:telephone","cdi:isPreferred"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isPreferred","description":"Whether this is the preferred telephone","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isPreferred"},{"path":["cdi:contactInformation","cdi:emessaging"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/emessaging","description":"Electronic messaging contact(s)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/emessaging"},{"path":["cdi:contactInformation","cdi:emessaging","cdi:contactAddress"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/contactAddress","description":"Messaging address or handle","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/contactAddress"},{"path":["cdi:contactInformation","cdi:emessaging","cdi:typeOfService"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfService","description":"Type of messaging service (e.g. Slack, Teams)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfService"},{"path":["cdi:contactInformation","cdi:emessaging","cdi:isPreferred"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isPreferred","description":"Whether this is the preferred messaging service","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isPreferred"},{"path":["cdi:contactInformation","cdi:email"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/email","description":"Email address(es)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/email"},{"path":["cdi:contactInformation","cdi:email","cdi:internetEmail"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/internetEmail","description":"Email address string","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/internetEmail"},{"path":["cdi:contactInformation","cdi:email","cdi:typeOfEmail"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfEmail","description":"Type of email (e.g. personal, work)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfEmail"},{"path":["cdi:contactInformation","cdi:email","cdi:isPreferred"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isPreferred","description":"Whether this is the preferred email","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isPreferred"},{"path":["cdi:contactInformation","cdi:address"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/address","description":"Postal address(es)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/address"},{"path":["cdi:contactInformation","cdi:address","cdi:line"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/line","description":"Address line(s)","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/line"},{"path":["cdi:contactInformation","cdi:address","cdi:cityPlaceLocal"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/cityPlaceLocal","description":"City, town, or locality","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/cityPlaceLocal"},{"path":["cdi:contactInformation","cdi:address","cdi:stateProvince"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/stateProvince","description":"State, province, or region","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/stateProvince"},{"path":["cdi:contactInformation","cdi:address","cdi:postalCode"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/postalCode","description":"Postal or ZIP code","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/postalCode"},{"path":["cdi:contactInformation","cdi:address","cdi:countryCode"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/countryCode","description":"Country code","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/countryCode"},{"path":["cdi:contactInformation","cdi:address","cdi:typeOfAddress"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfAddress","description":"Type of address (e.g. home, work, mailing)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfAddress"},{"path":["cdi:contactInformation","cdi:address","cdi:isPreferred"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isPreferred","description":"Whether this is the preferred address","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isPreferred"}]}