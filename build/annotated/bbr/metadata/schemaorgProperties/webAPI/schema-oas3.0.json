      "$defs": {
        "cdifConcept": {
          "type": "object",
          "properties": {
            "@context": {
              "description": "JSON-LD context declaring the skos namespace prefix. May be a single object or an array of strings and objects.",
              "type": "object",
              "properties": {
                "skos": {
                  "enum": [
                    "http://www.w3.org/2004/02/skos/core#"
                  ]
                }
              },
              "required": [
                "skos"
              ]
            },
            "@id": {
              "type": "string",
