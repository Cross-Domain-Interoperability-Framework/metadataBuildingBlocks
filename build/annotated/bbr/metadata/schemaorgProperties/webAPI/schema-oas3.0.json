    "cdif.bbr.metadata.profiles.cdifProfile.cdifConceptScheme": {
      "title": "CDIF Concept Scheme",
      "description": "Profile module for SKOS concept schemes used as controlled vocabularies in CDIF metadata. Thin wrapper around skosConceptScheme.",
      "type": "object",
      "properties": {
        "@context": {
          "description": "JSON-LD context declaring the skos namespace prefix and any additional prefixes used in concept URIs. May be a single object or an array of strings and objects.",
          "type": "object",
          "properties": {
            "skos": {
              "enum": [
                "http://www.w3.org/2004/02/skos/core#"
              ]
            }
          },
          "required": [
            "skos"
          ]
        },
        "@id": {
          "type": "string",
          "description": "URI identifier for this concept scheme."
        },
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "enum": [
              "skos:ConceptScheme"
            ]
          },
          "minItems": 1
        },
        "skos:prefLabel": {
          "description": "Preferred lexical label for the concept scheme. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "$ref": "https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/schemaorgProperties/webAPI/schema-oas3.0.json#/x-defs/cdif.bbr.metadata.profiles.cdifProfile.cdifConceptScheme/$defs/LanguageTaggedValue"
            },
            {
              "type": "array",
              "items": {
                "$ref": "https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/schemaorgProperties/webAPI/schema-oas3.0.json#/x-defs/cdif.bbr.metadata.profiles.cdifProfile.cdifConceptScheme/$defs/LanguageTaggedValue"
              }
            }
          ]
        },
        "skos:altLabel": {
          "description": "Alternative lexical labels (acronyms, abbreviations, spelling variants).",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "$ref": "https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/schemaorgProperties/webAPI/schema-oas3.0.json#/x-defs/cdif.bbr.metadata.profiles.cdifProfile.cdifConceptScheme/$defs/LanguageTaggedValue"
            },
            {
              "type": "array",
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "$ref": "https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/schemaorgProperties/webAPI/schema-oas3.0.json#/x-defs/cdif.bbr.metadata.profiles.cdifProfile.cdifConceptScheme/$defs/LanguageTaggedValue"
                  }
                ]
              }
            }
          ]
        },
        "skos:definition": {
          "description": "Formal explanation of the meaning or purpose of this concept scheme.",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "$ref": "https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/schemaorgProperties/webAPI/schema-oas3.0.json#/x-defs/cdif.bbr.metadata.profiles.cdifProfile.cdifConceptScheme/$defs/LanguageTaggedValue"
            },
            {
              "type": "array",
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "$ref": "https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/schemaorgProperties/webAPI/schema-oas3.0.json#/x-defs/cdif.bbr.metadata.profiles.cdifProfile.cdifConceptScheme/$defs/LanguageTaggedValue"
                  }
                ]
              }
            }
          ]
        },
        "skos:notation": {
          "description": "Classification code or notation for this concept scheme.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skos:note": {
          "description": "General note about the concept scheme.",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "$ref": "https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/schemaorgProperties/webAPI/schema-oas3.0.json#/x-defs/cdif.bbr.metadata.profiles.cdifProfile.cdifConceptScheme/$defs/LanguageTaggedValue"
            },
            {
              "type": "array",
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "$ref": "https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/schemaorgProperties/webAPI/schema-oas3.0.json#/x-defs/cdif.bbr.metadata.profiles.cdifProfile.cdifConceptScheme/$defs/LanguageTaggedValue"
                  }
                ]
              }
            }
          ]
        },
        "skos:hasTopConcept": {
