{"defs":{},"properties":[{"path":["schema:name"],"id":"http://schema.org/name","description":"string label associated with the variable in the dataset serialization","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/name"},{"path":["schema:description"],"id":"http://schema.org/description","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/description"},{"path":["schema:alternateName"],"id":"http://schema.org/alternateName","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/alternateName"},{"path":["schema:measurementTechnique"],"id":"http://schema.org/measurementTechnique","description":"Text description or URI specifying how values for the variable were obtained.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/measurementTechnique"},{"path":["schema:propertyID"],"id":"http://schema.org/propertyID","description":"identifier or name for the property concept","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/propertyID"},{"path":["schema:unitText"],"id":"http://schema.org/unitText","description":"unit of measurement as text","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/unitText"},{"path":["schema:unitCode"],"id":"http://schema.org/unitCode","description":"URI or code identifying the unit of measure","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/unitCode"},{"path":["schema:minValue"],"id":"http://schema.org/minValue","description":"minimum numeric value in the dataset","schema_type":"number","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/minValue"},{"path":["schema:maxValue"],"id":"http://schema.org/maxValue","description":"maximum numeric value in the dataset","schema_type":"number","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/maxValue"},{"path":["schema:url"],"id":"http://schema.org/url","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/url"},{"path":["schema:measurementTechnique","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["schema:measurementTechnique","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["schema:measurementTechnique","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:measurementTechnique","schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["schema:measurementTechnique","schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["schema:measurementTechnique","schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:measurementTechnique","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:url","dcterms:relation"],"id":"http://purl.org/dc/terms/relation","description":"URI of the related resource (DCAT canonical pointer to what is being related to; distinct from schema:url which is the presentation URL inherited from labeledLink).","schema_type":"string","format":"uri","effectiveId":"http://purl.org/dc/terms/relation"},{"path":["schema:url","dcat:hadRole"],"id":"http://www.w3.org/ns/dcat#hadRole","description":"Role of the related resource as a SKOS Concept (DCAT canonical role slot).","effectiveId":"http://www.w3.org/ns/dcat#hadRole"},{"path":["schema:url","dcat:hadRole","skos:relatedMatch"],"id":"http://www.w3.org/2004/02/skos/core#relatedMatch","description":"Related concepts in other schemes.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#relatedMatch"},{"path":["schema:url","dcat:hadRole","skos:narrowMatch"],"id":"http://www.w3.org/2004/02/skos/core#narrowMatch","description":"Narrower concepts in other schemes.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#narrowMatch"},{"path":["schema:url","dcat:hadRole","skos:broadMatch"],"id":"http://www.w3.org/2004/02/skos/core#broadMatch","description":"Broader concepts in other schemes.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#broadMatch"},{"path":["schema:url","dcat:hadRole","skos:closeMatch"],"id":"http://www.w3.org/2004/02/skos/core#closeMatch","description":"Concepts in other schemes with similar meaning.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#closeMatch"},{"path":["schema:url","dcat:hadRole","skos:exactMatch"],"id":"http://www.w3.org/2004/02/skos/core#exactMatch","description":"Concepts in other schemes with equivalent meaning.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#exactMatch"},{"path":["schema:url","dcat:hadRole","skos:related"],"id":"http://www.w3.org/2004/02/skos/core#related","description":"Associatively related concepts.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#related"},{"path":["schema:url","dcat:hadRole","skos:narrower"],"id":"http://www.w3.org/2004/02/skos/core#narrower","description":"Narrower (child) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#narrower"},{"path":["schema:url","dcat:hadRole","skos:broader"],"id":"http://www.w3.org/2004/02/skos/core#broader","description":"Broader (parent) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#broader"},{"path":["schema:url","dcat:hadRole","skos:topConceptOf"],"id":"http://www.w3.org/2004/02/skos/core#topConceptOf","description":"Concept scheme(s) for which this is a top concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#topConceptOf"},{"path":["schema:url","dcat:hadRole","skos:inScheme"],"id":"http://www.w3.org/2004/02/skos/core#inScheme","description":"Concept scheme(s) this concept belongs to.","effectiveId":"http://www.w3.org/2004/02/skos/core#inScheme"},{"path":["schema:url","dcat:hadRole","skos:example"],"id":"http://www.w3.org/2004/02/skos/core#example","description":"Example of use of this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#example"},{"path":["schema:url","dcat:hadRole","skos:editorialNote"],"id":"http://www.w3.org/2004/02/skos/core#editorialNote","description":"Note for editors and maintainers.","effectiveId":"http://www.w3.org/2004/02/skos/core#editorialNote"},{"path":["schema:url","dcat:hadRole","skos:changeNote"],"id":"http://www.w3.org/2004/02/skos/core#changeNote","description":"Note documenting a change.","effectiveId":"http://www.w3.org/2004/02/skos/core#changeNote"},{"path":["schema:url","dcat:hadRole","skos:historyNote"],"id":"http://www.w3.org/2004/02/skos/core#historyNote","description":"Note about past state or use.","effectiveId":"http://www.w3.org/2004/02/skos/core#historyNote"},{"path":["schema:url","dcat:hadRole","skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["schema:url","dcat:hadRole","skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying meaning and/or intended use.","effectiveId":"http://www.w3.org/2004/02/skos/core#scopeNote"},{"path":["schema:url","dcat:hadRole","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning of this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["schema:url","dcat:hadRole","skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["schema:url","dcat:hadRole","skos:hiddenLabel"],"id":"http://www.w3.org/2004/02/skos/core#hiddenLabel","description":"Labels accessible to free-text search but not displayed.","effectiveId":"http://www.w3.org/2004/02/skos/core#hiddenLabel"},{"path":["schema:url","dcat:hadRole","skos:altLabel"],"id":"http://www.w3.org/2004/02/skos/core#altLabel","description":"Alternative lexical labels (acronyms, abbreviations, variants).","effectiveId":"http://www.w3.org/2004/02/skos/core#altLabel"},{"path":["schema:url","dcat:hadRole","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["schema:url","schema:url"],"id":"http://schema.org/url","required":true,"schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:url","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:url","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"}]}