uired":true},{"path":["schema:url","dcat:hadRole","skos:broader","skos:notation"],"description":"Classification code or notation for this concept scheme.","schema_type":"array"},{"path":["schema:url","dcat:hadRole","skos:broader","skos:note"],"description":"General note about the concept scheme."},{"path":["schema:url","dcat:hadRole","skos:broader","skos:hasTopConcept"],"description":"Top-level concepts in this scheme. Each item is a skos:Concept (inline or @id reference).","required":true,"schema_type":"array"},{"path":["schema:url","dcat:hadRole","skos:broader","schema:version"],"description":"Version identifier for the concept scheme.","schema_type":["string","number"]},{"path":["schema:url","dcat:hadRole","skos:broader","schema:subjectOf"],"schema_type":"array"},{"path":["schema:url","dcat:hadRole","skos:inScheme"],"description":"Concept scheme(s) this concept belongs to."},{"path":["schema:url","dcat:hadRole","skos:note"],"description":"General note about this concept."},{"path":["schema:url","dcat:hadRole","skos:definition"],"description":"Formal explanation of the meaning of this concept."},{"path":["schema:url","dcat:hadRole","skos:notation"],"description":"Classification code for this concept within a scheme.","required":true,"schema_type":"array"},{"path":["schema:url","dcat:hadRole","skos:prefLabel"],"description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true},{"path":["schema:url","schema:url"],"id":"http://schema.org/url","required":true,"schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:url","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:url","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"}]}