{"defs":{},"properties":[{"path":["schema:name"],"id":"http://schema.org/name","description":"string label associated with the variable in the dataset serialization","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/name"},{"path":["schema:description"],"id":"http://schema.org/description","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/description"},{"path":["schema:alternateName"],"id":"http://schema.org/alternateName","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/alternateName"},{"path":["schema:measurementTechnique"],"id":"http://schema.org/measurementTechnique","description":"Text description or URI specifying how values for the variable were obtained.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/measurementTechnique"},{"path":["schema:propertyID"],"id":"http://schema.org/propertyID","description":"identifier or name for the property concept","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/propertyID"},{"path":["schema:unitText"],"id":"http://schema.org/unitText","description":"unit of measurement as text","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/unitText"},{"path":["schema:unitCode"],"id":"http://schema.org/unitCode","description":"URI or code identifying the unit of measure","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.variableMeasured"],"effectiveId":"http://schema.org/unitCode"},{"path":["schema:minValue"],"id":"http://schema.org/minValue","description":"minimum numeric value in the dataset","schema_type":"number","sources":["bb