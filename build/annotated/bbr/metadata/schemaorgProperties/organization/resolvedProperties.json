{"defs":{},"properties":[{"path":["schema:additionalType"],"id":"http://schema.org/additionalType","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"],"effectiveId":"http://schema.org/additionalType"},{"path":["schema:name"],"id":"http://schema.org/name","description":"string label for organization that is meaningful for human users","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"],"effectiveId":"http://schema.org/name"},{"path":["schema:alternateName"],"id":"http://schema.org/alternateName","description":"other labels by which the organization might be known","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"],"effectiveId":"http://schema.org/alternateName"},{"path":["schema:description"],"id":"http://schema.org/description","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"],"effectiveId":"http://schema.org/description"},{"path":["schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for organization","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"],"effectiveId":"http://schema.org/identifier"},{"path":["schema:sameAs"],"id":"http://schema.org/sameAs","description":"other identifiers for the organization","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"],"effectiveId":"http://schema.org/sameAs"},{"path":["schema:additionalType","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["schema:additionalType","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["schema:additionalType","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:additionalType","schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["schema:additionalType","schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["schema:additionalType","schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:additionalType","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"}]}