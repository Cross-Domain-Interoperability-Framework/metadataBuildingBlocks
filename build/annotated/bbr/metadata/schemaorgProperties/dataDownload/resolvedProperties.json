{"defs":{},"properties":[{"path":["schema:name"],"id":"http://schema.org/name","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.dataDownload"],"effectiveId":"http://schema.org/name"},{"path":["schema:description"],"id":"http://schema.org/description","description":"Description of this distribution, e.g. what format, access constraints, etc.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.dataDownload"],"effectiveId":"http://schema.org/description"},{"path":["schema:contentUrl"],"id":"http://schema.org/contentUrl","required":true,"schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.dataDownload"],"effectiveId":"http://schema.org/contentUrl"},{"path":["schema:encodingFormat"],"id":"http://schema.org/encodingFormat","description":"MIME type with extension; should indicate the serialization scheme in sufficient detail that machine can know how to parse.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.dataDownload"],"effectiveId":"http://schema.org/encodingFormat"},{"path":["spdx:checksum"],"description":"A string value calculated from the content of the resource representation, used to test if content has been modified. The checksum is a property of a particular distribution/DataDownload.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.dataDownload"]},{"path":["spdx:checksum","spdx:algorithm"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.dataDownload"]},{"path":["spdx:checksum","spdx:checksumValue"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.dataDownload"]},{"path":["dcterms:conformsTo"],"description":"An identifier for a standard or specification that the distribution conforms to. Recommended to enable machine-actionable data access.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.dataDownload"]},{"path":["schema:provider"],"id":"http://schema.org/provider","description":"Party who maintains this particular distribution option for the dataset. Use this property if there are multiple distributions from different providers","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.dataDownload"],"effectiveId":"http://schema.org/provider"},{"path":["schema:provider","schema:sameAs"],"id":"http://schema.org/sameAs","description":"other identifiers for the person","schema_type":"array","effectiveId":"http://schema.org/sameAs"},{"path":["schema:provider","schema:contactPoint"],"id":"http://schema.org/contactPoint","description":"restrict to email only. Schema.org allows telephone and postal contacts as well","schema_type":"object","effectiveId":"http://schema.org/contactPoint"},{"path":["schema:provider","schema:contactPoint","schema:email"],"id":"http://schema.org/email","required":true,"schema_type":"string","effectiveId":"http://schema.org/email"},{"path":["schema:provider","schema:affiliation"],"id":"http://schema.org/affiliation","description":"if affiliation is present, value must be a schema:Organization.","effectiveId":"http://schema.org/affiliation"},{"path":["schema:provider","schema:affiliation","schema:sameAs"],"id":"http://schema.org/sameAs","description":"other identifiers for the organization","schema_type":"array","effectiveId":"http://schema.org/sameAs"},{"path":["schema:provider","schema:affiliation","schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for organization","effectiveId":"http://schema.org/identifier"},{"path":["schema:provider","schema:affiliation","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:provider","schema:affiliation","schema:alternateName"],"id":"http://schema.org/alternateName","description":"other labels by which the organization might be known","schema_type":"string","effectiveId":"http://schema.org/alternateName"},{"path":["schema:provider","schema:affiliation","schema:name"],"id":"http://schema.org/name","description":"string label for organization that is meaningful for human users","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:provider","schema:affiliation","schema:additionalType"],"id":"http://schema.org/additionalType","schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["schema:provider","schema:affiliation","schema:additionalType","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:provider","schema:affiliation","schema:additionalType","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:provider","schema:affiliation","schema:additionalType","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["schema:provider","schema:affiliation","schema:additionalType","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["schema:provider","schema:alternateName"],"id":"http://schema.org/alternateName","description":"other labels by which the person might be known","schema_type":"string","effectiveId":"http://schema.org/alternateName"},{"path":["schema:provider","schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for person, recommend ORCID","effectiveId":"http://schema.org/identifier"},{"path":["schema:provider","schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["schema:provider","schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["schema:provider","schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:provider","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:provider","schema:name"],"id":"http://schema.org/name","description":"string label for person that is meaningful for human users, should format consistently. Recommend 'Family Name, Given name' format.","schema_type":"string","effectiveId":"http://schema.org/name"}]}