{"defs":{},"properties":[{"path":["schema:name"],"id":"http://schema.org/name","description":"Human-readable name (label) for the term set.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTermSet"],"effectiveId":"http://schema.org/name"},{"path":["schema:description"],"id":"http://schema.org/description","description":"Description of the scope and purpose of the term set.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTermSet"],"effectiveId":"http://schema.org/description"},{"path":["schema:identifier"],"id":"http://schema.org/identifier","description":"Formal identifier for the term set, as a string or structured PropertyValue.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTermSet"],"effectiveId":"http://schema.org/identifier"},{"path":["schema:url"],"id":"http://schema.org/url","description":"URL where the term set is published.","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTermSet"],"effectiveId":"http://schema.org/url"},{"path":["schema:hasDefinedTerm"],"id":"http://schema.org/hasDefinedTerm","description":"The terms that make up this set. Each item is a schema:DefinedTerm.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTermSet"],"effectiveId":"http://schema.org/hasDefinedTerm"},{"path":["schema:hasDefinedTerm","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:hasDefinedTerm","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:hasDefinedTerm","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["schema:hasDefinedTerm","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"}]}