{"defs":{"0":[{"path":["schema:additionalType"],"id":"http://schema.org/additionalType","schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["schema:additionalType","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:additionalType","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["schema:additionalType","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:additionalType","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["schema:alternateName"],"id":"http://schema.org/alternateName","description":"other labels by which the organization might be known","schema_type":"string","effectiveId":"http://schema.org/alternateName"},{"path":["schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for organization","effectiveId":"http://schema.org/identifier"},{"path":["schema:name"],"id":"http://schema.org/name","description":"string label for organization that is meaningful for human users","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:sameAs"],"id":"http://schema.org/sameAs","description":"other identifiers for the organization","schema_type":"array","effectiveId":"http://schema.org/sameAs"}]},"properties":[{"path":["schema:additionalType"],"id":"http://schema.org/additionalType","description":"Domain-specific type classifications. Should include a scientific instrument type URI (e.g. wd:Q3099911 for Wikidata scientific instrument).","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.xasProperties.xasInstrument"],"effectiveId":"http://schema.org/additionalType"},{"path":["schema:name"],"id":"http://schema.org/name","description":"Human-readable name for this instrument.","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:description"],"id":"http://schema.org/description","description":"Text description of this instrument, its purpose, and capabilities.","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:alternateName"],"id":"http://schema.org/alternateName","description":"Alternate name(s), e.g. specific make/model designation, common abbreviation.","schema_type":"array","effectiveId":"http://schema.org/alternateName"},{"path":["schema:identifier"],"id":"http://schema.org/identifier","description":"Formal identifier(s) for this instrument. Use PropertyValue for structured identifiers (e.g. PIDINST, serial number, inventory number).","schema_type":"array","effectiveId":"http://schema.org/identifier"},{"path":["schema:url"],"id":"http://schema.org/url","description":"Landing page URL for this instrument.","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:manufacturer"],"id":"http://schema.org/manufacturer","description":"Organization that manufactured this instrument.","ref":"0","effectiveId":"http://schema.org/manufacturer"},{"path":["schema:model"],"id":"http://schema.org/model","description":"Product model information for this instrument.","schema_type":"object","effectiveId":"http://schema.org/model"},{"path":["schema:model","schema:name"],"id":"http://schema.org/name","description":"Model name or number.","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:model","schema:identifier"],"id":"http://schema.org/identifier","description":"Model identifier.","effectiveId":"http://schema.org/identifier"},{"path":["schema:category"],"id":"http://schema.org/category","description":"Instrument type classification(s) from a controlled vocabulary.","schema_type":"array","effectiveId":"http://schema.org/category"},{"path":["schema:owner"],"id":"http://schema.org/owner","description":"Organization that owns this instrument.","ref":"0","effectiveId":"http://schema.org/owner"},{"path":["schema:contributor"],"id":"http://schema.org/contributor","description":"Agents associated with this instrument in specific roles (e.g. operator, custodian, principal investigator). Use schema:owner for the owning organization.","schema_type":"array","effectiveId":"http://schema.org/contributor"},{"path":["schema:contributor","schema:roleName"],"id":"http://schema.org/roleName","required":true,"effectiveId":"http://schema.org/roleName"},{"path":["schema:contributor","schema:contributor"],"id":"http://schema.org/contributor","required":true,"effectiveId":"http://schema.org/contributor"},{"path":["schema:additionalProperty"],"id":"http://schema.org/additionalProperty","description":"Instrument-specific properties (measured variables, detection limits, calibration information, operating parameters, etc.).","schema_type":"array","effectiveId":"http://schema.org/additionalProperty"},{"path":["schema:additionalProperty","schema:propertyID"],"id":"http://schema.org/propertyID","description":"identifier or name for the property concept quantified by the values in this variable slot. Multiple values can specify the property at different levels of granularity.","schema_type":"array","effectiveId":"http://schema.org/propertyID"},{"path":["schema:additionalProperty","schema:name"],"id":"http://schema.org/name","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:additionalProperty","schema:value"],"id":"http://schema.org/value","required":true,"effectiveId":"http://schema.org/value"},{"path":["schema:additionalProperty","schema:unitCode"],"id":"http://schema.org/unitCode","effectiveId":"http://schema.org/unitCode"},{"path":["schema:additionalProperty","schema:unitText"],"id":"http://schema.org/unitText","schema_type":"string","effectiveId":"http://schema.org/unitText"},{"path":["schema:validFrom"],"id":"http://schema.org/validFrom","description":"Date the instrument was commissioned (ISO 8601).","schema_type":"string","effectiveId":"http://schema.org/validFrom"},{"path":["schema:validThrough"],"id":"http://schema.org/validThrough","description":"Date the instrument was decommissioned (ISO 8601). Absent if still operational.","schema_type":"string","effectiveId":"http://schema.org/validThrough"},{"path":["schema:hasPart"],"id":"http://schema.org/hasPart","description":"Sub-components of this instrument system. Each item is either an inline instrument description or an @id reference.","schema_type":"array","effectiveId":"http://schema.org/hasPart"},{"path":["schema:relatedLink"],"id":"http://schema.org/relatedLink","description":"Links to related resources (manuals, datasheets, calibration records, related instruments).","schema_type":"array","effectiveId":"http://schema.org/relatedLink"},{"path":["schema:relatedLink","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:relatedLink","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:relatedLink","schema:url"],"id":"http://schema.org/url","required":true,"schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:relatedLink","dcat:hadRole"],"id":"http://www.w3.org/ns/dcat#hadRole","description":"Role of the related resource as a SKOS Concept (DCAT canonical role slot).","effectiveId":"http://www.w3.org/ns/dcat#hadRole"},{"path":["schema:relatedLink","dcat:hadRole","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["schema:relatedLink","dcat:hadRole","skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["schema:relatedLink","dcat:hadRole","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning of this concept.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["schema:relatedLink","dcat:hadRole","skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying meaning and/or intended use.","effectiveId":"http://www.w3.org/2004/02/skos/core#scopeNote"},{"path":["schema:relatedLink","dcat:hadRole","skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["schema:relatedLink","dcat:hadRole","skos:historyNote"],"id":"http://www.w3.org/2004/02/skos/core#historyNote","description":"Note about past state or use.","effectiveId":"http://www.w3.org/2004/02/skos/core#historyNote"},{"path":["schema:relatedLink","dcat:hadRole","skos:changeNote"],"id":"http://www.w3.org/2004/02/skos/core#changeNote","description":"Note documenting a change.","effectiveId":"http://www.w3.org/2004/02/skos/core#changeNote"},{"path":["schema:relatedLink","dcat:hadRole","skos:editorialNote"],"id":"http://www.w3.org/2004/02/skos/core#editorialNote","description":"Note for editors and maintainers.","effectiveId":"http://www.w3.org/2004/02/skos/core#editorialNote"},{"path":["schema:relatedLink","dcat:hadRole","skos:inScheme"],"id":"http://www.w3.org/2004/02/skos/core#inScheme","description":"Concept scheme(s) this concept belongs to.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#inScheme"},{"path":["schema:relatedLink","dcat:hadRole","skos:topConceptOf"],"id":"http://www.w3.org/2004/02/skos/core#topConceptOf","description":"Concept scheme(s) for which this is a top concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#topConceptOf"},{"path":["schema:relatedLink","dcat:hadRole","skos:broader"],"id":"http://www.w3.org/2004/02/skos/core#broader","description":"Broader (parent) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#broader"},{"path":["schema:relatedLink","dcat:hadRole","skos:narrower"],"id":"http://www.w3.org/2004/02/skos/core#narrower","description":"Narrower (child) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#narrower"},{"path":["schema:relatedLink","dcterms:relation"],"id":"http://purl.org/dc/terms/relation","description":"URI of the related resource (DCAT canonical pointer to what is being related to; distinct from schema:url which is the presentation URL inherited from labeledLink).","schema_type":"string","format":"uri","effectiveId":"http://purl.org/dc/terms/relation"},{"path":["schema:subjectOf"],"id":"http://schema.org/subjectOf","description":"Catalog record metadata-about-metadata for this instrument description.","schema_type":"object","effectiveId":"http://schema.org/subjectOf"},{"path":["schema:subjectOf","schema:dateModified"],"id":"http://schema.org/dateModified","description":"Date this metadata record was last modified (ISO 8601).","schema_type":"string","effectiveId":"http://schema.org/dateModified"},{"path":["schema:subjectOf","schema:about"],"id":"http://schema.org/about","schema_type":"object","effectiveId":"http://schema.org/about"},{"path":["schema:subjectOf","dcterms:conformsTo"],"description":"Schema or profile this metadata record conforms to.","schema_type":"array"},{"path":["schema:contributor","schema:contributor","schema:sameAs"],"id":"http://schema.org/sameAs","description":"other identifiers for the person","schema_type":"array","effectiveId":"http://schema.org/sameAs"},{"path":["schema:contributor","schema:contributor","schema:contactPoint"],"id":"http://schema.org/contactPoint","description":"restrict to email only. Schema.org allows telephone and postal contacts as well","schema_type":"object","effectiveId":"http://schema.org/contactPoint"},{"path":["schema:contributor","schema:contributor","schema:contactPoint","schema:email"],"id":"http://schema.org/email","required":true,"schema_type":"string","effectiveId":"http://schema.org/email"},{"path":["schema:contributor","schema:contributor","schema:affiliation"],"id":"http://schema.org/affiliation","description":"if affiliation is present, value must be a schema:Organization.","effectiveId":"http://schema.org/affiliation"},{"path":["schema:contributor","schema:contributor","schema:alternateName"],"id":"http://schema.org/alternateName","description":"other labels by which the person might be known","schema_type":"string","effectiveId":"http://schema.org/alternateName"},{"path":["schema:contributor","schema:contributor","schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for person, recommend ORCID","effectiveId":"http://schema.org/identifier"},{"path":["schema:contributor","schema:contributor","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:contributor","schema:contributor","schema:name"],"id":"http://schema.org/name","description":"string label for person that is meaningful for human users, should format consistently. Recommend 'Family Name, Given name' format.","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["schema:hasPart","schema:model"],"id":"http://schema.org/model","schema_type":"object","effectiveId":"http://schema.org/model"},{"path":["schema:hasPart","schema:model","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:hasPart","schema:model","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:hasPart","schema:manufacturer"],"id":"http://schema.org/manufacturer","effectiveId":"http://schema.org/manufacturer"},{"path":["schema:hasPart","schema:additionalProperty"],"id":"http://schema.org/additionalProperty","schema_type":"array","effectiveId":"http://schema.org/additionalProperty"},{"path":["schema:hasPart","schema:additionalType"],"id":"http://schema.org/additionalType","description":"Component type classification.","schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["schema:hasPart","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:hasPart","schema:alternateName"],"id":"http://schema.org/alternateName","schema_type":"array","effectiveId":"http://schema.org/alternateName"},{"path":["schema:hasPart","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:hasPart","schema:name"],"id":"http://schema.org/name","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"}]}