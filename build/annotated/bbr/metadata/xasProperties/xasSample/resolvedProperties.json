{"defs":{},"properties":[{"path":["schema:additionalType"],"id":"http://schema.org/additionalType","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.xasProperties.xasSample"],"effectiveId":"http://schema.org/additionalType"},{"path":["schema:name"],"id":"http://schema.org/name","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.xasProperties.xasSample"],"effectiveId":"http://schema.org/name"},{"path":["schema:identifier"],"id":"http://schema.org/identifier","sources":["bblocks://cdif.bbr.metadata.xasProperties.xasSample"],"effectiveId":"http://schema.org/identifier"},{"path":["schema:description"],"id":"http://schema.org/description","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.xasProperties.xasSample"],"effectiveId":"http://schema.org/description"},{"path":["schema:additionalProperty"],"id":"http://schema.org/additionalProperty","description":"extend base definition (AdditionalProperty) with some expected propertyID values from NEXUS and XDI specs added in the enum","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.xasProperties.xasSample"],"effectiveId":"http://schema.org/additionalProperty"},{"path":["schema:additionalProperty","schema:propertyID"],"id":"http://schema.org/propertyID","description":"identifier or name for the property concept quantified by the values in this variable slot. Multiple values can specify the property at different levels of granularity.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.xasProperties.xasSample"],"effectiveId":"http://schema.org/propertyID"},{"path":["schema:additionalProperty","schema:name"],"id":"http://schema.org/name","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:additionalProperty","schema:value"],"id":"http://schema.org/value","required":true,"effectiveId":"http://schema.org/value"},{"path":["schema:additionalProperty","schema:unitCode"],"id":"http://schema.org/unitCode","effectiveId":"http://schema.org/unitCode"},{"path":["schema:additionalProperty","schema:unitText"],"id":"http://schema.org/unitText","schema_type":"string","effectiveId":"http://schema.org/unitText"},{"path":["schema:additionalProperty","schema:propertyID","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["schema:additionalProperty","schema:propertyID","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["schema:additionalProperty","schema:propertyID","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:additionalProperty","schema:propertyID","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"}]}