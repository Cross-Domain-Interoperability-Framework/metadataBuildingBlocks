{"defs":{"0":[{"path":["schema:additionalType"],"id":"http://schema.org/additionalType","schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["schema:additionalType","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:additionalType","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["schema:additionalType","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:additionalType","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["schema:alternateName"],"id":"http://schema.org/alternateName","description":"other labels by which the organization might be known","schema_type":"string","effectiveId":"http://schema.org/alternateName"},{"path":["schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for organization","effectiveId":"http://schema.org/identifier"},{"path":["schema:name"],"id":"http://schema.org/name","description":"string label for organization that is meaningful for human users","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:sameAs"],"id":"http://schema.org/sameAs","description":"other identifiers for the organization","schema_type":"array","effectiveId":"http://schema.org/sameAs"}],"1":[{"path":["schema:name"],"id":"http://schema.org/name","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:propertyID"],"id":"http://schema.org/propertyID","description":"identifier or name for the property concept quantified by the values in this variable slot. Multiple values can specify the property at different levels of granularity.","schema_type":"array","effectiveId":"http://schema.org/propertyID"},{"path":["schema:unitCode"],"id":"http://schema.org/unitCode","effectiveId":"http://schema.org/unitCode"},{"path":["schema:unitText"],"id":"http://schema.org/unitText","schema_type":"string","effectiveId":"http://schema.org/unitText"},{"path":["schema:value"],"id":"http://schema.org/value","required":true,"effectiveId":"http://schema.org/value"}],"2":[{"path":["schema:additionalProperty"],"id":"http://schema.org/additionalProperty","description":"Instrument-specific properties (measured variables, detection limits, calibration information, operating parameters, etc.).","schema_type":"array","ref":"1","effectiveId":"http://schema.org/additionalProperty"},{"path":["schema:additionalType"],"id":"http://schema.org/additionalType","description":"Domain-specific type classifications. Should include a scientific instrument type URI (e.g. wd:Q3099911 for Wikidata scientific instrument).","schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["schema:alternateName"],"id":"http://schema.org/alternateName","description":"Alternate name(s), e.g. specific make/model designation, common abbreviation.","schema_type":"array","effectiveId":"http://schema.org/alternateName"},{"path":["schema:category"],"id":"http://schema.org/category","description":"Instrument type classification(s) from a controlled vocabulary.","schema_type":"array","effectiveId":"http://schema.org/category"},{"path":["schema:contributor"],"id":"http://schema.org/contributor","description":"Agents associated with this instrument in specific roles (e.g. operator, custodian, principal investigator). Use schema:owner for the owning organization.","schema_type":"array","effectiveId":"http://schema.org/contributor"},{"path":["schema:contributor","schema:contributor"],"id":"http://schema.org/contributor","required":true,"effectiveId":"http://schema.org/contributor"},{"path":["schema:contributor","schema:contributor","schema:affiliation"],"id":"http://schema.org/affiliation","description":"if affiliation is present, value must be a schema:Organization.","effectiveId":"http://schema.org/affiliation"},{"path":["schema:contributor","schema:contributor","schema:alternateName"],"id":"http://schema.org/alternateName","description":"other labels by which the person might be known","schema_type":"string","effectiveId":"http://schema.org/alternateName"},{"path":["schema:contributor","schema:contributor","schema:contactPoint"],"id":"http://schema.org/contactPoint","description":"restrict to email only. Schema.org allows telephone and postal contacts as well","schema_type":"object","effectiveId":"http://schema.org/contactPoint"},{"path":["schema:contributor","schema:contributor","schema:contactPoint","schema:email"],"id":"http://schema.org/email","required":true,"schema_type":"string","effectiveId":"http://schema.org/email"},{"path":["schema:contributor","schema:contributor","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:contributor","schema:contributor","schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for person, recommend ORCID","effectiveId":"http://schema.org/identifier"},{"path":["schema:contributor","schema:contributor","schema:name"],"id":"http://schema.org/name","description":"string label for person that is meaningful for human users, should format consistently. Recommend 'Family Name, Given name' format.","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:contributor","schema:contributor","schema:sameAs"],"id":"http://schema.org/sameAs","description":"other identifiers for the person","schema_type":"array","effectiveId":"http://schema.org/sameAs"},{"path":["schema:contributor","schema:roleName"],"id":"http://schema.org/roleName","required":true,"effectiveId":"http://schema.org/roleName"},{"path":["schema:description"],"id":"http://schema.org/description","description":"Text description of this instrument, its purpose, and capabilities.","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:hasPart"],"id":"http://schema.org/hasPart","description":"Sub-components of this instrument system. Each item is either an inline instrument description or an @id reference.","schema_type":"array","effectiveId":"http://schema.org/hasPart"},{"path":["schema:hasPart","schema:additionalProperty"],"id":"http://schema.org/additionalProperty","schema_type":"array","effectiveId":"http://schema.org/additionalProperty"},{"path":["schema:hasPart","schema:additionalType"],"id":"http://schema.org/additionalType","description":"Component type classification.","schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["schema:hasPart","schema:alternateName"],"id":"http://schema.org/alternateName","schema_type":"array","effectiveId":"http://schema.org/alternateName"},{"path":["schema:hasPart","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:hasPart","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:hasPart","schema:manufacturer"],"id":"http://schema.org/manufacturer","effectiveId":"http://schema.org/manufacturer"},{"path":["schema:hasPart","schema:model"],"id":"http://schema.org/model","schema_type":"object","effectiveId":"http://schema.org/model"},{"path":["schema:hasPart","schema:model","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:hasPart","schema:model","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:hasPart","schema:name"],"id":"http://schema.org/name","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:identifier"],"id":"http://schema.org/identifier","description":"Formal identifier(s) for this instrument. Use PropertyValue for structured identifiers (e.g. PIDINST, serial number, inventory number).","schema_type":"array","effectiveId":"http://schema.org/identifier"},{"path":["schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["schema:manufacturer"],"id":"http://schema.org/manufacturer","description":"Organization that manufactured this instrument.","ref":"0","effectiveId":"http://schema.org/manufacturer"},{"path":["schema:model"],"id":"http://schema.org/model","description":"Product model information for this instrument.","schema_type":"object","effectiveId":"http://schema.org/model"},{"path":["schema:model","schema:identifier"],"id":"http://schema.org/identifier","description":"Model identifier.","effectiveId":"http://schema.org/identifier"},{"path":["schema:model","schema:name"],"id":"http://schema.org/name","description":"Model name or number.","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:name"],"id":"http://schema.org/name","description":"Human-readable name for this instrument.","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:owner"],"id":"http://schema.org/owner","description":"Organization that owns this instrument.","ref":"0","effectiveId":"http://schema.org/owner"},{"path":["schema:relatedLink"],"id":"http://schema.org/relatedLink","description":"Links to related resources (manuals, datasheets, calibration records, related instruments).","schema_type":"array","effectiveId":"http://schema.org/relatedLink"},{"path":["schema:relatedLink","dcat:hadRole"],"id":"http://www.w3.org/ns/dcat#hadRole","description":"Role of the related resource as a SKOS Concept (DCAT canonical role slot).","effectiveId":"http://www.w3.org/ns/dcat#hadRole"},{"path":["schema:relatedLink","dcat:hadRole","skos:broader"],"description":"Broader (parent) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array"},{"path":["schema:relatedLink","dcat:hadRole","skos:broader","schema:subjectOf"],"schema_type":"array"},{"path":["schema:relatedLink","dcat:hadRole","skos:broader","schema:version"],"description":"Version identifier for the concept scheme.","schema_type":["string","number"]},{"path":["schema:relatedLink","dcat:hadRole","skos:broader","skos:altLabel"],"description":"Alternative lexical labels (acronyms, abbreviations, spelling variants)."},{"path":["schema:relatedLink","dcat:hadRole","skos:broader","skos:definition"],"description":"Formal explanation of the meaning or purpose of this concept scheme.","required":true},{"path":["schema:relatedLink","dcat:hadRole","skos:broader","skos:hasTopConcept"],"description":"Top-level concepts in this scheme. Each item is a skos:Concept (inline or @id reference).","required":true,"schema_type":"array"},{"path":["schema:relatedLink","dcat:hadRole","skos:broader","skos:notation"],"description":"Classification code or notation for this concept scheme.","schema_type":"array"},{"path":["schema:relatedLink","dcat:hadRole","skos:broader","skos:note"],"description":"General note about the concept scheme."},{"path":["schema:relatedLink","dcat:hadRole","skos:broader","skos:prefLabel"],"description":"Preferred lexical label for the concept scheme. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true},{"path":["schema:relatedLink","dcat:hadRole","skos:definition"],"description":"Formal explanation of the meaning of this concept."},{"path":["schema:relatedLink","dcat:hadRole","skos:inScheme"],"description":"Concept scheme(s) this concept belongs to."},{"path":["schema:relatedLink","dcat:hadRole","skos:narrower"],"description":"Narrower (child) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array"},{"path":["schema:relatedLink","dcat:hadRole","skos:notation"],"description":"Classification code for this concept within a scheme.","required":true,"schema_type":"array"},{"path":["schema:relatedLink","dcat:hadRole","skos:note"],"description":"General note about this concept."},{"path":["schema:relatedLink","dcat:hadRole","skos:prefLabel"],"description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true},{"path":["schema:relatedLink","dcterms:relation"],"id":"http://purl.org/dc/terms/relation","description":"URI of the related resource (DCAT canonical pointer to what is being related to; distinct from schema:url which is the presentation URL inherited from labeledLink).","schema_type":"string","format":"uri","effectiveId":"http://purl.org/dc/terms/relation"},{"path":["schema:relatedLink","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:relatedLink","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:relatedLink","schema:url"],"id":"http://schema.org/url","required":true,"schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:subjectOf"],"id":"http://schema.org/subjectOf","description":"Catalog record metadata-about-metadata for this instrument description.","schema_type":"object","effectiveId":"http://schema.org/subjectOf"},{"path":["schema:subjectOf","dcterms:conformsTo"],"description":"Schema or profile this metadata record conforms to.","schema_type":"array"},{"path":["schema:subjectOf","schema:about"],"id":"http://schema.org/about","schema_type":"object","effectiveId":"http://schema.org/about"},{"path":["schema:subjectOf","schema:dateModified"],"id":"http://schema.org/dateModified","description":"Date this metadata record was last modified (ISO 8601).","schema_type":"string","effectiveId":"http://schema.org/dateModified"},{"path":["schema:url"],"id":"http://schema.org/url","description":"Landing page URL for this instrument.","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:validFrom"],"id":"http://schema.org/validFrom","description":"Date the instrument was commissioned (ISO 8601).","schema_type":"string","effectiveId":"http://schema.org/validFrom"},{"path":["schema:validThrough"],"id":"http://schema.org/validThrough","description":"Date the instrument was decommissioned (ISO 8601). Absent if still operational.","schema_type":"string","effectiveId":"http://schema.org/validThrough"}]},"properties":[{"path":["prov:used"],"id":"http://www.w3.org/ns/prov#used","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.xasProperties.xasGeneratedBy"],"effectiveId":"http://www.w3.org/ns/prov#used"},{"path":["prov:used","_anyOf"],"keyword":"anyOf"},{"path":["prov:used","_anyOf","0"],"title":"a","keyword":"branch"},{"path":["prov:used","_anyOf","2"],"title":"b","keyword":"branch"},{"path":["prov:used","_anyOf","2","schema:instrument"],"id":"http://schema.org/instrument","required":true,"ref":"2","effectiveId":"http://schema.org/instrument"},{"path":["schema:name"],"id":"http://schema.org/name","description":"Human-readable name for the activity","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:description"],"id":"http://schema.org/description","description":"Text description of what this activity did","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:identifier"],"id":"http://schema.org/identifier","description":"Formal identifier for this activity","effectiveId":"http://schema.org/identifier"},{"path":["schema:agent"],"id":"http://schema.org/agent","description":"Primary responsible agent for this activity (maps to PROV wasAssociatedWith)","effectiveId":"http://schema.org/agent"},{"path":["schema:participant"],"id":"http://schema.org/participant","description":"Other participants in this activity","schema_type":"array","effectiveId":"http://schema.org/participant"},{"path":["schema:object"],"id":"http://schema.org/object","description":"Input entity (or entities) for this activity. Per schema.org, the range of schema:object is schema:Thing. Accepts four shapes (1) a string URI, (2) an @id reference object, (3) an inline schema:Thing object, or (4) an array whose items take any of those shapes (used when an activity has multiple inputs, e.g. samples analyzed). Supports action chaining where the value references the result of a prior activity.","sources":["bblocks://cdif.bbr.metadata.xasProperties.xasGeneratedBy"],"effectiveId":"http://schema.org/object"},{"path":["schema:result"],"id":"http://schema.org/result","description":"Output entity (or entities) produced by this activity. Per schema.org, the range is schema:Thing. Accepts: (1) a string URI reference (action chaining shorthand to be referenced as schema:object of a subsequent activity); (2) a single {\"@id\": \"<uri>\"} object reference; (3) an inline schema:Thing (object with @type); or (4) an array of any of these forms (e.g. multiple datasets produced by this activity). Profiles may restrict the array item shape further.","effectiveId":"http://schema.org/result"},{"path":["schema:actionStatus"],"id":"http://schema.org/actionStatus","description":"Status of this activity","schema_type":"string","enum":["schema:CompletedActionStatus","schema:ActiveActionStatus","schema:PotentialActionStatus","schema:FailedActionStatus"],"effectiveId":"http://schema.org/actionStatus"},{"path":["schema:startTime"],"id":"http://schema.org/startTime","description":"ISO8601 date-time when the activity started (maps to PROV startedAtTime)","schema_type":"string","effectiveId":"http://schema.org/startTime"},{"path":["schema:endTime"],"id":"http://schema.org/endTime","description":"ISO8601 date-time when the activity ended (maps to PROV endedAtTime)","schema_type":"string","effectiveId":"http://schema.org/endTime"},{"path":["schema:location"],"id":"http://schema.org/location","description":"Where the activity occurred","sources":["bblocks://cdif.bbr.metadata.xasProperties.xasGeneratedBy"],"effectiveId":"http://schema.org/location"},{"path":["schema:actionProcess"],"id":"http://schema.org/actionProcess","description":"Methodology or protocol for this activity","effectiveId":"http://schema.org/actionProcess"},{"path":["schema:error"],"id":"http://schema.org/error","description":"Error description for failed activities","schema_type":"string","effectiveId":"http://schema.org/error"},{"path":["schema:additionalProperty"],"id":"http://schema.org/additionalProperty","description":"Domain-specific extension properties","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.xasProperties.xasGeneratedBy"],"ref":"1","effectiveId":"http://schema.org/additionalProperty"},{"path":["schema:startDate"],"id":"http://schema.org/startDate","description":"Date/time the XAS analysis started","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.xasProperties.xasGeneratedBy"],"effectiveId":"http://schema.org/startDate"},{"path":["prov:used","_anyOf","0","schema:instrument"],"id":"http://schema.org/instrument","required":true,"sources":["bblocks://cdif.bbr.metadata.xasProperties.xasGeneratedBy"],"ref":"2","effectiveId":"http://schema.org/instrument"},{"path":["prov:used","_anyOf","0","schema:instrument","schema:additionalType"],"id":"http://schema.org/additionalType","required":true,"schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["schema:additionalProperty","schema:propertyID"],"id":"http://schema.org/propertyID","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.xasProperties.xasGeneratedBy"],"effectiveId":"http://schema.org/propertyID"},{"path":["schema:location","schema:additionalType"],"id":"http://schema.orgadditionalType","description":"Domain-specific type classifications for this place (e.g. facility type,laboratory classification, feature type).","required":true,"schema_type":"array","effectiveId":"http://schema.orgadditionalType"},{"path":["schema:location","schema:identifier"],"id":"http://schema.orgidentifier","description":"Formal identifier for this place (e.g. ROR identifier for a facility).","effectiveId":"http://schema.orgidentifier"},{"path":["schema:location","schema:name"],"id":"http://schema.orgname","description":"A place name for the location, either as a string or a DefinedTerm from a gazetteer.","required":true,"schema_type":"string","effectiveId":"http://schema.orgname"},{"path":["schema:location","schema:additionalProperty"],"id":"http://schema.orgadditionalProperty","schema_type":"array","ref":"1","effectiveId":"http://schema.orgadditionalProperty"},{"path":["schema:object","schema:additionalType"],"id":"http://schema.org/additionalType","required":true,"schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["schema:object","schema:name"],"id":"http://schema.org/name","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:object","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:object","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:object","schema:additionalProperty"],"id":"http://schema.org/additionalProperty","description":"extend base definition (AdditionalProperty) with some expected propertyID values from NEXUS and XDI specs added in the enum","schema_type":"array","ref":"1","effectiveId":"http://schema.org/additionalProperty"},{"path":["schema:object","schema:additionalProperty","schema:propertyID"],"id":"http://schema.org/propertyID","schema_type":"array","effectiveId":"http://schema.org/propertyID"},{"path":["schema:location","geosparql:hasGeometry"],"description":"Optional geographic extent using wkt geometry, see Ocean InfoHub (https://book.oceaninfohub.org/thematics/spatial/README.html#simple-geosparql-wkt). Other geometry schemes might be specified in a specific domain profile, e.g. for atmospheric, subsurface data, or local coordinate systems. NOTE that the location specified here should be the same as the schema.org point or contained within the specified bounding box.","schema_type":"object"},{"path":["schema:location","geosparql:hasGeometry","geosparql:crs"],"schema_type":"object"},{"path":["schema:location","geosparql:hasGeometry","geosparql:asWKT"],"schema_type":"object"},{"path":["schema:location","schema:geo"],"id":"http://schema.org/geo","description":"Either a bounding box or a point location.","effectiveId":"http://schema.org/geo"},{"path":["schema:location","schema:geo","_anyOf"],"keyword":"anyOf"},{"path":["schema:location","schema:geo","_anyOf","2"],"title":"c","keyword":"branch"},{"path":["schema:location","schema:geo","_anyOf","2","schema:line"],"id":"http://schema.org/line","description":"A GeoShape box defines a curvilinear geometry as a string of latitude-longitude coordinates. A space should be used to separate the latitude and longitude values. The coordinate point pairs are also separated by a space. 'East longitude' means positive longitude values are east of the prime (Greenwich) meridian. e.g. '39.33 120.77 40.44 123.96 41.00 121.34' ","required":true,"schema_type":"string","effectiveId":"http://schema.org/line"},{"path":["schema:location","schema:geo","_anyOf","1"],"title":"b","keyword":"branch"},{"path":["schema:location","schema:geo","_anyOf","1","schema:box"],"id":"http://schema.org/box","description":"A GeoShape box defines an area on the surface of the earth defined by point locations of the southwest corner and northeast corner of the rectangle in latitude-longitude coordinates. A space should be used to separate the latitude and longitude values. The two corner coordinate points are separated by a space. 'East longitude' means positive longitude values are east of the prime (Greenwich) meridian.","required":true,"schema_type":"string","effectiveId":"http://schema.org/box"},{"path":["schema:location","schema:geo","_anyOf","0"],"title":"a","keyword":"branch"},{"path":["schema:location","schema:geo","_anyOf","0","schema:longitude"],"id":"http://schema.org/longitude","required":true,"schema_type":"number","effectiveId":"http://schema.org/longitude"},{"path":["schema:location","schema:geo","_anyOf","0","schema:latitude"],"id":"http://schema.org/latitude","required":true,"schema_type":"number","effectiveId":"http://schema.org/latitude"},{"path":["schema:location","schema:alternateName"],"id":"http://schema.org/alternateName","description":"Alternate or abbreviated name(s) for this place.","schema_type":"array","effectiveId":"http://schema.org/alternateName"},{"path":["schema:actionProcess","schema:step"],"id":"http://schema.org/step","description":"Ordered steps in this methodology","schema_type":"array","effectiveId":"http://schema.org/step"},{"path":["schema:actionProcess","schema:step","schema:position"],"id":"http://schema.org/position","description":"Ordinal position of this step","schema_type":"integer","effectiveId":"http://schema.org/position"},{"path":["schema:actionProcess","schema:step","schema:url"],"id":"http://schema.org/url","description":"URL to documentation for this step","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:actionProcess","schema:step","schema:description"],"id":"http://schema.org/description","description":"Description of what this step involves","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:actionProcess","schema:step","schema:name"],"id":"http://schema.org/name","description":"Name of this step","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:actionProcess","schema:url"],"id":"http://schema.org/url","description":"URL to a published methodology or protocol document","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:actionProcess","schema:description"],"id":"http://schema.org/description","description":"Description of the methodology","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:actionProcess","schema:name"],"id":"http://schema.org/name","description":"Name of the methodology or protocol","schema_type":"string","effectiveId":"http://schema.org/name"}]}