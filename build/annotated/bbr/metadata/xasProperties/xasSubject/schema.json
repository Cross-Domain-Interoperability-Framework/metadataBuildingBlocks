{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "allOf": [
    {
      "$ref": "https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/cdifProperties/cdifCatalogRecord/schema.json"
    },
    {
      "properties": {
        "dcterms:conformsTo": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "@id": {
                "type": "string",
                "description": "uri for specifications that this metadata record conforms to"
              }
            }
          },
          "minItems": 2,
          "contains": {
            "type": "object",
            "properties": {
              "@id": {
                "const": "https://w3id.org/cdif/bbr/metadata/profiles/cdifProfiles/CDIFxas"
              }
            },
            "required": [
              "@id"
            ]
          },
          "minContains": 1
        }
      }
    }
  ],
  "x-jsonld-prefixes": {
    "schema": "http://schema.org/"
  }
}