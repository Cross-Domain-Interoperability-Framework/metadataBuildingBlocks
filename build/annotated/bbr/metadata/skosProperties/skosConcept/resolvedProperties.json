{"defs":{},"properties":[{"path":["skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["skos:altLabel"],"id":"http://www.w3.org/2004/02/skos/core#altLabel","description":"Alternative lexical labels (acronyms, abbreviations, variants).","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#altLabel"},{"path":["skos:hiddenLabel"],"id":"http://www.w3.org/2004/02/skos/core#hiddenLabel","description":"Labels accessible to free-text search but not displayed.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#hiddenLabel"},{"path":["skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning of this concept.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying meaning and/or intended use.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#scopeNote"},{"path":["skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about this concept.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["skos:historyNote"],"id":"http://www.w3.org/2004/02/skos/core#historyNote","description":"Note about past state or use.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#historyNote"},{"path":["skos:changeNote"],"id":"http://www.w3.org/2004/02/skos/core#changeNote","description":"Note documenting a change.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#changeNote"},{"path":["skos:editorialNote"],"id":"http://www.w3.org/2004/02/skos/core#editorialNote","description":"Note for editors and maintainers.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#editorialNote"},{"path":["skos:example"],"id":"http://www.w3.org/2004/02/skos/core#example","description":"Example of use of this concept.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#example"},{"path":["skos:inScheme"],"id":"http://www.w3.org/2004/02/skos/core#inScheme","description":"Concept scheme(s) this concept belongs to.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#inScheme"},{"path":["skos:topConceptOf"],"id":"http://www.w3.org/2004/02/skos/core#topConceptOf","description":"Concept scheme(s) for which this is a top concept.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#topConceptOf"},{"path":["skos:broader"],"id":"http://www.w3.org/2004/02/skos/core#broader","description":"Broader (parent) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#broader"},{"path":["skos:narrower"],"id":"http://www.w3.org/2004/02/skos/core#narrower","description":"Narrower (child) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#narrower"},{"path":["skos:related"],"id":"http://www.w3.org/2004/02/skos/core#related","description":"Associatively related concepts.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#related"},{"path":["skos:exactMatch"],"id":"http://www.w3.org/2004/02/skos/core#exactMatch","description":"Concepts in other schemes with equivalent meaning.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#exactMatch"},{"path":["skos:closeMatch"],"id":"http://www.w3.org/2004/02/skos/core#closeMatch","description":"Concepts in other schemes with similar meaning.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#closeMatch"},{"path":["skos:broadMatch"],"id":"http://www.w3.org/2004/02/skos/core#broadMatch","description":"Broader concepts in other schemes.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#broadMatch"},{"path":["skos:narrowMatch"],"id":"http://www.w3.org/2004/02/skos/core#narrowMatch","description":"Narrower concepts in other schemes.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#narrowMatch"},{"path":["skos:relatedMatch"],"id":"http://www.w3.org/2004/02/skos/core#relatedMatch","description":"Related concepts in other schemes.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#relatedMatch"}]}