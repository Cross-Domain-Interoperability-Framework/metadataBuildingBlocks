{"defs":{},"properties":[{"path":["skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning of this concept.","required":true,"sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying meaning and/or intended use.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#scopeNote"},{"path":["skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about this concept.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["skos:historyNote"],"id":"http://www.w3.org/2004/02/skos/core#historyNote","description":"Note about past state or use.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#historyNote"},{"path":["skos:changeNote"],"id":"http://www.w3.org/2004/02/skos/core#changeNote","description":"Note documenting a change.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#changeNote"},{"path":["skos:editorialNote"],"id":"http://www.w3.org/2004/02/skos/core#editorialNote","description":"Note for editors and maintainers.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#editorialNote"},{"path":["skos:inScheme"],"id":"http://www.w3.org/2004/02/skos/core#inScheme","description":"Concept scheme(s) this concept belongs to.","required":true,"sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#inScheme"},{"path":["skos:topConceptOf"],"id":"http://www.w3.org/2004/02/skos/core#topConceptOf","description":"Concept scheme(s) for which this is a top concept.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#topConceptOf"},{"path":["skos:broader"],"id":"http://www.w3.org/2004/02/skos/core#broader","description":"Broader (parent) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#broader"},{"path":["skos:narrower"],"id":"http://www.w3.org/2004/02/skos/core#narrower","description":"Narrower (child) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConcept"],"effectiveId":"http://www.w3.org/2004/02/skos/core#narrower"}]}