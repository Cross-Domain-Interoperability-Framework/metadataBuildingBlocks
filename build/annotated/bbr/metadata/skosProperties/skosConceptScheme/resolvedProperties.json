te"],"id":"http://www.w3.org/2004/02/skos/core#historyNote","description":"Note about past state or use.","effectiveId":"http://www.w3.org/2004/02/skos/core#historyNote"},{"path":["skos:hasTopConcept","skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["skos:hasTopConcept","skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying meaning and/or intended use.","effectiveId":"http://www.w3.org/2004/02/skos/core#scopeNote"},{"path":["skos:hasTopConcept","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning of this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["skos:hasTopConcept","skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["skos:hasTopConcept","skos:hiddenLabel"],"id":"http://www.w3.org/2004/02/skos/core#hiddenLabel","description":"Labels accessible to free-text search but not displayed.","effectiveId":"http://www.w3.org/2004/02/skos/core#hiddenLabel"},{"path":["skos:hasTopConcept","skos:altLabel"],"id":"http://www.w3.org/2004/02/skos/core#altLabel","description":"Alternative lexical labels (acronyms, abbreviations, variants).","effectiveId":"http://www.w3.org/2004/02/skos/core#altLabel"},{"path":["skos:hasTopConcept","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"}]}