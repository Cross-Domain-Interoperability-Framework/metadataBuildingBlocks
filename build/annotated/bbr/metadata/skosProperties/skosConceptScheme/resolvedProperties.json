{"defs":{},"properties":[{"path":["skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for the concept scheme. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["skos:altLabel"],"id":"http://www.w3.org/2004/02/skos/core#altLabel","description":"Alternative lexical labels (acronyms, abbreviations, spelling variants).","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://www.w3.org/2004/02/skos/core#altLabel"},{"path":["skos:hiddenLabel"],"id":"http://www.w3.org/2004/02/skos/core#hiddenLabel","description":"Labels accessible to free-text search but not displayed.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://www.w3.org/2004/02/skos/core#hiddenLabel"},{"path":["skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning or purpose of this concept scheme.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code or notation for this concept scheme.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about the concept scheme.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying the intended scope of the concept scheme.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://www.w3.org/2004/02/skos/core#scopeNote"},{"path":["skos:historyNote"],"id":"http://www.w3.org/2004/02/skos/core#historyNote","description":"Note about the history of the concept scheme.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://www.w3.org/2004/02/skos/core#historyNote"},{"path":["skos:changeNote"],"id":"http://www.w3.org/2004/02/skos/core#changeNote","description":"Note documenting a change to the concept scheme.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://www.w3.org/2004/02/skos/core#changeNote"},{"path":["skos:editorialNote"],"id":"http://www.w3.org/2004/02/skos/core#editorialNote","description":"Note for editors, translators, and maintainers.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://www.w3.org/2004/02/skos/core#editorialNote"},{"path":["skos:example"],"id":"http://www.w3.org/2004/02/skos/core#example","description":"Example of the use of this concept scheme.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://www.w3.org/2004/02/skos/core#example"},{"path":["skos:hasTopConcept"],"id":"http://www.w3.org/2004/02/skos/core#hasTopConcept","description":"Top-level concepts in this scheme. Each item is a skos:Concept (inline or @id reference).","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://www.w3.org/2004/02/skos/core#hasTopConcept"},{"path":["dcterms:creator"],"id":"http://purl.org/dc/terms/creator","description":"Agent(s) who created this concept scheme.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://purl.org/dc/terms/creator"},{"path":["dcterms:creator","_anyOf"],"sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"keyword":"anyOf"},{"path":["dcterms:creator","_anyOf","1"],"title":"a","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"keyword":"branch"},{"path":["dcterms:creator","_anyOf","1","schema:name"],"id":"http://schema.org/name","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://schema.org/name"},{"path":["dcterms:creator","_anyOf","2"],"title":"b","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"keyword":"branch"},{"path":["dcterms:created"],"id":"http://purl.org/dc/terms/created","description":"Date the concept scheme was created (ISO 8601).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://purl.org/dc/terms/created"},{"path":["dcterms:modified"],"id":"http://purl.org/dc/terms/modified","description":"Date the concept scheme was last modified (ISO 8601).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://purl.org/dc/terms/modified"},{"path":["dcterms:title"],"id":"http://purl.org/dc/terms/title","description":"Title of the concept scheme (Dublin Core). Prefer skos:prefLabel for the SKOS label; dcterms:title may be used for additional metadata.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://purl.org/dc/terms/title"},{"path":["dcterms:description"],"id":"http://purl.org/dc/terms/description","description":"Description of the concept scheme (Dublin Core).","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"http://purl.org/dc/terms/description"},{"path":["dcterms:license"],"id":"http://purl.org/dc/terms/license","description":"License for the concept scheme.","sources":["bblocks://cdif.bbr.metadata.skosProperties.skosConceptScheme"],"effectiveId":"