{"defs":{},"properties":[{"path":["bios:executesLabProtocol"],"id":"https://bioschemas.org/executesLabProtocol","description":"The laboratory protocol executed by this process. Links a LabProcess activity to the LabProtocol it follows. In cdifProvActivity, also mapped to schema:actionProcess for compatibility.","sources":["bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties"],"effectiveId":"https://bioschemas.org/executesLabProtocol"},{"path":["bios:parameterValue"],"id":"https://bioschemas.org/parameterValue","description":"Actual parameter values used during a lab process execution. Each entry is a schema:PropertyValue recording a specific instrument setting or measurement condition (temperature, flow rate, scan range, etc.).","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties"],"effectiveId":"https://bioschemas.org/parameterValue"},{"path":["bios:parameterValue","schema:name"],"id":"http://schema.org/name","description":"Name of the parameter","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties"],"effectiveId":"http://schema.org/name"},{"path":["bios:parameterValue","schema:value"],"id":"http://schema.org/value","description":"The actual value (string, number, or boolean)","sources":["bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties"],"effectiveId":"http://schema.org/value"},{"path":["bios:parameterValue","schema:unitText"],"id":"http://schema.org/unitText","description":"Unit of measurement (e.g. degrees C, mL/min, mg)","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties"],"effectiveId":"http://schema.org/unitText"},{"path":["bios:parameterValue","schema:propertyID"],"id":"http://schema.org/propertyID","description":"Link to the FormalParameter definition this value realizes","sources":["bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties"],"effectiveId":"http://schema.org/propertyID"},{"path":["bios:labEquipment"],"id":"https://bioschemas.org/labEquipment","description":"Laboratory equipment used in a protocol. Instruments, devices, and apparatus employed during the process.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties"],"effectiveId":"https://bioschemas.org/labEquipment"},{"path":["bios:computationalTool"],"id":"https://bioschemas.org/computationalTool","description":"Software or computational tool used as part of a lab protocol to complete a part of it.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties"],"effectiveId":"https://bioschemas.org/computationalTool"},{"path":["bios:reagent"],"id":"https://bioschemas.org/reagent","description":"Materials or chemical substances used in protocol execution.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties"],"effectiveId":"https://bioschemas.org/reagent"},{"path":["bios:executesLabProtocol","schema:result"],"id":"http://schema.org/result","description":"Expected output parameters (FormalParameter references)","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties"],"effectiveId":"http://schema.org/result"},{"path":["bios:executesLabProtocol","schema:object"],"id":"http://schema.org/object","description":"Expected input parameters (FormalParameter references)","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties"],"effectiveId":"http://schema.org/object"},{"path":["bios:executesLabProtocol","schema:object","schema:name"],"id":"http://schema.org/name","description":"Name matching the corresponding workflow parameter slot","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties"]