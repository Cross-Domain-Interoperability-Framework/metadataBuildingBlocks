{"defs":{"0":[{"path":["cdi:ddiReference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiReference","description":"DDI IRDI reference","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiReference"},{"path":["cdi:ddiReference","cdi:dataIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/dataIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/dataIdentifier"},{"path":["cdi:ddiReference","cdi:registrationAuthorityIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/registrationAuthorityIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/registrationAuthorityIdentifier"},{"path":["cdi:ddiReference","cdi:versionIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/versionIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/versionIdentifier"},{"path":["cdi:description"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description","description":"Human-readable description of the reference","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description"},{"path":["cdi:semantic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic","description":"Semantic role of this reference","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic"},{"path":["cdi:uri"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri","description":"URI of the referenced entity","schema_type":"string","format":"uri","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri"}],"1":[{"path":["cdi:context"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/context","description":"Context or usage of this name","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/context"},{"path":["cdi:context","cdi:entryReference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference","description":"A reference to the specific item in the vocabulary referenced by cdi:vocabulary, using a URI or other resolvable identifier.","schema_type":"array","ref":"0","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference"},{"path":["cdi:context","cdi:entryValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue","description":"The value of the entry of the controlled vocabulary. If no controlled vocabulary is used the term is entered here and none of the properties defining the controlled vocabulary location are used.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue"},{"path":["cdi:context","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"The name of the code list (controlled vocabulary).","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["cdi:context","cdi:valueForOther"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther","description":"If the value of the string is \"Other\" or the equivalent from the codelist, this attribute can provide a more specific value not found in the codelist.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther"},{"path":["cdi:context","cdi:vocabulary"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary","description":"A reference to the external controlled vocabulary, using a URI or other resolvable identifier.","ref":"0","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary"},{"path":["cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"The name string","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"}],"2":[{"path":["cdi:languageSpecificString"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/languageSpecificString","description":"Language-tagged string value(s)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/languageSpecificString"},{"path":["cdi:languageSpecificString","cdi:content"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content","description":"The text content","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content"},{"path":["cdi:languageSpecificString","cdi:language"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/language","description":"ISO language code (e.g. en, fr, de)","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/language"}]},"properties":[{"path":["_anyOf"],"sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"keyword":"anyOf"},{"path":["_anyOf","0"],"title":"a","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"keyword":"branch"},{"path":["_anyOf","0","cdi:allowsDuplicates"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/allowsDuplicates","description":"If value is False, the members are unique within the collection - if True, there may be duplicates. (Note that a mathematical \u201cbag\u201d permits duplicates and is unordered - a \u201cset\u201d does not have duplicates and may be ordered.)","schema_type":"boolean","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/allowsDuplicates"},{"path":["_anyOf","0","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"Human understandable name (linguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"ref":"1","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["_anyOf","0","cdi:purpose"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose","description":"Intent or reason for the object/the description of the object.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"ref":"2","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose"},{"path":["_anyOf","0","cdi:has"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/has","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/has"},{"path":["_anyOf","1"],"title":"b","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"keyword":"branch"},{"path":["_anyOf","1","cdi:has"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/has","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/has"},{"path":["_anyOf","1","cdi:allowsDuplicates"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/allowsDuplicates","description":"If value is False, the members are unique within the collection - if True, there may be duplicates. (Note that a mathematical \u201cbag\u201d permits duplicates and is unordered - a \u201cset\u201d does not have duplicates and may be ordered.)","schema_type":"boolean","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/allowsDuplicates"},{"path":["_anyOf","1","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"Human understandable name (linguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"ref":"1","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["_anyOf","1","cdi:purpose"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose","description":"Intent or reason for the object/the description of the object.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"ref":"2","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose"},{"path":["_anyOf","2"],"title":"c","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"keyword":"branch"},{"path":["_anyOf","2","cdi:correspondence"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/correspondence","description":"Type of correspondence in terms of commonalities and differences between two members.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/correspondence"},{"path":["_anyOf","2","cdi:correspondence","cdi:commonality"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/commonality","description":"A description of the common features of the two items.","ref":"2","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/commonality"},{"path":["_anyOf","2","cdi:correspondence","cdi:commonalityCode"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/commonalityCode","description":"Commonality expressed as a term or code. Supports the use of an external controlled vocabulary. Ordered; repeat to cite multiple vocabularies.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/commonalityCode"},{"path":["_anyOf","2","cdi:correspondence","cdi:difference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/difference","description":"A description of the differences between the two items.","ref":"2","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/difference"},{"path":["_anyOf","2","cdi:correspondence","cdi:matching"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/matching","description":"The type of match between the two items (MatchingCriterion).","schema_type":"string","enum":["CloseMatch","Disjoint","ExactMatch"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/matching"},{"path":["_anyOf","2","cdi:hasTarget"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasTarget","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasTarget"},{"path":["_anyOf","2","cdi:hasSource"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasSource","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasSource"},{"path":["_anyOf","4"],"title":"d","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"keyword":"branch"},{"path":["_anyOf","4","cdi:semantics"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantics","description":"Specifies the semantics of the object in reference to a vocabulary, ontology, etc.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantics"},{"path":["_anyOf","4","cdi:hasTarget"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasTarget","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasTarget"},{"path":["_anyOf","4","cdi:hasSource"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasSource","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasSource"},{"path":["_anyOf","6"],"title":"e","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"keyword":"branch"},{"path":["_anyOf","6","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"Human understandable name (linguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"ref":"1","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["_anyOf","6","cdi:purpose"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose","description":"Intent or reason for the object/the description of the object.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"ref":"2","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose"},{"path":["_anyOf","6","cdi:semantics"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantics","description":"Specifies the semantics of the object in reference to a vocabulary, ontology, etc.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantics"},{"path":["_anyOf","6","cdi:specification"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/specification","description":"Provides information on reflexivity, transitivity, and symmetry of relationship using a descriptive term from an enumerated list. Use if all relations within this relation structure are of the same specification.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/specification"},{"path":["_anyOf","6","cdi:specification","cdi:reflexive"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/reflexive","description":"Whether members are related to themselves (MemberRelationshipScope).","schema_type":"string","enum":["All","None","Some"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/reflexive"},{"path":["_anyOf","6","cdi:specification","cdi:symmetric"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/symmetric","description":"Whether the member relationship is symmetric (MemberRelationshipScope).","schema_type":"string","enum":["All","None","Some"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/symmetric"},{"path":["_anyOf","6","cdi:specification","cdi:transitive"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/transitive","description":"Whether the member relationship is transitive (MemberRelationshipScope).","schema_type":"string","enum":["All","None","Some"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/transitive"},{"path":["_anyOf","6","cdi:topology"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/topology","description":"Means of organizing a set of members in a collection based on explicit rules for how members are related to each other. At a minimum, the controlled vocabulary should contain the following entries below. Note that these entries overlap and need to be organized into a type hierarchy once other entries are identified and defined.\n\n- Graph: organized collection where members are vertices and relationships between them are edges. - Lattice: organized collection where members are vertices, relationships between them are directed edges and there are two and only two distinguished vertices, i.e. a source, which has only outgoing edges, and a sink, which has only incoming edges. - Network/mesh: collection of linked members. - Partition: organized collection where members are grouped into non-empty and non-overlapping sub-collections - Tree: organized collection where members are vertices, relationships between them are edges and any two vertices are connected by exactly one path (sequence of contiguous edges)","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/topology"},{"path":["_anyOf","6","cdi:totality"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/totality","description":"Indicates whether the related collections are comprehensive in terms of their coverage i.e application to all (total) or some (partial) members.","schema_type":"string","enum":["Partial","Total"],"sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/totality"},{"path":["_anyOf","6","cdi:structures"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/structures","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/structures"},{"path":["_anyOf","6","cdi:has"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/has","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/has"},{"path":["_anyOf","8"],"title":"f","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"keyword":"branch"},{"path":["_anyOf","8","cdi:purpose"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose","description":"Intent or reason for the object/the description of the object.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"ref":"2","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose"},{"path":["_anyOf","8","cdi:maps"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maps","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maps"},{"path":["_anyOf","8","cdi:has"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/has","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/has"},{"path":["_anyOf","1","cdi:has","cdi:indexes"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/indexes","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/indexes"},{"path":["_anyOf","1","cdi:has","cdi:value"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/value","description":"Index value of the member in an ordered array.","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCollections"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/value"}]}