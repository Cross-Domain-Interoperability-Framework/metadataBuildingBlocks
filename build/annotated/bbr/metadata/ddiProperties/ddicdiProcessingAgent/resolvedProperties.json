{"defs":{"0":[{"path":["cdi:historicDate"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/historicDate","description":"Free-text historic date","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/historicDate"},{"path":["cdi:isoDate"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isoDate","description":"ISO 8601 date-time value","schema_type":"string","format":"date-time","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isoDate"}],"1":[{"path":["cdi:dataIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/dataIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/dataIdentifier"},{"path":["cdi:registrationAuthorityIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/registrationAuthorityIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/registrationAuthorityIdentifier"},{"path":["cdi:versionIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/versionIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/versionIdentifier"}],"2":[{"path":["cdi:ddiReference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiReference","description":"DDI IRDI reference","ref":"1","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiReference"},{"path":["cdi:description"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description","description":"Human-readable description of the reference","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description"},{"path":["cdi:semantic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic","description":"Semantic role of this reference","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic"},{"path":["cdi:uri"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri","description":"URI of the referenced entity","schema_type":"string","format":"uri","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri"}]},"properties":[{"path":["cdi:performs"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/performs","description":"Activities this agent performs (cdi:Activity). Use @id references to Activity nodes defined elsewhere in the graph.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiProcessingAgent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/performs"},{"path":["cdi:operatesOn"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/operatesOn","description":"Production environments this agent operates on (cdi:ProductionEnvironment)","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiProcessingAgent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/operatesOn"},{"path":["cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Formal identifier for this agent","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiProcessingAgent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["cdi:identifier","cdi:ddiIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiIdentifier","description":"DDI-specific IRDI identifier","ref":"1","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiIdentifier"},{"path":["cdi:identifier","cdi:uri"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri","description":"URI form of the identifier","schema_type":"string","format":"uri","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri"},{"path":["cdi:identifier","cdi:nonDdiIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nonDdiIdentifier","description":"Non-DDI identifier","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nonDdiIdentifier"},{"path":["cdi:image"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/image","description":"Image associated with this agent","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiProcessingAgent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/image"},{"path":["cdi:image","cdi:effectiveDates"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/effectiveDates","description":"Date range when this image is effective","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/effectiveDates"},{"path":["cdi:image","cdi:effectiveDates","cdi:startDate"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/startDate","description":"Start date of the range","ref":"0","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/startDate"},{"path":["cdi:image","cdi:effectiveDates","cdi:endDate"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/endDate","description":"End date of the range","ref":"0","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/endDate"},{"path":["cdi:image","cdi:privacy"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/privacy","description":"Privacy classification","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/privacy"},{"path":["cdi:image","cdi:privacy","cdi:entryReference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference","description":"A reference to the specific item in the vocabulary referenced by cdi:vocabulary, using a URI or other resolvable identifier.","schema_type":"array","ref":"2","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference"},{"path":["cdi:image","cdi:privacy","cdi:entryValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue","description":"The value of the entry of the controlled vocabulary. If no controlled vocabulary is used the term is entered here and none of the properties defining the controlled vocabulary location are used.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue"},{"path":["cdi:image","cdi:privacy","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"The name of the code list (controlled vocabulary).","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["cdi:image","cdi:privacy","cdi:valueForOther"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther","description":"If the value of the string is \"Other\" or the equivalent from the codelist, this attribute can provide a more specific value not found in the codelist.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther"},{"path":["cdi:image","cdi:privacy","cdi:vocabulary"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary","description":"A reference to the external controlled vocabulary, using a URI or other resolvable identifier.","ref":"2","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary"},{"path":["cdi:purpose"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose","description":"Purpose or role of this agent","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiProcessingAgent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose"},{"path":["cdi:purpose","cdi:languageSpecificString"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/languageSpecificString","description":"Language-tagged string value(s)","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/languageSpecificString"},{"path":["cdi:identifier","cdi:nonDdiIdentifier","cdi:managingAgency"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/managingAgency","description":"Agency managing this identifier scheme","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/managingAgency"},{"path":["cdi:identifier","cdi:nonDdiIdentifier","cdi:identifierContent"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifierContent","description":"The identifier value","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifierContent"},{"path":["cdi:purpose","cdi:languageSpecificString","cdi:language"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/language","description":"ISO language code (e.g. en, fr, de)","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/language"},{"path":["cdi:purpose","cdi:languageSpecificString","cdi:content"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content","description":"The text content","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content"}]}