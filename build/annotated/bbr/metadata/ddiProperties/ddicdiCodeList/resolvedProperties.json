{"defs":{"0":[{"path":["cdi:dataIdentifier"],"required":true,"schema_type":"string"},{"path":["cdi:registrationAuthorityIdentifier"],"required":true,"schema_type":"string"},{"path":["cdi:versionIdentifier"],"required":true,"schema_type":"string"}],"1":[{"path":["cdi:ddiReference"],"description":"DDI IRDI reference","ref":"0"},{"path":["cdi:description"],"description":"Human-readable description of the reference","schema_type":"string"},{"path":["cdi:semantic"],"description":"Semantic role of this reference"},{"path":["cdi:uri"],"description":"URI of the referenced entity","schema_type":"string","format":"uri"}]},"properties":[{"path":["cdi:allowsDuplicates"],"description":"If value is False, the members are unique within the collection - if True, there may be duplicates. (Note that a mathematical \u201cbag\u201d permits duplicates and is unordered - a \u201cset\u201d does not have duplicates and may be ordered.)","schema_type":"boolean","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCodeList"]},{"path":["cdi:has"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCodeList"]},{"path":["cdi:identifier"],"description":"Identifier for objects requiring short- or long-lasting referencing and management.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCodeList"]},{"path":["cdi:identifier","cdi:ddiIdentifier"],"description":"DDI-specific IRDI identifier","ref":"0"},{"path":["cdi:identifier","cdi:uri"],"description":"URI form of the identifier","schema_type":"string","format":"uri"},{"path":["cdi:identifier","cdi:nonDdiIdentifier"],"description":"Non-DDI identifier"},{"path":["cdi:name"],"description":"Human understandable name (liguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCodeList"]},{"path":["cdi:name","cdi:name"],"description":"The name string","required":true,"schema_type":"string"},{"path":["cdi:name","cdi:context"],"description":"Context or usage of this name"},{"path":["cdi:name","cdi:context","cdi:entryReference"],"description":"A reference to the specific item in the vocabulary referenced by cdi:vocabulary, using a URI or other resolvable identifier.","schema_type":"array","ref":"1"},{"path":["cdi:name","cdi:context","cdi:entryValue"],"description":"The value of the entry of the controlled vocabulary. If no controlled vocabulary is used the term is entered here and none of the properties defining the controlled vocabulary location are used.","schema_type":"array"},{"path":["cdi:name","cdi:context","cdi:name"],"description":"The name of the code list (controlled vocabulary).","schema_type":"string"},{"path":["cdi:name","cdi:context","cdi:valueForOther"],"description":"If the value of the string is \"Other\" or the equivalent from the codelist, this attribute can provide a more specific value not found in the codelist.","schema_type":"string"},{"path":["cdi:name","cdi:context","cdi:vocabulary"],"description":"A reference to the external controlled vocabulary, using a URI or other resolvable identifier.","ref":"1"},{"path":["cdi:uses"],"sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCodeList"]},{"path":["cdi:references"],"sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCodeList"]},{"path":["cdi:isDefinedBy"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCodeList"]},{"path":["cdi:purpose"],"description":"Intent or reason for the object/the description of the object.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiCodeList"]},{"path":["cdi:purpose","cdi:languageSpecificString"],"description":"Language-tagged string value(s)"},{"path":["cdi:identifier","cdi:nonDdiIdentifier","cdi:managingAgency"],"description":"Agency managing this identifier scheme","schema_type":"string"},{"path":["cdi:identifier","cdi:nonDdiIdentifier","cdi:identifierContent"],"description":"The identifier value","required":true,"schema_type":"string"},{"path":["cdi:purpose","cdi:languageSpecificString","cdi:language"],"description":"ISO language code (e.g. en, fr, de)","schema_type":"string"},{"path":["cdi:purpose","cdi:languageSpecificString","cdi:content"],"description":"The text content","required":true,"schema_type":"string"}]}