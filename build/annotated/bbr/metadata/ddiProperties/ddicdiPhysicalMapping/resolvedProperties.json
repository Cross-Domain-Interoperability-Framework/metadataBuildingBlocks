chema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["_anyOf","0","cdi:formats","schema:measurementTechnique","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["_anyOf","0","cdi:formats","schema:measurementTechnique","schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["_anyOf","0","cdi:formats","schema:measurementTechnique","schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["_anyOf","0","cdi:formats","schema:measurementTechnique","schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["_anyOf","0","cdi:formats","schema:measurementTechnique","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["_anyOf","0","cdi:formats","schema:measurementTechnique","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["_anyOf","0","cdi:formats","schema:alternateName"],"id":"http://schema.org/alternateName","schema_type":"array","effectiveId":"http://schema.org/alternateName"},{"path":["_anyOf","0","cdi:formats","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["_anyOf","0","cdi:formats","schema:name"],"id":"http://schema.org/name","description":"string label associated with the variable in the dataset serialization","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["cdi:length"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/length","description":"The length in characters of the physical representation of the value.","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/length"},{"path":["cdi:decimalPositions"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions","description":"The number of decimal positions, used when the decimal position is implied (no decimal separator present).","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions"},{"path":["cdi:scale"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale","description":"The scale of the number - a multiplier used with the value to determine the measurement.","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale"},{"path":["cdi:numberPattern"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/numberPattern","description":"A pattern description of the format of a numeric value (W3C tabular-metadata pattern / UAX35 number format pattern).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/numberPattern"},{"path":["cdi:position"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/position","description":"The position of this mapping in an ordered sequence of mappings.","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/position"},{"path":["cdi:minimumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength","description":"The smallest possible length of the physical representation of the value.","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength"},{"path":["cdi:physicalDataType"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/physicalDataType","description":"The base datatype of the physical representation (e.g. an integer variable stored as a floating point number).","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/physicalDataType"},{"path":["cdi:defaultValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue","description":"A default string indicating the value to substitute for an empty string.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue"},{"path":["cdi:maximumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumLength","description":"The largest possible length of the physical representation of the value.","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org