{"defs":{"0":[{"path":["cdi:dataIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/dataIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/dataIdentifier"},{"path":["cdi:registrationAuthorityIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/registrationAuthorityIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/registrationAuthorityIdentifier"},{"path":["cdi:versionIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/versionIdentifier","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/versionIdentifier"}],"1":[{"path":["cdi:ddiReference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiReference","description":"DDI IRDI reference","ref":"0","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiReference"},{"path":["cdi:description"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description","description":"Human-readable description of the reference","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description"},{"path":["cdi:semantic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic","description":"Semantic role of this reference","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic"},{"path":["cdi:uri"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri","description":"URI of the referenced entity","schema_type":"string","format":"uri","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri"}],"2":[{"path":["cdi:ddiIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiIdentifier","description":"DDI-specific IRDI identifier","ref":"0","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/ddiIdentifier"},{"path":["cdi:nonDdiIdentifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nonDdiIdentifier","description":"Non-DDI identifier","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nonDdiIdentifier"},{"path":["cdi:nonDdiIdentifier","cdi:identifierContent"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifierContent","description":"The identifier value","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifierContent"},{"path":["cdi:nonDdiIdentifier","cdi:managingAgency"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/managingAgency","description":"Agency managing this identifier scheme","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/managingAgency"},{"path":["cdi:uri"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri","description":"URI form of the identifier","schema_type":"string","format":"uri","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/uri"}],"3":[{"path":["cdi:entryReference"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference","description":"A reference to the specific item in the vocabulary referenced by cdi:vocabulary, using a URI or other resolvable identifier.","schema_type":"array","ref":"1","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryReference"},{"path":["cdi:entryValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue","description":"The value of the entry of the controlled vocabulary. If no controlled vocabulary is used the term is entered here and none of the properties defining the controlled vocabulary location are used.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/entryValue"},{"path":["cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"The name of the code list (controlled vocabulary).","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["cdi:valueForOther"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther","description":"If the value of the string is \"Other\" or the equivalent from the codelist, this attribute can provide a more specific value not found in the codelist.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/valueForOther"},{"path":["cdi:vocabulary"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary","description":"A reference to the external controlled vocabulary, using a URI or other resolvable identifier.","ref":"1","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/vocabulary"}]},"properties":[{"path":["_anyOf"],"sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"keyword":"anyOf"},{"path":["_anyOf","0"],"title":"a","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"keyword":"branch"},{"path":["_anyOf","0","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"ref":"2","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","0","cdi:format"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/format","description":"The format of the physical representation of the value (W3C tabular-metadata format; DDI 3.2 ManagedNumericRepresentation@format).","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"ref":"3","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/format"},{"path":["_anyOf","0","cdi:formats"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/formats","description":"The InstanceVariable whose values this mapping physically represents.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/formats"},{"path":["_anyOf","1"],"title":"b","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"keyword":"branch"},{"path":["_anyOf","1","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"ref":"2","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","1","cdi:format"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/format","description":"The format of the physical representation of the value.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"ref":"3","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/format"},{"path":["_anyOf","1","cdi:defaultDecimalSeparator"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultDecimalSeparator","description":"The character separating the integer part from the fractional part of a decimal or real number. Default is \".\" (period).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultDecimalSeparator"},{"path":["_anyOf","1","cdi:defaultDigitGroupSeparator"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultDigitGroupSeparator","description":"A character separating groups of digits (for readability). Default is null.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultDigitGroupSeparator"},{"path":["_anyOf","1","cdi:mappingLabel"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/mappingLabel","description":"A human-readable display label for this mapping. Ordered; repeat for labels with different content.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/mappingLabel"},{"path":["_anyOf","1","cdi:mappingLabel","cdi:locationVariant"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/locationVariant","description":"Geographic or locale variant","ref":"3","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/locationVariant"},{"path":["_anyOf","1","cdi:mappingLabel","cdi:maxLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maxLength","description":"Maximum display length","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maxLength"},{"path":["_anyOf","1","cdi:mappingLabel","cdi:languageSpecificString"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/languageSpecificString","description":"The label text with language tag","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/languageSpecificString"},{"path":["_anyOf","1","cdi:mappingLabel","cdi:languageSpecificString","cdi:content"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content","description":"The text content","required":true,"schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content"},{"path":["_anyOf","1","cdi:mappingLabel","cdi:languageSpecificString","cdi:language"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/language","description":"ISO language code (e.g. en, fr, de)","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/language"},{"path":["_anyOf","1","cdi:formats"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/formats","description":"The InstanceVariable whose values this mapping physically represents.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/formats"},{"path":["_anyOf","2"],"title":"c","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"keyword":"branch"},{"path":["_anyOf","2","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"ref":"2","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","2","cdi:locator"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/locator","description":"A string that addresses the value's position in the physical layout (e.g. an XPath, JSON pointer, or array index expression).","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/locator"},{"path":["_anyOf","2","cdi:format"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/format","description":"The format of the physical representation of the value.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"ref":"3","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/format"},{"path":["_anyOf","2","cdi:formats"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/formats","description":"The InstanceVariable whose values this mapping physically represents.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/formats"},{"path":["_anyOf","0","cdi:formats","cdi:qualifies"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/qualifies","description":"reference to an instance variable defined for this dataset","schema_type":"object","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/qualifies"},{"path":["_anyOf","0","cdi:formats","cdi:describedUnitOfMeasure"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/describedUnitOfMeasure","description":"The unit in which the data values are measured, expressed as a controlled-vocabulary entry (RepresentedVariable.describedUnitOfMeasure). For a plain-string unit, use cdif:simpleUnitOfMeasure instead.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/describedUnitOfMeasure"},{"path":["_anyOf","0","cdi:formats","cdi:hasIntendedDataType"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasIntendedDataType","description":"The data type intended to be used by this variable, independent of its physical representation (RepresentedVariable.hasIntendedDataType).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasIntendedDataType"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection"],"description":"The StatisticsCollection holding summary / category statistics for this InstanceVariable (InstanceVariable.isDescribedBy). cdif: namespaced and target-suffixed because the DDI-CDI isDescribedBy association is polymorphic."},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdi:hasWeight"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight","description":"The InstanceVariable whose values were used as weights (inline cdifInstanceVariable node or an @id-reference).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics"],"id":"https://cdif.org/0.1/has_Statistics","description":"Statistics nodes carried by this collection (inline or @id-ref). cdif: namespaced and target-suffixed because the DDI-CDI cdi:has association is polymorphic.","required":true,"schema_type":"array","effectiveId":"https://cdif.org/0.1/has_Statistics"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics"],"id":"https://cdif.org/0.1/has_CategoryStatistics","description":"CategoryStatistics entries breaking this Statistics bundle down by Category. cdif: namespaced and target-suffixed because the DDI-CDI cdi:has association is polymorphic.","schema_type":"array","effectiveId":"https://cdif.org/0.1/has_CategoryStatistics"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:hasWeight"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight","description":"The InstanceVariable whose values were used as weights (inline cdifInstanceVariable node or an @id-reference).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:statistic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/statistic","description":"Per-category Statistic value objects.","required":true,"schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/statistic"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:typeOfStatistic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfStatistic","description":"Controlled-vocabulary entry naming the kind of statistic.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfStatistic"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/for","description":"The Category this CategoryStatistics is for (inline Category node or an @id-reference).","required":true,"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/for"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for","cdif:name"],"id":"https://cdif.org/0.1/name","description":"Human-understandable name(s). CDIF-simplified from DDI-CDI Category.name (ObjectName) to plain strings.","schema_type":"array","effectiveId":"https://cdif.org/0.1/name"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for","cdif:descriptiveText"],"id":"https://cdif.org/0.1/descriptiveText","description":"Short natural-language account of the category. CDIF-simplified from DDI-CDI Category.descriptiveText (InternationalString).","schema_type":"string","effectiveId":"https://cdif.org/0.1/descriptiveText"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for","cdif:definition"],"id":"https://cdif.org/0.1/definition","description":"Natural-language definition of the category. CDIF-simplified from DDI-CDI Category.definition (InternationalString).","schema_type":"string","effectiveId":"https://cdif.org/0.1/definition"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for","cdif:displayLabel"],"id":"https://cdif.org/0.1/displayLabel","description":"Human-readable display label(s). CDIF-simplified from DDI-CDI Category.displayLabel (LabelForDisplay).","schema_type":"array","effectiveId":"https://cdif.org/0.1/displayLabel"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:appliesTo"],"id":"https://cdif.org/0.1/appliesTo","description":"CDIF addition (not in canonical DDI-CDI): the InstanceVariable(s) this Statistics bundle summarizes \u2014 the per-bundle \"what these numbers describe\" link. When a Statistics node sits inside a StatisticsCollection that indexes more than one variable, cdif:appliesTo disambiguates which variable each bundle describes.","schema_type":"array","effectiveId":"https://cdif.org/0.1/appliesTo"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:hasWeight"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight","description":"The InstanceVariable whose values were used as weights when computing the Statistic entries (inline cdifInstanceVariable node or an @id-reference).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/statistic","description":"Ordered list of Statistic value objects carried by this bundle. Order is significant \u2014 consumers MAY rely on array position.","required":true,"schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/statistic"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic","cdi:typeOfNumericValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfNumericValue","description":"The type of numeric value carried in cdi:content \u2014 decimal, float, or double.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfNumericValue"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic","cdi:isWeighted"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isWeighted","description":"True if the statistic was computed using a weighting variable.","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isWeighted"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic","cdi:content"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content","description":"The value of the statistic expressed as a real number.","schema_type":"number","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic","cdi:computationBase"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/computationBase","description":"The cases included in determining the statistic \u2014 Total (all cases, valid and missing), ValidOnly (valid values only), MissingOnly (invalid cases only).","schema_type":"string","enum":["MissingOnly","Total","ValidOnly"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/computationBase"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:typeOfStatistic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfStatistic","description":"Controlled-vocabulary entry naming the kind of statistic \u2014 e.g. mean, median, count, sum, stdDev.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfStatistic"},{"path":["_anyOf","0","cdi:formats","cdif:isDescribedBy_StatisticsCollection","cdif:indexedBy"],"id":"https://cdif.org/0.1/indexedBy","description":"CDIF addition (not in canonical DDI-CDI): the InstanceVariable(s) the contained Statistics index \u2014 the collection-level coordinate space.","schema_type":"array","effectiveId":"https://cdif.org/0.1/indexedBy"},{"path":["_anyOf","0","cdi:formats","cdi:source"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/source","description":"Reference capturing provenance information for this InstanceVariable (InstanceVariable.source).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/source"},{"path":["_anyOf","0","cdi:formats","cdi:platformType"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/platformType","description":"The application or technical system context in which the variable has been realized - typically a statistical processing package or processing environment (InstanceVariable.platformType).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/platformType"},{"path":["_anyOf","0","cdi:formats","cdi:function"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/function","description":"Immutable characteristic of the variable such as geographic designator, weight, temporal designation, etc. (InstanceVariable.function).","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/function"},{"path":["_anyOf","0","cdi:formats","cdif:uses"],"description":"Essentially the same as schema:propertyID. References to concepts that this variable measures or represents. When the dataset's distribution carries cdi:isStructuredBy (CDIF Data Structure profile), cdif:uses references the RepresentedVariable that supplies the represented-variable-level properties below, which are then NOT duplicated on the InstanceVariable.","schema_type":"array"},{"path":["_anyOf","0","cdi:formats","cdif:simpleUnitOfMeasure"]},{"path":["_anyOf","0","cdi:formats","cdif:role"],"description":"Specifies the role this variable plays in a data structure. UnitIdentifier names the unit a row describes; Measure holds observed/derived values; Attribute qualifies an observation; Dimension addresses a cell in a multi-dimensional cube; Descriptor names the variable that a Reference column records values for (long format); ReferenceVariable holds those recorded values.","schema_type":"string","enum":["UnitIdentifier","Measure","Attribute","Dimension","Descriptor","ReferenceVariable"]},{"path":["_anyOf","0","cdi:formats","cdif:physicalDataType"],"description":"identifier or name for the data type concept.","schema_type":"array"},{"path":["_anyOf","0","cdi:formats","schema:url"],"id":"http://schema.org/url","effectiveId":"http://schema.org/url"},{"path":["_anyOf","0","cdi:formats","schema:url","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["_anyOf","0","cdi:formats","schema:url","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["_anyOf","0","cdi:formats","schema:url","schema:url"],"id":"http://schema.org/url","required":true,"schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["_anyOf","0","cdi:formats","schema:url","dcat:hadRole"],"id":"http://www.w3.org/ns/dcat#hadRole","description":"Role of the related resource as a SKOS Concept (DCAT canonical role slot).","effectiveId":"http://www.w3.org/ns/dcat#hadRole"},{"path":["_anyOf","0","cdi:formats","schema:url","dcat:hadRole","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["_anyOf","0","cdi:formats","schema:url","dcat:hadRole","skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["_anyOf","0","cdi:formats","schema:url","dcat:hadRole","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning of this concept.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["_anyOf","0","cdi:formats","schema:url","dcat:hadRole","skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying meaning and/or intended use.","effectiveId":"htt