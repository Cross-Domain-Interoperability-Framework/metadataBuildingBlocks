{"defs":{},"properties":[{"path":["cdif:index"],"description":"Non-negative integer that orders the fields in the data structure (column number).","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifPhysicalMapping"]},{"path":["cdif:format"],"description":"A format for number expressed as a string, or date format like YYYY/MM or MM-DD-YY.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifPhysicalMapping"]},{"path":["cdif:physicalDataType"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifPhysicalMapping"]},{"path":["cdi:numberPattern"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/numberPattern","description":"Number format pattern for the field (PhysicalMapping.numberPattern). Text-format properties (column width, decimal/digit-group separators, display label) live on cdifTextMapping.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/numberPattern"},{"path":["cdi:nullSequence"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence","description":"The value of this property becomes the null annotation for the described column.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence"},{"path":["cdi:defaultValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue","description":"A default string indicating the value to substitute for an empty string.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifPhysicalMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue"},{"path":["cdi:scale"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.