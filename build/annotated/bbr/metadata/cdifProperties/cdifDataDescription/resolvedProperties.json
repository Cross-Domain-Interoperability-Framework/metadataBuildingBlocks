{"defs":{"0":[{"path":["cdi:decimalPositions"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions"},{"path":["cdi:defaultValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue","description":"A default string indicating the value to substitute for an empty string.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue"},{"path":["cdi:isRequired"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isRequired","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isRequired"},{"path":["cdi:length"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/length","description":"The column width if the tabular text is fixed width.","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/length"},{"path":["cdi:maximumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumLength","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumLength"},{"path":["cdi:minimumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength"},{"path":["cdi:nullSequence"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence","description":"The value of this property becomes the null annotation for the described column.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence"},{"path":["cdi:scale"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale"},{"path":["cdif:format"],"description":"A format for number expressed as a string, or date format like YYYY/MM or MM-DD-YY.","schema_type":"string"},{"path":["cdif:formats_InstanceVariable"],"description":"Reference to a variable defined in schema:variableMeasured.","schema_type":"object"},{"path":["cdif:index"],"description":"Non-negative integer that orders the fields in the data structure (column number).","schema_type":"integer"},{"path":["cdif:physicalDataType"],"schema_type":"string"}]},"properties":[{"path":["cdif:hasPrimaryKey"],"description":"Primary key of the dataset: a cdif:Key whose cdif:isComposedOf is an ordered list of cdi:InstanceVariables (from schema:variableMeasured) that uniquely identify each data instance.","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["cdif:statistics"],"description":"Summary statistics describing the dataset's values. Each entry is a cdi:Statistics bundle (one or more Statistic value objects, optionally weighted by an InstanceVariable, optionally broken down by Category) or a cdi:StatisticsCollection (groups multiple Statistics nodes and records which InstanceVariables they index). Inline node or @id-reference to one declared elsewhere in the document. cdif: namespaced \u2014 DDI-CDI has no `statistics` association from a dataset; this is a CDIF attachment property.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:subjectOf"],"sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:subjectOf","dcterms:conformsTo"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:variableMeasured"],"required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom"],"description":"Sentinel (missing / not-applicable) value domain(s) for this variable (RepresentedVariable.takesSentinelValuesFrom).","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:variableMeasured","cdi:takesSubstantiveValuesFrom"],"description":"The substantive value domain for this variable - the set of valid, meaningful values (RepresentedVariable.takesSubstantiveValuesFrom).","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:distribution"],"description":"Each schema:DataDownload distribution item SHOULD additionally be typed as cdi:PhysicalDataSet or one of its subclasses (cdi:TabularTextDataSet, cdi:StructuredDataSet). schema:WebAPI distribution items do not require a cdi: dataset type. Not enforced at schema level (the merge with cdifCore and cdifArchiveDistribution drops the @type constraint at profile resolution); consider a SHACL rule if runtime enforcement is needed.","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:distribution","cdif:hasPhysicalMapping"],"description":"Per-field physical mappings linking the variables measured by this distribution to their physical representation in the file - column index, format, physical data type, length, null sequence, etc. Applies to schema:DataDownload items typed as cdi:PhysicalDataSet or one of its subclasses. Each item is a cdifPhysicalMapping.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"],"ref":"0"},{"path":["schema:distribution","cdi:characterSet"],"description":"The character set used in the distribution (e.g., UTF-8, ASCII).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:distribution","cdif:fileSize"],"description":"The size of the distribution file.","schema_type":"number","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:distribution","cdif:fileSizeUofM"],"description":"Unit of measure for the file size (e.g., bytes, KB, MB, GB).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:distribution","schema:potentialAction"],"description":"For schema:WebAPI distributions, the potentialAction.result describes the physical realization of the API response bytes - analogous to a DataDownload distribution. The result MAY be additionally typed as cdi:PhysicalDataSet or one of its subclasses, and MAY carry the same physical-realization properties (cdif:hasPhysicalMapping, cdi:characterSet, cdif:fileSize, cdif:fileSizeUofM) as a DataDownload distribution. cdi:PhysicalDataSet typing belongs on the result, NOT on the WebAPI distribution itself - the WebAPI distribution describes the service; the result describes the bytes the service produces.","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:distribution","schema:potentialAction","schema:result"],"sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:distribution","schema:potentialAction","schema:result","cdif:hasPhysicalMapping"],"description":"Per-field physical mappings for the API response bytes. cdif:formats_InstanceVariable should reference the @ids of variables in the parent dataset's schema:variableMeasured (the API response is another physical realization of those same InstanceVariables).","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"],"ref":"0"},{"path":["schema:distribution","schema:potentialAction","schema:result","cdi:characterSet"],"description":"The character set used in the API response (e.g., UTF-8).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:distribution","schema:potentialAction","schema:result","cdif:fileSize"],"description":"The size of the API response payload.","schema_type":"number","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:distribution","schema:potentialAction","schema:result","cdif:fileSizeUofM"],"description":"Unit of measure for the response size (e.g., bytes, KB, MB).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataDescription"]},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:recommendedDataType"],"id":"https://cdif.org/0.1/recommendedDataType","description":"The data types that are recommended for use with this domain.","schema_type":"array","effectiveId":"https://cdif.org/0.1/recommendedDataType"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:displayLabel"],"id":"https://cdif.org/0.1/displayLabel","description":"A human-readable display label for the object. Supports the use of multiple languages. Repeat for labels with different content, for example, labels with differing length limitations.","schema_type":"string","effectiveId":"https://cdif.org/0.1/displayLabel"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom"],"id":"https://cdif.org/0.1/takesValuesFrom","effectiveId":"https://cdif.org/0.1/takesValuesFrom"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:identifier"],"id":"https://cdif.org/0.1/identifier","description":"Identifier for this enumerated (categorical) domain.","effectiveId":"https://cdif.org/0.1/identifier"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","schema:name"],"id":"http://schema.org/name","description":"Human understandable name (liguistic signifier, word, phrase, or mnemonic).","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references"],"id":"https://cdif.org/0.1/references","description":"SKOS concept scheme that contains concepts defining the allowed values of this enumeration domain.","required":true,"effectiveId":"https://cdif.org/0.1/references"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:version"],"id":"http://schema.org/version","description":"Version identifier for the concept scheme.","schema_type":["string","number"],"effectiveId":"http://schema.org/version"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","dcterms:rights"],"id":"http://purl.org/dc/terms/rights","description":"Rights statement for the concept scheme.","schema_type":"string","effectiveId":"http://purl.org/dc/terms/rights"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","dcterms:license"],"id":"http://purl.org/dc/terms/license","description":"License for the concept scheme.","effectiveId":"http://purl.org/dc/terms/license"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","dcterms:description"],"id":"http://purl.org/dc/terms/description","description":"Description of the concept scheme (Dublin Core).","effectiveId":"http://purl.org/dc/terms/description"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","dcterms:title"],"id":"http://purl.org/dc/terms/title","description":"Title of the concept scheme (Dublin Core). Prefer skos:prefLabel for the SKOS label; dcterms:title may be used for additional metadata.","effectiveId":"http://purl.org/dc/terms/title"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","dcterms:modified"],"id":"http://purl.org/dc/terms/modified","description":"Date the concept scheme was last modified (ISO 8601).","schema_type":"string","effectiveId":"http://purl.org/dc/terms/modified"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","dcterms:created"],"id":"http://purl.org/dc/terms/created","description":"Date the concept scheme was created (ISO 8601).","schema_type":"string","effectiveId":"http://purl.org/dc/terms/created"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","dcterms:creator"],"id":"http://purl.org/dc/terms/creator","description":"Agent(s) who created this concept scheme.","effectiveId":"http://purl.org/dc/terms/creator"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","dcterms:creator","_anyOf"],"keyword":"anyOf"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","dcterms:creator","_anyOf","2"],"title":"b","keyword":"branch"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","dcterms:creator","_anyOf","2","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","dcterms:creator","_anyOf","1"],"title":"a","keyword":"branch"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","dcterms:creator","_anyOf","1","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept"],"id":"http://www.w3.org/2004/02/skos/core#hasTopConcept","description":"Top-level concepts in this scheme. Each item is a skos:Concept (inline or @id reference).","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#hasTopConcept"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:example"],"id":"http://www.w3.org/2004/02/skos/core#example","description":"Example of the use of this concept scheme.","effectiveId":"http://www.w3.org/2004/02/skos/core#example"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:editorialNote"],"id":"http://www.w3.org/2004/02/skos/core#editorialNote","description":"Note for editors, translators, and maintainers.","effectiveId":"http://www.w3.org/2004/02/skos/core#editorialNote"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:changeNote"],"id":"http://www.w3.org/2004/02/skos/core#changeNote","description":"Note documenting a change to the concept scheme.","effectiveId":"http://www.w3.org/2004/02/skos/core#changeNote"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:historyNote"],"id":"http://www.w3.org/2004/02/skos/core#historyNote","description":"Note about the history of the concept scheme.","effectiveId":"http://www.w3.org/2004/02/skos/core#historyNote"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying the intended scope of the concept scheme.","effectiveId":"http://www.w3.org/2004/02/skos/core#scopeNote"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about the concept scheme.","effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code or notation for this concept scheme.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning or purpose of this concept scheme.","effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hiddenLabel"],"id":"http://www.w3.org/2004/02/skos/core#hiddenLabel","description":"Labels accessible to free-text search but not displayed.","effectiveId":"http://www.w3.org/2004/02/skos/core#hiddenLabel"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:altLabel"],"id":"http://www.w3.org/2004/02/skos/core#altLabel","description":"Alternative lexical labels (acronyms, abbreviations, spelling variants).","effectiveId":"http://www.w3.org/2004/02/skos/core#altLabel"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for the concept scheme. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["schema:variableMeasured","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:purpose"],"id":"https://cdif.org/0.1/purpose","description":"Intent or reason for the object/the description of the object.","schema_type":"string","effectiveId":"https://cdif.org/0.1/purpose"},{"path":["schema:variableMeasured","cdi:takesSubstantiveValuesFrom","cdif:recommendedDataType"],"id":"https://cdif.org/0.1/recommendedDataType","description":"The data types that are recommended for use with this domain.","schema_type":"array","effectiveId":"https://cdif.org/0.1/recommendedDataType"},{"path":["schema:variableMeasured","cdi:takesSubstantiveValuesFrom","cdif:displayLabel"],"id":"https://cdif.org/0.1/displayLabel","description":"A human-readable display label for the object. Supports the use of multiple languages. Repeat for labels with different content, for example, labels with differing length limitations.","schema_type":"string","effectiveId":"https://cdif.org/0.1/displayLabel"},{"path":["schema:variableMeasured","cdi:takesSubstantiveValuesFrom","cdif:takesValuesFrom"],"id":"https://cdif.org/0.1/takesValuesFrom","effectiveId":"https://cdif.org/0.1/takesValuesFrom"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf"],"id":"https://cdif.org/0.1/isComposedOf","description":"Ordered list of cdi:ComponentPosition wrappers. Each wrapper carries cdi:indexes (an inline cdifInstanceVariable or @id-reference to one declared elsewhere in the dataset) and cdi:value (the integer position in the key, 0- or 1-based).","required":true,"schema_type":"array","effectiveId":"https://cdif.org/0.1/isComposedOf"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:value"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/value","description":"Index value (position) of the variable in the ordered key.","required":true,"schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/value"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/indexes","required":true,"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/indexes"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:name"],"id":"http://schema.org/name","description":"string label associated with the variable in the dataset serialization","required":true,"schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:alternateName"],"id":"http://schema.org/alternateName","schema_type":"array","effectiveId":"http://schema.org/alternateName"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:measurementTechnique"],"id":"http://schema.org/measurementTechnique","description":"Text description or URI specifying how values for the variable were obtained.","effectiveId":"http://schema.org/measurementTechnique"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:measurementTechnique","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:propertyID"],"id":"http://schema.org/propertyID","description":"identifier or name for the property concept","schema_type":"array","effectiveId":"http://schema.org/propertyID"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:unitText"],"id":"http://schema.org/unitText","description":"unit of measurement as text","schema_type":"string","effectiveId":"http://schema.org/unitText"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:unitCode"],"id":"http://schema.org/unitCode","description":"URI or code identifying the unit of measure","effectiveId":"http://schema.org/unitCode"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:minValue"],"id":"http://schema.org/minValue","description":"minimum numeric value in the dataset","schema_type":"number","effectiveId":"http://schema.org/minValue"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:maxValue"],"id":"http://schema.org/maxValue","description":"maximum numeric value in the dataset","schema_type":"number","effectiveId":"http://schema.org/maxValue"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url"],"id":"http://schema.org/url","effectiveId":"http://schema.org/url"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcterms:relation"],"id":"http://purl.org/dc/terms/relation","description":"URI of the related resource (DCAT canonical pointer to what is being related to; distinct from schema:url which is the presentation URL inherited from labeledLink).","schema_type":"string","format":"uri","effectiveId":"http://purl.org/dc/terms/relation"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole"],"id":"http://www.w3.org/ns/dcat#hadRole","description":"Role of the related resource as a SKOS Concept (DCAT canonical role slot).","effectiveId":"http://www.w3.org/ns/dcat#hadRole"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:relatedMatch"],"id":"http://www.w3.org/2004/02/skos/core#relatedMatch","description":"Related concepts in other schemes.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#relatedMatch"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:narrowMatch"],"id":"http://www.w3.org/2004/02/skos/core#narrowMatch","description":"Narrower concepts in other schemes.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#narrowMatch"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:broadMatch"],"id":"http://www.w3.org/2004/02/skos/core#broadMatch","description":"Broader concepts in other schemes.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#broadMatch"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:closeMatch"],"id":"http://www.w3.org/2004/02/skos/core#closeMatch","description":"Concepts in other schemes with similar meaning.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#closeMatch"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:exactMatch"],"id":"http://www.w3.org/2004/02/skos/core#exactMatch","description":"Concepts in other schemes with equivalent meaning.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#exactMatch"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:related"],"id":"http://www.w3.org/2004/02/skos/core#related","description":"Associatively related concepts.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#related"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:narrower"],"id":"http://www.w3.org/2004/02/skos/core#narrower","description":"Narrower (child) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#narrower"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:broader"],"id":"http://www.w3.org/2004/02/skos/core#broader","description":"Broader (parent) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#broader"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:topConceptOf"],"id":"http://www.w3.org/2004/02/skos/core#topConceptOf","description":"Concept scheme(s) for which this is a top concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#topConceptOf"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:inScheme"],"id":"http://www.w3.org/2004/02/skos/core#inScheme","description":"Concept scheme(s) this concept belongs to.","effectiveId":"http://www.w3.org/2004/02/skos/core#inScheme"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:example"],"id":"http://www.w3.org/2004/02/skos/core#example","description":"Example of use of this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#example"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:editorialNote"],"id":"http://www.w3.org/2004/02/skos/core#editorialNote","description":"Note for editors and maintainers.","effectiveId":"http://www.w3.org/2004/02/skos/core#editorialNote"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:changeNote"],"id":"http://www.w3.org/2004/02/skos/core#changeNote","description":"Note documenting a change.","effectiveId":"http://www.w3.org/2004/02/skos/core#changeNote"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:historyNote"],"id":"http://www.w3.org/2004/02/skos/core#historyNote","description":"Note about past state or use.","effectiveId":"http://www.w3.org/2004/02/skos/core#historyNote"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying meaning and/or intended use.","effectiveId":"http://www.w3.org/2004/02/skos/core#scopeNote"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning of this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:hiddenLabel"],"id":"http://www.w3.org/2004/02/skos/core#hiddenLabel","description":"Labels accessible to free-text search but not displayed.","effectiveId":"http://www.w3.org/2004/02/skos/core#hiddenLabel"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:altLabel"],"id":"http://www.w3.org/2004/02/skos/core#altLabel","description":"Alternative lexical labels (acronyms, abbreviations, variants).","effectiveId":"http://www.w3.org/2004/02/skos/core#altLabel"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","dcat:hadRole","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","schema:url"],"id":"http://schema.org/url","required":true,"schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","schema:url","schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:physicalDataType"],"description":"identifier or name for the data type concept.","schema_type":"array"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:role"],"description":"Specifies the role this variable plays in a data structure. UnitIdentifier names the unit a row describes; Measure holds observed/derived values; Attribute qualifies an observation; Dimension addresses a cell in a multi-dimensional cube; Descriptor names the variable that a Reference column records values for (long format); ReferenceVariable holds those recorded values.","schema_type":"string","enum":["UnitIdentifier","Measure","Attribute","Dimension","Descriptor","ReferenceVariable"]},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:simpleUnitOfMeasure"]},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:uses"],"description":"Essentially the same as schema:propertyID. References to concepts that this variable measures or represents. When the dataset's distribution carries cdi:isStructuredBy (CDIF Data Structure profile), cdif:uses references the RepresentedVariable that supplies the represented-variable-level properties below, which are then NOT duplicated on the InstanceVariable.","schema_type":"array"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdi:function"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/function","description":"Immutable characteristic of the variable such as geographic designator, weight, temporal designation, etc. (InstanceVariable.function).","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/function"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdi:platformType"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/platformType","description":"The application or technical system context in which the variable has been realized - typically a statistical processing package or processing environment (InstanceVariable.platformType).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/platformType"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdi:source"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/source","description":"Reference capturing provenance information for this InstanceVariable (InstanceVariable.source).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/source"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection"],"description":"The StatisticsCollection holding summary / category statistics for this InstanceVariable (InstanceVariable.isDescribedBy). cdif: namespaced and target-suffixed because the DDI-CDI isDescribedBy association is polymorphic."},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:indexedBy"],"id":"https://cdif.org/0.1/indexedBy","description":"CDIF addition (not in canonical DDI-CDI): the InstanceVariable(s) the contained Statistics index \u2014 the collection-level coordinate space.","schema_type":"array","effectiveId":"https://cdif.org/0.1/indexedBy"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics"],"id":"https://cdif.org/0.1/has_Statistics","description":"Statistics nodes carried by this collection (inline or @id-ref). cdif: namespaced and target-suffixed because the DDI-CDI cdi:has association is polymorphic.","required":true,"schema_type":"array","effectiveId":"https://cdif.org/0.1/has_Statistics"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:typeOfStatistic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfStatistic","description":"Controlled-vocabulary entry naming the kind of statistic \u2014 e.g. mean, median, count, sum, stdDev.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfStatistic"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/statistic","description":"Ordered list of Statistic value objects carried by this bundle. Order is significant \u2014 consumers MAY rely on array position.","required":true,"schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/statistic"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic","cdi:computationBase"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/computationBase","description":"The cases included in determining the statistic \u2014 Total (all cases, valid and missing), ValidOnly (valid values only), MissingOnly (invalid cases only).","schema_type":"string","enum":["MissingOnly","Total","ValidOnly"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/computationBase"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic","cdi:content"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content","description":"The value of the statistic expressed as a real number.","schema_type":"number","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/content"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic","cdi:isWeighted"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isWeighted","description":"True if the statistic was computed using a weighting variable.","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isWeighted"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:statistic","cdi:typeOfNumericValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfNumericValue","description":"The type of numeric value carried in cdi:content \u2014 decimal, float, or double.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfNumericValue"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdi:hasWeight"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight","description":"The InstanceVariable whose values were used as weights when computing the Statistic entries (inline cdifInstanceVariable node or an @id-reference).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:appliesTo"],"id":"https://cdif.org/0.1/appliesTo","description":"CDIF addition (not in canonical DDI-CDI): the InstanceVariable(s) this Statistics bundle summarizes \u2014 the per-bundle \"what these numbers describe\" link. When a Statistics node sits inside a StatisticsCollection that indexes more than one variable, cdif:appliesTo disambiguates which variable each bundle describes.","schema_type":"array","effectiveId":"https://cdif.org/0.1/appliesTo"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics"],"id":"https://cdif.org/0.1/has_CategoryStatistics","description":"CategoryStatistics entries breaking this Statistics bundle down by Category. cdif: namespaced and target-suffixed because the DDI-CDI cdi:has association is polymorphic.","schema_type":"array","effectiveId":"https://cdif.org/0.1/has_CategoryStatistics"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/for","description":"The Category this CategoryStatistics is for (inline Category node or an @id-reference).","required":true,"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/for"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for","cdif:displayLabel"],"id":"https://cdif.org/0.1/displayLabel","description":"Human-readable display label(s). CDIF-simplified from DDI-CDI Category.displayLabel (LabelForDisplay).","schema_type":"array","effectiveId":"https://cdif.org/0.1/displayLabel"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for","cdif:definition"],"id":"https://cdif.org/0.1/definition","description":"Natural-language definition of the category. CDIF-simplified from DDI-CDI Category.definition (InternationalString).","schema_type":"string","effectiveId":"https://cdif.org/0.1/definition"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for","cdif:descriptiveText"],"id":"https://cdif.org/0.1/descriptiveText","description":"Short natural-language account of the category. CDIF-simplified from DDI-CDI Category.descriptiveText (InternationalString).","schema_type":"string","effectiveId":"https://cdif.org/0.1/descriptiveText"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:for","cdif:name"],"id":"https://cdif.org/0.1/name","description":"Human-understandable name(s). CDIF-simplified from DDI-CDI Category.name (ObjectName) to plain strings.","schema_type":"array","effectiveId":"https://cdif.org/0.1/name"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:typeOfStatistic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfStatistic","description":"Controlled-vocabulary entry naming the kind of statistic.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfStatistic"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:statistic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/statistic","description":"Per-category Statistic value objects.","required":true,"schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/statistic"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdif:has_Statistics","cdif:has_CategoryStatistics","cdi:hasWeight"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight","description":"The InstanceVariable whose values were used as weights (inline cdifInstanceVariable node or an @id-reference).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdif:isDescribedBy_StatisticsCollection","cdi:hasWeight"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight","description":"The InstanceVariable whose values were used as weights (inline cdifInstanceVariable node or an @id-reference).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasWeight"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdi:hasIntendedDataType"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasIntendedDataType","description":"The data type intended to be used by this variable, independent of its physical representation (RepresentedVariable.hasIntendedDataType).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasIntendedDataType"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdi:describedUnitOfMeasure"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/describedUnitOfMeasure","description":"The unit in which the data values are measured, expressed as a controlled-vocabulary entry (RepresentedVariable.describedUnitOfMeasure). For a plain-string unit, use cdif:simpleUnitOfMeasure instead.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/describedUnitOfMeasure"},{"path":["cdif:hasPrimaryKey","cdif:isComposedOf","cdi:indexes","cdi:qualifies"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/qualifies","description":"reference to an instance variable defined for this dataset","schema_type":"object","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/qualifies"}]}