{"defs":{"0":[{"path":["cdi:decimalPositions"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions"},{"path":["cdi:defaultValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue","description":"A default string indicating the value to substitute for an empty string.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue"},{"path":["cdi:isRequired"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isRequired","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isRequired"},{"path":["cdi:length"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/length","description":"The column width if the tabular text is fixed width.","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/length"},{"path":["cdi:maximumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumLength","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumLength"},{"path":["cdi:minimumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength"},{"path":["cdi:nullSequence"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence","description":"The value of this property becomes the null annotation for the described column.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence"},{"path":["cdi:scale"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale"},{"path":["cdif:format"],"description":"A format for number expressed as a string, or date format like YYYY/MM or MM-DD-YY.","schema_type":"string"},{"path":["cdif:formats_InstanceVariable"],"description":"Reference to a variable defined in schema:variableMeasured.","schema_type":"object"},{"path":["cdif:index"],"description":"Non-negative integer that orders the fields in the data structure (column number).","schema_type":"integer"},{"path":["cdif:locator"],"description":"String that can be used by software to locate values of the variable in this physical dataset.","schema_type":"string"},{"path":["cdif:physicalDataType"],"schema_type":"string"}]},"properties":[{"path":["schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:description"],"id":"http://schema.org/description","description":"Description of this distribution, e.g. what format, access constraints, etc.","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:contentUrl"],"id":"http://schema.org/contentUrl","required":true,"schema_type":"string","format":"uri","effectiveId":"http://schema.org/contentUrl"},{"path":["schema:encodingFormat"],"id":"http://schema.org/encodingFormat","description":"MIME type with extension; should indicate the serialization scheme in sufficient detail that machine can know how to parse.","schema_type":"array","effectiveId":"http://schema.org/encodingFormat"},{"path":["schema:contentSize"],"id":"http://schema.org/contentSize","description":"File size of this distribution, e.g. '2.5 MB' or a byte count. Per schema.org/contentSize.","schema_type":"string","effectiveId":"http://schema.org/contentSize"},{"path":["spdx:checksum"],"description":"A string value calculated from the content of the resource representation, used to test if content has been modified. The checksum is a property of a particular distribution/DataDownload.","schema_type":"object"},{"path":["spdx:checksum","spdx:algorithm"],"schema_type":"string"},{"path":["spdx:checksum","spdx:checksumValue"],"schema_type":"string"},{"path":["dcterms:conformsTo"],"description":"An identifier for a standard or specification that the distribution conforms to. Recommended to enable machine-actionable data access.","schema_type":"array"},{"path":["schema:provider"],"id":"http://schema.org/provider","description":"Party who maintains this particular distribution option for the dataset. Use this property if there are multiple distributions from different providers","schema_type":"array","effectiveId":"http://schema.org/provider"},{"path":["schema:hasPart"],"id":"http://schema.org/hasPart","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"effectiveId":"http://schema.org/hasPart"},{"path":["schema:hasPart","schema:name"],"id":"http://schema.org/name","description":"Filename of the component file within the archive.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"effectiveId":"http://schema.org/name"},{"path":["schema:hasPart","schema:description"],"id":"http://schema.org/description","description":"Description of the file content. May include checksum information.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"effectiveId":"http://schema.org/description"},{"path":["schema:hasPart","schema:encodingFormat"],"id":"http://schema.org/encodingFormat","description":"MIME type(s) for this file.","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"effectiveId":"http://schema.org/encodingFormat"},{"path":["schema:hasPart","schema:size"],"id":"http://schema.org/size","description":"File size as a QuantitativeValue.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"effectiveId":"http://schema.org/size"},{"path":["schema:hasPart","schema:size","schema:value"],"id":"http://schema.org/value","description":"Numeric size value.","schema_type":"number","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"effectiveId":"http://schema.org/value"},{"path":["schema:hasPart","schema:size","schema:unitText"],"id":"http://schema.org/unitText","description":"Unit of measure for size (e.g. 'byte').","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"effectiveId":"http://schema.org/unitText"},{"path":["schema:hasPart","schema:about"],"id":"http://schema.org/about","description":"For metadata sidecar files, references the data file this metadata describes.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"effectiveId":"http://schema.org/about"},{"path":["schema:hasPart","spdx:checksum"],"id":"http://spdx.org/rdf/terms#checksum","description":"Checksum for integrity verification of this component file.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"effectiveId":"http://spdx.org/rdf/terms#checksum"},{"path":["schema:hasPart","spdx:checksum","spdx:algorithm"],"id":"http://spdx.org/rdf/terms#algorithm","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"effectiveId":"http://spdx.org/rdf/terms#algorithm"},{"path":["schema:hasPart","spdx:checksum","spdx:checksumValue"],"id":"http://spdx.org/rdf/terms#checksumValue","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"effectiveId":"http://spdx.org/rdf/terms#checksumValue"},{"path":["schema:hasPart","_anyOf"],"sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"keyword":"anyOf"},{"path":["schema:hasPart","_anyOf","0"],"title":"a","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"keyword":"branch"},{"path":["schema:hasPart","_anyOf","0","cdif:hasPhysicalMapping"],"description":"Links variables to their physical representation in this dataset.","schema_type":"array","ref":"0"},{"path":["schema:hasPart","_anyOf","1"],"title":"b","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifArchive"],"keyword":"branch"},{"path":["schema:hasPart","_anyOf","1","_oneOf"],"keyword":"oneOf"},{"path":["schema:hasPart","_anyOf","1","_oneOf","0"],"title":"a","keyword":"branch"},{"path":["schema:hasPart","_anyOf","1","_oneOf","0","cdi:isDelimited"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited","required":true,"const":true,"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited"},{"path":["schema:hasPart","_anyOf","1","_oneOf","0","cdi:isFixedWidth"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth","const":false,"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth"},{"path":["schema:hasPart","_anyOf","1","_oneOf","1"],"title":"b","keyword":"branch"},{"path":["schema:hasPart","_anyOf","1","_oneOf","1","cdi:isDelimited"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited","const":false,"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited"},{"path":["schema:hasPart","_anyOf","1","_oneOf","1","cdi:isFixedWidth"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth","required":true,"const":true,"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth"},{"path":["schema:hasPart","_anyOf","1","cdi:arrayBase"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/arrayBase","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/arrayBase"},{"path":["schema:hasPart","_anyOf","1","csvw:commentPrefix"],"description":"An atomic property that sets the comment prefix flag to the single provided value, which MUST be a string. The default is '#'.","schema_type":"string"},{"path":["schema:hasPart","_anyOf","1","csvw:delimiter"],"description":"Sets the delimiter flag to the single provided value, which MUST be a string. The default is ','.","schema_type":"string"},{"path":["schema:hasPart","_anyOf","1","csvw:header"],"description":"If true, sets the header row count flag to 1, and if false to 0, unless headerRowCount is provided, in which case the value provided for the header property is ignored. The default is true.","schema_type":"boolean"},{"path":["schema:hasPart","_anyOf","1","csvw:headerRowCount"],"description":"A numeric atomic property that sets the header row count flag to the single provided value, which MUST be a non-negative integer.","schema_type":"integer"},{"path":["schema:hasPart","_anyOf","1","cdi:isDelimited"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited","description":"Schema constraint is that one of {'isDelimited','isFixedWidth'} must be present with a True value; the other one may be present or omitted, but if present must have a false value.","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDelimited"},{"path":["schema:hasPart","_anyOf","1","cdi:isFixedWidth"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isFixedWidth"},{"path":["schema:hasPart","_anyOf","1","csvw:lineTerminators"],"schema_type":"string","enum":["CRLF","LF","\r\n","\n"]},{"path":["schema:hasPart","_anyOf","1","csvw:quoteChar"],"description":"Same as DDI-CDI quoteCharacter. The string that is used around escaped cells.","schema_type":"string"},{"path":["schema:hasPart","_anyOf","1","csvw:skipBlankRows"],"schema_type":"boolean"},{"path":["schema:hasPart","_anyOf","1","csvw:skipColumns"],"description":"The number of columns to skip at the beginning of each row.","schema_type":"integer"},{"path":["schema:hasPart","_anyOf","1","csvw:skipInitialSpace"],"schema_type":"boolean"},{"path":["schema:hasPart","_anyOf","1","csvw:skipRows"],"description":"The number of rows to skip at the beginning of the file, before a header row or tabular data.","schema_type":"integer"},{"path":["schema:hasPart","_anyOf","1","cdi:escapeCharacter"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/escapeCharacter","description":"The character used to escape special characters in the data. From DDI-CDI PhysicalSegmentLayout.escapeCharacter.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/escapeCharacter"},{"path":["schema:hasPart","_anyOf","1","cdi:headerIsCaseSensitive"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/headerIsCaseSensitive","description":"Whether column header names are case-sensitive. From DDI-CDI PhysicalSegmentLayout.headerIsCaseSensitive.","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/headerIsCaseSensitive"},{"path":["schema:hasPart","_anyOf","1","cdi:treatConsecutiveDelimitersAsOne"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/treatConsecutiveDelimitersAsOne","description":"Whether consecutive delimiters should be treated as a single delimiter. From DDI-CDI PhysicalSegmentLayout.treatConsecutiveDelimitersAsOne.","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/treatConsecutiveDelimitersAsOne"},{"path":["schema:hasPart","_anyOf","1","csvw:tableDirection"],"description":"Indicates the direction of the table layout (left-to-right or right-to-left). From DDI-CDI PhysicalSegmentLayout.tableDirection.","schema_type":"string","enum":["Ltr","Rtl"]},{"path":["schema:hasPart","_anyOf","1","csvw:textDirection"],"description":"Indicates whether the text within cells should be displayed as left-to-right, right-to-left, according to content, or inherited from the table direction. From DDI-CDI PhysicalSegmentLayout.textDirection.","schema_type":"string","enum":["Auto","Inherit","Ltr","Rtl"]},{"path":["schema:hasPart","_anyOf","1","csvw:trim"],"description":"Indicates whether to trim whitespace around cells. 'true' corresponds to DDI-CDI 'both' value, 'false' corresponds to DDI-CDI 'neither' value.","schema_type":"string","enum":["true","end","false","start"]},{"path":["schema:hasPart","_anyOf","1","cdif:hasPhysicalMapping"],"description":"Links variables to their physical representation in this dataset.","required":true,"schema_type":"array","ref":"0"},{"path":["schema:hasPart","_anyOf","1","countRows"],"schema_type":"integer"},{"path":["schema:hasPart","_anyOf","1","countColumns"],"schema_type":"integer"},{"path":["schema:provider","schema:sameAs"],"id":"http://schema.org/sameAs","description":"other identifiers for the person","schema_type":"array","effectiveId":"http://schema.org/sameAs"},{"path":["schema:provider","schema:contactPoint"],"id":"http://schema.org/contactPoint","description":"restrict to email only. Schema.org allows telephone and postal contacts as well","schema_type":"object","effectiveId":"http://schema.org/contactPoint"},{"path":["schema:provider","schema:contactPoint","schema:email"],"id":"http://schema.org/email","required":true,"schema_type":"string","effectiveId":"http://schema.org/email"},{"path":["schema:provider","schema:affiliation"],"id":"http://schema.org/affiliation","description":"if affiliation is present, value must be a schema:Organization.","effectiveId":"http://schema.org/affiliation"},{"path":["schema:provider","schema:affiliation","schema:sameAs"],"id":"http://schema.org/sameAs","description":"other identifiers for the organization","schema_type":"array","effectiveId":"http://schema.org/sameAs"},{"path":["schema:provider","schema:affiliation","schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for organization","effectiveId":"http://schema.org/identifier"},{"path":["schema:provider","schema:affiliation","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:provider","schema:affiliation","schema:alternateName"],"id":"http://schema.org/alternateName","description":"other labels by which the organization might be known","schema_type":"string","effectiveId":"http://schema.org/alternateName"},{"path":["schema:provider","schema:affiliation","schema:name"],"id":"http://schema.org/name","description":"string label for organization that is meaningful for human users","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:provider","schema:affiliation","schema:additionalType"],"id":"http://schema.org/additionalType","schema_type":"array","effectiveId":"http://schema.org/additionalType"},{"path":["schema:provider","schema:affiliation","schema:additionalType","schema:name"],"id":"http://schema.org/name","description":"text label for the term that is useful to human user","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:provider","schema:affiliation","schema:additionalType","schema:identifier"],"id":"http://schema.org/identifier","effectiveId":"http://schema.org/identifier"},{"path":["schema:provider","schema:affiliation","schema:additionalType","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["schema:provider","schema:affiliation","schema:additionalType","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","effectiveId":"http://schema.org/termCode"},{"path":["schema:provider","schema:alternateName"],"id":"http://schema.org/alternateName","description":"other labels by which the person might be known","schema_type":"string","effectiveId":"http://schema.org/alternateName"},{"path":["schema:provider","schema:identifier"],"id":"http://schema.org/identifier","description":"identifier for person, recommend ORCID","effectiveId":"http://schema.org/identifier"},{"path":["schema:provider","schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["schema:provider","schema:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["schema:provider","schema:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["schema:provider","schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:provider","schema:name"],"id":"http://schema.org/name","description":"string label for person that is meaningful for human users, should format consistently. Recommend 'Family Name, Given name' format.","schema_type":"string","effectiveId":"http://schema.org/name"}]}