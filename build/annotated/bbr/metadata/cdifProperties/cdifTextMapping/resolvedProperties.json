{"defs":{},"properties":[{"path":["cdif:index"],"description":"Non-negative integer that orders the fields in the data structure (column number).","schema_type":"integer"},{"path":["cdif:format"],"description":"A format for number expressed as a string, or date format like YYYY/MM or MM-DD-YY.","schema_type":"string"},{"path":["cdif:physicalDataType"],"schema_type":"string"},{"path":["cdi:numberPattern"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/numberPattern","description":"Number format pattern for the field (PhysicalMapping.numberPattern). Text-format properties (column width, decimal/digit-group separators, display label) live on cdifTextMapping.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/numberPattern"},{"path":["cdi:nullSequence"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence","description":"The value of this property becomes the null annotation for the described column.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence"},{"path":["cdi:defaultValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue","description":"A default string indicating the value to substitute for an empty string.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue"},{"path":["cdi:scale"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale"},{"path":["cdi:decimalPositions"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions"},{"path":["cdi:minimumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength"},{"path":["cdi:maximumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumLength","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumLength"},{"path":["cdi:isRequired"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isRequired","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isRequired"},{"path":["cdif:formats_InstanceVariable"],"description":"Reference to a variable defined in schema:variableMeasured.","schema_type":"object"},{"path":["cdi:length"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/length","description":"The column width if the tabular text is fixed width (TextMapping.length).","schema_type":"integer","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifTextMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/length"},{"path":["cdi:defaultDecimalSeparator"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultDecimalSeparator","description":"Decimal separator used when not otherwise specified (TextMapping.defaultDecimalSeparator).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifTextMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultDecimalSeparator"},{"path":["cdi:defaultDigitGroupSeparator"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultDigitGroupSeparator","description":"Digit-group (thousands) separator (TextMapping.defaultDigitGroupSeparator).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifTextMapping"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultDigitGroupSeparator"},{"path":["cdif:displayLabel"],"id":"https://cdif.org/0.1/displayLabel","description":"Human-readable label(s) for display. CDIF simplification (plain string) of DDI-CDI TextMapping.displayLabel, whose model type is LabelForDisplay. Per the cdi/cdif namespace policy a structured-string type simplified to a plain string is in the cdif namespace.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifTextMapping"],"effectiveId":"https://cdif.org/0.1/displayLabel"}]}