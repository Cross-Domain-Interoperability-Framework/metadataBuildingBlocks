{"defs":{},"properties":[{"path":["schema:name"],"id":"http://schema.org/name","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["schema:description"],"id":"http://schema.org/description","schema_type":"string","effectiveId":"http://schema.org/description"},{"path":["schema:url"],"id":"http://schema.org/url","required":true,"schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["dcat:hadRole"],"id":"http://www.w3.org/ns/dcat#hadRole","description":"Role of the related resource as a SKOS Concept (DCAT canonical role slot).","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifReference"],"effectiveId":"http://www.w3.org/ns/dcat#hadRole"},{"path":["dcat:hadRole","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["dcat:hadRole","skos:altLabel"],"id":"http://www.w3.org/2004/02/skos/core#altLabel","description":"Alternative lexical labels (acronyms, abbreviations, variants).","effectiveId":"http://www.w3.org/2004/02/skos/core#altLabel"},{"path":["dcat:hadRole","skos:hiddenLabel"],"id":"http://www.w3.org/2004/02/skos/core#hiddenLabel","description":"Labels accessible to free-text search but not displayed.","effectiveId":"http://www.w3.org/2004/02/skos/core#hiddenLabel"},{"path":["dcat:hadRole","skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["dcat:hadRole","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning of this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["dcat:hadRole","skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying meaning and/or intended use.","effectiveId":"http://www.w3.org/2004/02/skos/core#scopeNote"},{"path":["dcat:hadRole","skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["dcat:hadRole","skos:historyNote"],"id":"http://www.w3.org/2004/02/skos/core#historyNote","description":"Note about past state or use.","effectiveId":"http://www.w3.org/2004/02/skos/core#historyNote"},{"path":["dcat:hadRole","skos:changeNote"],"id":"http://www.w3.org/2004/02/skos/core#changeNote","description":"Note documenting a change.","effectiveId":"http://www.w3.org/2004/02/skos/core#changeNote"},{"path":["dcat:hadRole","skos:editorialNote"],"id":"http://www.w3.org/2004/02/skos/core#editorialNote","description":"Note for editors and maintainers.","effectiveId":"http://www.w3.org/2004/02/skos/core#editorialNote"},{"path":["dcat:hadRole","skos:example"],"id":"http://www.w3.org/2004/02/skos/core#example","description":"Example of use of this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#example"},{"path":["dcat:hadRole","skos:inScheme"],"id":"http://www.w3.org/2004/02/skos/core#inScheme","description":"Concept scheme(s) this concept belongs to.","effectiveId":"http://www.w3.org/2004/02/skos/core#inScheme"},{"path":["dcat:hadRole","skos:topConceptOf"],"id":"http://www.w3.org/2004/02/skos/core#topConceptOf","description":"Concept scheme(s) for which this is a top concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#topConceptOf"},{"path":["dcat:hadRole","skos:broader"],"id":"http://www.w3.org/2004/02/skos/core#broader","description":"Broader (parent) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#broader"},{"path":["dcat:hadRole","skos:narrower"],"id":"http://www.w3.org/2004/02/skos/core#narrower","description":"Narrower (child) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#narrower"},{"path":["dcat:hadRole","skos:related"],"id":"http://www.w3.org/2004/02/skos/core#related","description":"Associatively related concepts.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#related"},{"path":["dcat:hadRole","skos:exactMatch"],"id":"http://www.w3.org/2004/02/skos/core#exactMatch","description":"Concepts in other schemes with equivalent meaning.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#exactMatch"},{"path":["dcat:hadRole","skos:closeMatch"],"id":"http://www.w3.org/2004/02/skos/core#closeMatch","description":"Concepts in other schemes with similar meaning.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#closeMatch"},{"path":["dcat:hadRole","skos:broadMatch"],"id":"http://www.w3.org/2004/02/skos/core#broadMatch","description":"Broader concepts in other schemes.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#broadMatch"},{"path":["dcat:hadRole","skos:narrowMatch"],"id":"http://www.w3.org/2004/02/skos/core#narrowMatch","description":"Narrower concepts in other schemes.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#narrowMatch"},{"path":["dcat:hadRole","skos:relatedMatch"],"id":"http://www.w3.org/2004/02/skos/core#relatedMatch","description":"Related concepts in other schemes.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#relatedMatch"},{"path":["dcterms:relation"],"id":"http://purl.org/dc/terms/relation","description":"URI of the related resource (DCAT canonical pointer to what is being related to; distinct from schema:url which is the presentation URL inherited from labeledLink).","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifReference"],"effectiveId":"http://purl.org/dc/terms/relation"}]}