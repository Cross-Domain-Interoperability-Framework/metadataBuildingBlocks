{"defs":{},"properties":[{"path":["cdif:hasPhysicalMapping"],"description":"Links variables to their physical representation in this dataset.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataCube"]},{"path":["cdif:hasPhysicalMapping","cdif:index"],"description":"Non-negative integer that orders the fields in the data structure (column number).","schema_type":"integer"},{"path":["cdif:hasPhysicalMapping","cdif:format"],"description":"A format for number expressed as a string, or date format like YYYY/MM or MM-DD-YY.","schema_type":"string"},{"path":["cdif:hasPhysicalMapping","cdif:physicalDataType"],"schema_type":"string"},{"path":["cdif:hasPhysicalMapping","cdi:numberPattern"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/numberPattern","description":"Number format pattern for the field (PhysicalMapping.numberPattern). Text-format properties (column width, decimal/digit-group separators, display label) live on cdifTextMapping.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/numberPattern"},{"path":["cdif:hasPhysicalMapping","cdi:nullSequence"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence","description":"The value of this property becomes the null annotation for the described column.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/nullSequence"},{"path":["cdif:hasPhysicalMapping","cdi:defaultValue"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue","description":"A default string indicating the value to substitute for an empty string.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/defaultValue"},{"path":["cdif:hasPhysicalMapping","cdi:scale"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/scale"},{"path":["cdif:hasPhysicalMapping","cdi:decimalPositions"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/decimalPositions"},{"path":["cdif:hasPhysicalMapping","cdi:minimumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumLength"},{"path":["cdif:hasPhysicalMapping","cdi:maximumLength"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumLength","schema_type":"integer","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumLength"},{"path":["cdif:hasPhysicalMapping","cdi:isRequired"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isRequired","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isRequired"},{"path":["cdif:hasPhysicalMapping","cdif:formats_InstanceVariable"],"description":"Reference to a variable defined in schema:variableMeasured.","schema_type":"object"},{"path":["cdif:hasPhysicalMapping","cdi:locator"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/locator","description":"String that can be used by software to locate values of the variable in this physical dataset (DDI-CDI LocatorMapping.locator).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataCube"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/locator"}]}