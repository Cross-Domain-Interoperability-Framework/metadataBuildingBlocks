{"defs":{},"properties":[{"path":["_anyOf"],"sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"keyword":"anyOf"},{"path":["_anyOf","0"],"title":"a","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"keyword":"branch"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable"],"required":true,"sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"]},{"path":["_anyOf","1"],"title":"b","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"keyword":"branch"},{"path":["_anyOf","1","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"Human understandable name (liguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["_anyOf","1","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","1","cdif:isDefinedBy_RepresentedVariable"],"sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"]},{"path":["_anyOf","1","cdi:semantic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic","description":"Qualifies the purpose or use expressed as a paired external controlled vocabulary.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic"},{"path":["_anyOf","2"],"title":"c","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"keyword":"branch"},{"path":["_anyOf","2","cdi:qualifies"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/qualifies","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/qualifies"},{"path":["_anyOf","2","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","2","cdif:isDefinedBy_RepresentedVariable"],"sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"]},{"path":["_anyOf","2","cdi:semantic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic","description":"Qualifies the purpose or use expressed as a paired external controlled vocabulary.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic"},{"path":["_anyOf","3"],"title":"d","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"keyword":"branch"},{"path":["_anyOf","3","cdif:isDefinedBy_RepresentedVariable"],"required":true,"sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"]},{"path":["_anyOf","4"],"title":"e","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"keyword":"branch"},{"path":["_anyOf","4","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","4","cdif:isDefinedBy_RepresentedVariable"],"sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"]},{"path":["_anyOf","4","cdi:semantic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic","description":"Qualifies the purpose or use expressed as a paired external controlled vocabulary.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic"},{"path":["_anyOf","5"],"title":"f","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"keyword":"branch"},{"path":["_anyOf","5","cdif:isDefinedBy_DescriptorVariable"],"required":true,"sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"]},{"path":["_anyOf","5","cdif:isDefinedBy_DescriptorVariable","cdif:hasValuesFrom"],"id":"https://cdif.org/0.1/hasValuesFrom","description":"A cdi:DescriptorValueDomain enumerating the codes that can appear in the descriptor column, each paired (via cdif:isDefinedBy) with the RepresentedVariable that the code names.","required":true,"effectiveId":"https://cdif.org/0.1/hasValuesFrom"},{"path":["_anyOf","5","cdif:isDefinedBy_DescriptorVariable","cdif:hasValuesFrom","cdif:takesValuesFrom"],"id":"https://cdif.org/0.1/takesValuesFrom","description":"Ordered list of descriptor entries. Each entry has a cdif:value (the code as it appears in the descriptor column) and a cdif:isDefinedBy pointer to the RepresentedVariable that the code names.","required":true,"schema_type":"array","effectiveId":"https://cdif.org/0.1/takesValuesFrom"},{"path":["_anyOf","5","cdif:isDefinedBy_DescriptorVariable","cdif:hasValuesFrom","cdif:takesValuesFrom","cdif:value"],"id":"https://cdif.org/0.1/value","description":"The code value as it appears in the descriptor column.","required":true,"schema_type":"string","effectiveId":"https://cdif.org/0.1/value"},{"path":["_anyOf","5","cdif:isDefinedBy_DescriptorVariable","cdif:hasValuesFrom","cdif:takesValuesFrom","cdif:isDefinedBy"],"id":"https://cdif.org/0.1/isDefinedBy","required":true,"effectiveId":"https://cdif.org/0.1/isDefinedBy"},{"path":["_anyOf","5","cdif:isDefinedBy_DescriptorVariable","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"Human understandable name (linguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["_anyOf","5","cdi:refersTo"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/refersTo","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/refersTo"},{"path":["_anyOf","5","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","5","cdi:semantic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic","description":"Qualifies the purpose or use expressed as a paired external controlled vocabulary.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdif:uses_Concept"],"schema_type":"array"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"Human understandable name (linguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:externalDefinition"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/externalDefinition","description":"A reference to an external definition of a concept (that is, a concept which is described outside the content of the DDI-CDI metadata description). An example is a SKOS concept. The definition property is assumed to duplicate the external one referenced if externalDefinition is used. Other corresponding properties are assumed to be included unchanged if used.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/externalDefinition"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:displayLabel"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/displayLabel","description":"A human-readable display label for the object. Supports the use of multiple languages. Repeat for labels with different content, for example, labels with differing length limitations.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/displayLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:definition"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/definition","description":"Natural language statement conveying the meaning of a concept, differentiating it from other concepts. Supports the use of multiple languages and structured text. 'externalDefinition' can't be used if 'definition' is used.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/definition"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:unitOfMeasureKind"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/unitOfMeasureKind","description":"Kind of unit of measure, so that it may be prone to translation to equivalent UOMs. Example values include \"acceleration,\" \"temperature,\" \"salinity\", etc. This description exists at the conceptual level, indicating a limitation on the type of representations which may be used for the variable as it is made more concrete.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/unitOfMeasureKind"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:measures"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/measures","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/measures"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:measures","cdi:descriptiveText"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/descriptiveText","description":"A short natural language account of the characteristics of the object.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/descriptiveText"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:measures","cdi:definition"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/definition","description":"Natural language statement conveying the meaning of a concept, differentiating it from other concepts. Supports the use of multiple languages and structured text. 'externalDefinition' can't be used if 'definition' is used.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/definition"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:measures","cdi:displayLabel"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/displayLabel","description":"A human-readable display label for the object. Supports the use of multiple languages. Repeat for labels with different content, for example, labels with differing length limitations.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/displayLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:measures","cdi:externalDefinition"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/externalDefinition","description":"A reference to an external definition of a concept (that is, a concept which is described outside the content of the DDI-CDI metadata description). An example is a SKOS concept. The definition property is assumed to duplicate the external one referenced if externalDefinition is used. Other corresponding properties are assumed to be included unchanged if used.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/externalDefinition"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:measures","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:measures","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"Human understandable name (linguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:measures","cdif:uses_Concept"],"schema_type":"array"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveConceptsFrom"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesSubstantiveConceptsFrom","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesSubstantiveConceptsFrom"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveConceptsFrom","cdi:displayLabel"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/displayLabel","description":"A human-readable display label for the object. Supports the use of multiple languages. Repeat for labels with different content, for example, labels with differing length limitations.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/displayLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveConceptsFrom","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveConceptsFrom","cdi:isDescribedBy"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDescribedBy","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDescribedBy"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveConceptsFrom","cdi:takesConceptsFrom"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesConceptsFrom","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesConceptsFrom"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesSentinelConceptsFrom","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesSentinelConceptsFrom"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:displayLabel"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/displayLabel","description":"A human-readable display label for the object. Supports the use of multiple languages. Repeat for labels with different content, for example, labels with differing length limitations.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/displayLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:isDescribedBy"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDescribedBy","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/isDescribedBy"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:isDescribedBy","cdi:regularExpression"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/regularExpression","description":"A regular expression where strings matching the expression belong to the set of valid values. Use typeOfContent to specify the syntax of the regularExpression found in content.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/regularExpression"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:isDescribedBy","cdi:regularExpression","cdi:typeOfContent"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfContent","description":"Optional use of a controlled vocabulary to specifically type the associated content.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/typeOfContent"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:isDescribedBy","cdi:regularExpression","cdif:content"],"description":"Content of the property expressed as a simple string.","schema_type":"string"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:isDescribedBy","cdi:minimumValueInclusive"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumValueInclusive","description":"A string denoting the minimum possible value. From the W3C Recommendation \"Metadata Vocabulary for Tabular Data\" (https://www.w3.org/TR/tabular-metadata/) 5.11.2: \"minimum: An atomic property that contains a single number or string that is the minimum valid value (inclusive); equivalent to minInclusive. The value of this property becomes the minimum annotation for the described datatype. See Value Constraints in [tabular-data-model] for details.\"","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumValueInclusive"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:isDescribedBy","cdi:minimumValueExclusive"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumValueExclusive","description":"A string denoting the minimum possible value (excluding this value). From the W3C Recommendation \"Metadata Vocabulary for Tabular Data\" (https://www.w3.org/TR/tabular-metadata/) 5.11.2: \"minExclusive: An atomic property that contains a single number or string that is the minimum valid value (exclusive). The value of this property becomes the minimum exclusive annotation for the described datatype. See Value Constraints in [tabular-data-model] for details.\"","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/minimumValueExclusive"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:isDescribedBy","cdi:maximumValueInclusive"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumValueInclusive","description":"A string denoting the maximum possible value. From the W3C Recommendation \"Metadata Vocabulary for Tabular Data\" (https://www.w3.org/TR/tabular-metadata/) 5.11.2: \"maximum: An atomic property that contains a single number or string that is the maximum valid value (inclusive); equivalent to maxInclusive. The value of this property becomes the maximum annotation for the described datatype. See Value Constraints in [tabular-data-model] for details.\"","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumValueInclusive"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:isDescribedBy","cdi:maximumValueExclusive"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumValueExclusive","description":"A string denoting the maximum possible value (excluding this value). From the W3C Recommendation \"Metadata Vocabulary for Tabular Data\" (https://www.w3.org/TR/tabular-metadata/) 5.11.2: \"maxExclusive: An atomic property that contains a single number or string that is the maximum valid value (exclusive). The value of this property becomes the maximum exclusive annotation for the described datatype. See Value Constraints in [tabular-data-model] for details.\"","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/maximumValueExclusive"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:isDescribedBy","cdi:logicalExpression"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/logicalExpression","description":"A logical expression where the values of \"x\" making the expression true are the members of the set of valid values. For example, \"(all reals x such that x > 0)\" describes the real numbers greater than 0.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/logicalExpression"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:isDescribedBy","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:isDescribedBy","cdi:formatPattern"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/formatPattern","description":"A pattern for a number as described in Unicode Locale Data Markup Language (LDML) (http://www.unicode.org/reports/tr35/tr35.html) Part 3: Numbers (http://www.unicode.org/reports/tr35/tr35-numbers.html#Number_Format_Patterns) and Part 4. Dates (http://www.unicode.org/reports/tr35/tr35-dates.html#Date_Format_Patterns) . Examples would be #,##0.### to describe the pattern for a decimal number, or yyyy.MM.dd G 'at' HH:mm:ss zzz for a datetime pattern.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/formatPattern"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:isDescribedBy","cdi:description"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description","description":"A formal description of the set of values in human-readable language.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/description"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:isDescribedBy","cdi:classificationLevel"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/classificationLevel","description":"Indicates the type of relationship, nominal, ordinal, interval, ratio, or continuous. Use where appropriate for the representation type.","schema_type":"string","enum":["Continuous","Interval","Nominal","Ordinal","Ratio"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/classificationLevel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:takesConceptsFrom"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesConceptsFrom","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesConceptsFrom"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:takesConceptsFrom","cdi:purpose"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose","description":"Intent or reason for the object/the description of the object.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/purpose"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:takesConceptsFrom","cdif:has_Concept"],"schema_type":"array"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:takesConceptsFrom","cdif:isDefinedBy_Concept"],"schema_type":"array"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:takesConceptsFrom","cdi:name"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name","description":"Human understandable name (liguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/name"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:takesConceptsFrom","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:takesConceptsFrom","cdi:externalDefinition"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/externalDefinition","description":"A reference to an external definition of a concept (that is, a concept which is described outside the content of the DDI-CDI metadata description). An example is a SKOS concept. The definition property is assumed to duplicate the external one referenced if externalDefinition is used. Other corresponding properties are assumed to be included unchanged if used.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/externalDefinition"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:takesConceptsFrom","cdi:externalDefinition","schema:description"],"description":"Human-readable description of the reference.","schema_type":"string"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:takesConceptsFrom","cdi:externalDefinition","schema:name"],"description":"Human-readable name of the referenced resource.","schema_type":"string"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:takesConceptsFrom","cdi:externalDefinition","schema:url"],"description":"URL of the referenced resource.","schema_type":"string","format":"uri"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelConceptsFrom","cdi:takesConceptsFrom","cdi:allowsDuplicates"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/allowsDuplicates","description":"If value is False, the members are unique within the collection - if True, there may be duplicates. (Note that a mathematical \u201cbag\u201d permits duplicates and is unordered - a \u201cset\u201d does not have duplicates and may be ordered.)","schema_type":"boolean","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/allowsDuplicates"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:descriptiveText"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/descriptiveText","description":"A short natural language account of the characteristics of the object.","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/descriptiveText"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:simpleUnitOfMeasure"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/simpleUnitOfMeasure","description":"The unit in which the data values are measured (kg, pound, euro), expressed as a simple string, in cases where no additional information is available (in the legacy system) or needed (as in the case of broad agreement within the community of use [i.e., ISO country codes, currencies, etc. in SDMX])","schema_type":"string","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/simpleUnitOfMeasure"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveValuesFrom"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesSubstantiveValuesFrom","description":"The substantive value domain for this RepresentedVariable - the set of valid, meaningful values (RepresentedVariable.takesSubstantiveValuesFrom).","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesSubstantiveValuesFrom"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveValuesFrom","cdif:takesValuesFrom"],"id":"https://cdif.org/0.1/takesValuesFrom","effectiveId":"https://cdif.org/0.1/takesValuesFrom"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveValuesFrom","cdif:displayLabel"],"id":"https://cdif.org/0.1/displayLabel","description":"A human-readable display label for the object. Supports the use of multiple languages. Repeat for labels with different content, for example, labels with differing length limitations.","schema_type":"string","effectiveId":"https://cdif.org/0.1/displayLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSubstantiveValuesFrom","cdif:recommendedDataType"],"id":"https://cdif.org/0.1/recommendedDataType","description":"The data types that are recommended for use with this domain.","schema_type":"array","effectiveId":"https://cdif.org/0.1/recommendedDataType"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesSentinelValuesFrom","description":"Sentinel (missing / not-applicable) value domain(s) for this RepresentedVariable (RepresentedVariable.takesSentinelValuesFrom).","schema_type":"array","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/takesSentinelValuesFrom"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom"],"id":"https://cdif.org/0.1/takesValuesFrom","effectiveId":"https://cdif.org/0.1/takesValuesFrom"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:purpose"],"id":"https://cdif.org/0.1/purpose","description":"Intent or reason for the object/the description of the object.","schema_type":"string","effectiveId":"https://cdif.org/0.1/purpose"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references"],"id":"https://cdif.org/0.1/references","description":"CDIF codelist (skos:ConceptScheme) whose concepts define the allowed values of this enumeration domain.","required":true,"effectiveId":"https://cdif.org/0.1/references"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:identifier"],"id":"http://schema.org/identifier","description":"Primary identifier for the codelist. May be a string URI or a structured PropertyValue.","required":true,"effectiveId":"http://schema.org/identifier"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:identifier","schema:url"],"id":"http://schema.org/url","schema_type":"string","effectiveId":"http://schema.org/url"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:identifier","schema:value"],"id":"http://schema.org/value","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:dateModified"],"id":"http://schema.org/dateModified","description":"ISO 8601 date when the codelist was last modified.","required":true,"schema_type":"string","effectiveId":"http://schema.org/dateModified"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:url"],"id":"http://schema.org/url","description":"Web location of a page describing the codelist.","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:license"],"id":"http://schema.org/license","description":"License for the codelist.","schema_type":"array","effectiveId":"http://schema.org/license"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","schema:conditionsOfAccess"],"id":"http://schema.org/conditionsOfAccess","description":"Text statement of access conditions for the codelist.","schema_type":"array","effectiveId":"http://schema.org/conditionsOfAccess"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for the concept scheme. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","schema_type":"string","effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning or purpose of this concept scheme.","schema_type":"string","effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about the concept scheme.","schema_type":"string","effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept"],"id":"http://www.w3.org/2004/02/skos/core#hasTopConcept","description":"Top-level concepts that have no skos:broader in this scheme. Required for hierarchical codelists.","required":true,"schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#hasTopConcept"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept","skos:inScheme"],"id":"http://www.w3.org/2004/02/skos/core#inScheme","description":"The concept scheme this concept belongs to. Required for CDIF codelist concepts.","required":true,"schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#inScheme"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"schema_type":"string","effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept","skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","required":true,"schema_type":"string","effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal definition of this concept. Optional for CDIF codelist concepts. A plain string.","schema_type":"string","effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept","skos:narrower"],"id":"http://www.w3.org/2004/02/skos/core#narrower","description":"Narrower (child) concepts. If present, each inline concept must also declare skos:broader pointing back to the parent concept. Both skos:narrower and skos:broader must be explicit in CDIF codelists.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#narrower"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:references","skos:hasTopConcept","skos:broader"],"id":"http://www.w3.org/2004/02/skos/core#broader","description":"Broader (parent) concepts. Required on any concept that appears as a skos:narrower value of another concept. CDIF requires both directions to be explicit for hierarchy traversal.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#broader"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","schema:name"],"id":"http://schema.org/name","description":"Human understandable name (liguistic signifier, word, phrase, or mnemonic).","schema_type":"string","effectiveId":"http://schema.org/name"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:identifier"],"id":"https://cdif.org/0.1/identifier","description":"Identifier for this enumerated (categorical) domain.","effectiveId":"https://cdif.org/0.1/identifier"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:identifier","schema:url"],"id":"http://schema.org/url","description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","effectiveId":"http://schema.org/url"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:identifier","schema:value"],"id":"http://schema.org/value","description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","effectiveId":"http://schema.org/value"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:takesValuesFrom","cdif:identifier","schema:propertyID"],"id":"http://schema.org/propertyID","description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","effectiveId":"http://schema.org/propertyID"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:displayLabel"],"id":"https://cdif.org/0.1/displayLabel","description":"A human-readable display label for the object. Supports the use of multiple languages. Repeat for labels with different content, for example, labels with differing length limitations.","schema_type":"string","effectiveId":"https://cdif.org/0.1/displayLabel"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:takesSentinelValuesFrom","cdif:recommendedDataType"],"id":"https://cdif.org/0.1/recommendedDataType","description":"The data types that are recommended for use with this domain.","schema_type":"array","effectiveId":"https://cdif.org/0.1/recommendedDataType"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:hasIntendedDataType"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasIntendedDataType","description":"The data type intended to be used by this variable. Supports the optional use of an external controlled vocabulary.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/hasIntendedDataType"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/describedUnitOfMeasure","description":"The unit in which the data values are measured (kg, pound, euro), expressed as a value from a controlled system of entries (i.e., QDT). Supports the provision of an identifier for the entry in the authoritative source (a URI, etc.), and the specific vocabulary.","effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/describedUnitOfMeasure"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure","skos:narrower"],"id":"http://www.w3.org/2004/02/skos/core#narrower","description":"Narrower (child) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#narrower"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure","skos:broader"],"id":"http://www.w3.org/2004/02/skos/core#broader","description":"Broader (parent) concepts in the hierarchy. Items are inline concept objects or @id references.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#broader"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure","skos:topConceptOf"],"id":"http://www.w3.org/2004/02/skos/core#topConceptOf","description":"Concept scheme(s) for which this is a top concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#topConceptOf"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure","skos:inScheme"],"id":"http://www.w3.org/2004/02/skos/core#inScheme","description":"Concept scheme(s) this concept belongs to.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#inScheme"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure","skos:editorialNote"],"id":"http://www.w3.org/2004/02/skos/core#editorialNote","description":"Note for editors and maintainers.","effectiveId":"http://www.w3.org/2004/02/skos/core#editorialNote"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure","skos:changeNote"],"id":"http://www.w3.org/2004/02/skos/core#changeNote","description":"Note documenting a change.","effectiveId":"http://www.w3.org/2004/02/skos/core#changeNote"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure","skos:historyNote"],"id":"http://www.w3.org/2004/02/skos/core#historyNote","description":"Note about past state or use.","effectiveId":"http://www.w3.org/2004/02/skos/core#historyNote"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure","skos:note"],"id":"http://www.w3.org/2004/02/skos/core#note","description":"General note about this concept.","effectiveId":"http://www.w3.org/2004/02/skos/core#note"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure","skos:scopeNote"],"id":"http://www.w3.org/2004/02/skos/core#scopeNote","description":"Note clarifying meaning and/or intended use.","effectiveId":"http://www.w3.org/2004/02/skos/core#scopeNote"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure","skos:definition"],"id":"http://www.w3.org/2004/02/skos/core#definition","description":"Formal explanation of the meaning of this concept.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#definition"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure","skos:notation"],"id":"http://www.w3.org/2004/02/skos/core#notation","description":"Classification code for this concept within a scheme.","schema_type":"array","effectiveId":"http://www.w3.org/2004/02/skos/core#notation"},{"path":["_anyOf","0","cdif:isDefinedBy_RepresentedVariable","cdi:describedUnitOfMeasure","skos:prefLabel"],"id":"http://www.w3.org/2004/02/skos/core#prefLabel","description":"Preferred lexical label for this concept. A single string, a single language-tagged value, or an array of language-tagged values. Each language should appear at most once.","required":true,"effectiveId":"http://www.w3.org/2004/02/skos/core#prefLabel"},{"path":["_anyOf","2","cdi:qualifies","cdi:semantic"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic","description":"Qualifies the purpose or use expressed as a paired external controlled vocabulary.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/semantic"},{"path":["_anyOf","2","cdi:qualifies","cdif:isDefinedBy_RepresentedVariable"],"sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"]},{"path":["_anyOf","2","cdi:qualifies","cdi:identifier"],"id":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier","description":"Identifier for objects requiring short- or long-lasting referencing and management.","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifDataStructureComponent"],"effectiveId":"http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/identifier"}]}