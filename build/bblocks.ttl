<bblocks://cdif.bbr.metadata.ddiProperties.ddicdiLogicalRecordRepository> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "DDI-CDI Logical Record Repository" ;
    dct:abstract "A managed collection of logical records (delimited file, fixed-record-length file, relational database, etc.). Successor to the DDI-CDI 1.0 DataStore class, renamed and relocated to the FormatDescription package in the 2026-03 DDI-CDI model. Provides $defs for LogicalRecordRepositoryStructure (topology), LogicalRecordRelationship (cross-record linkage, successor to RecordRelation), and InstanceVariableMap. Composes building block: ddicdiLogicalRecord, ddicdiDataTypes (ddiProperties); cdifInstanceVariable (cdifDataType)."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2026-05-14T00:00:00+00:00"^^xsd:dateTime ;
