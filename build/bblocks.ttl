            prof:hasArtifact <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/_sources/cdifDataType/cdifPhysicalMapping/rules.shacl> ;
            prof:hasRole role:validation ],
        [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
