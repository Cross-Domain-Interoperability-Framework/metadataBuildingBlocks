            dct:format "application/ld+json" ;
            prof:hasArtifact <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/cdifDataType/cdifDataFingerprint/context.jsonld> ;
