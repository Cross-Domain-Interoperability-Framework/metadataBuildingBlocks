<bblocks://cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "DDI-CDI Physical Mapping" ;
    dct:abstract "Describes how an InstanceVariable's values are physically represented in a dataset - format, length, decimal handling, null sequences, W3C tabular-data-model parameters. Successor to the DDI-CDI 1.0 ValueMapping class (renamed PhysicalMapping in the 2026-03 model, with the variable relationship reversed: PhysicalMapping formats InstanceVariable). Root validates any of PhysicalMapping, TextMapping (text-dialect detail), or LocatorMapping (locator string for non-tabular layouts); provides a $def for PhysicalMappingPosition. Composes building block: ddicdiDataTypes (ddiProperties); cdifInstanceVariable (cdifDataType)."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2026-05-14T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/bblock/cdif.bbr.metadata.ddiProperties.ddicdiPhysicalMapping> ],
        [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/generateddocs/json-full/bbr/metadata/ddiProperties/ddicdiPhysicalMapping/index.json> ],
        [ dct:format "text/markdown" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/generateddocs/markdown/bbr/metadata/ddiProperties/ddicdiPhysicalMapping/index.md> ] ;
    dct:hasVersion "0.1" ;
    dct:modified "2026-05-28"^^xsd:date ;
    dct:source <https://ddialliance.org/Specification/DDI-CDI/> ;
    skos:inScheme <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/> ;
    skos:prefLabel "DDI-CDI Physical Mapping" ;
    skos:topConceptOf <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/> ;
    dcat:keyword "CDIF",
        "DDI-CDI",
        "PhysicalMapping" ;
    prof:hasResource [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
