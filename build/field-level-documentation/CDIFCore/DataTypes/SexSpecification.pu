@startuml
title SexSpecification
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

enum "SexSpecification" as SexSpecification <<enumeration>> #F9E79F
{
  Feminine
  GenderNeutral
  Masculine
}

@enduml