@startuml
title DataDownload
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "DataDownload" as DataDownload #FEFECE {
  +characterSet : string [0..1]
  +fileSize : integer [0..1]
  +fileSizeUofM : string [0..1]
}

@enduml