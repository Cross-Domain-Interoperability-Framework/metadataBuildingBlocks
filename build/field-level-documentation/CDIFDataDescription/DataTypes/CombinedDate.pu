@startuml
title CombinedDate
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "CombinedDate" as CombinedDate <<dataType>> #FAE5D3 {
  +isoDate : XsdDate [1]
  +nonIsoDate : NonIsoDate [1..*]
  +semantics : ControlledVocabularyEntry [1]
}

@enduml