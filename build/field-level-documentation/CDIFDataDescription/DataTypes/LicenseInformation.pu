@startuml
title LicenseInformation
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "LicenseInformation" as LicenseInformation <<dataType>> #FAE5D3 {
  +contact : ContactInformation [1..*]
  +description : InternationalString [1..*]
  +licenseAgent : AgentInRole [1..*]
  +licenseReference : Reference [1..*]
}

@enduml