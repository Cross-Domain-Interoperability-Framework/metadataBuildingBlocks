@startuml
title ObjectName
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "ObjectName" as ObjectName <<dataType>> #FAE5D3 {
  +context : ControlledVocabularyEntry [1]
  +name : string [1]
}
class "InstanceVariable" as InstanceVariable #EEEEEE
InstanceVariable ..> ObjectName : name

@enduml