@startuml
title ComputationBaseList
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

enum "ComputationBaseList" as ComputationBaseList <<enumeration>> #F9E79F
{
  MissingOnly
  Total
  ValidOnly
}

@enduml