@startuml
title WebLink
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "WebLink" as WebLink <<dataType>> #FAE5D3 {
  +effectiveDates : DateRange [1]
  +isPreferred : boolean [1]
  +privacy : ControlledVocabularyEntry [1]
  +typeOfWebsite : ControlledVocabularyEntry [1]
  +uri : XsdAnyUri [1]
}

@enduml