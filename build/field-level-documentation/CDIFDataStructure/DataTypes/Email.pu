@startuml
title Email
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "Email" as Email <<dataType>> #FAE5D3 {
  +effectiveDates : DateRange [1]
  +internetEmail : string [1]
  +isPreferred : boolean [1]
  +privacy : ControlledVocabularyEntry [1]
  +typeOfEmail : ControlledVocabularyEntry [1]
}

@enduml