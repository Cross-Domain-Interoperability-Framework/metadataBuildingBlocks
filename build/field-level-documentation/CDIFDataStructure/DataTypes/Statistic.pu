@startuml
title Statistic
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "Statistic" as Statistic <<dataType>> #FAE5D3 {
  +computationBase : ComputationBaseList [1]
  +content : number [1]
  +isWeighted : boolean [1]
  +typeOfNumericValue : string [1]
}
class "Statistic" as Statistic #EEEEEE
Statistic ..> Statistic : statistic

@enduml