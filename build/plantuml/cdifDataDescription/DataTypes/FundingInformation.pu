@startuml
title FundingInformation
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "FundingInformation" as FundingInformation <<dataType>> #FAE5D3 {
  +fundingAgent : AgentInRole [1..*]
  +grantNumber : string [1]
}

@enduml