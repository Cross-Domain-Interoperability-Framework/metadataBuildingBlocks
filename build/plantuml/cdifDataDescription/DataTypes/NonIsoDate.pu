@startuml
title NonIsoDate
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "NonIsoDate" as NonIsoDate <<dataType>> #FAE5D3 {
  +calendar : ControlledVocabularyEntry [1]
  +dateContent : string [1]
  +nonIsoDateFormat : ControlledVocabularyEntry [1]
}

@enduml