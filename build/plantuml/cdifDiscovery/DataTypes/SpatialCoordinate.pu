@startuml
title SpatialCoordinate
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "SpatialCoordinate" as SpatialCoordinate <<dataType>> #FAE5D3 {
  +content : string [1]
  +coordinateType : PointFormat [1]
}

@enduml