@startuml
title InternationalIdentifier
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "InternationalIdentifier" as InternationalIdentifier <<dataType>> #FAE5D3 {
  +identifierContent : string [1]
  +isURI : boolean [1]
  +managingAgency : ControlledVocabularyEntry [1]
}

@enduml