@startuml
title PointFormat
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

enum "PointFormat" as PointFormat <<enumeration>> #F9E79F
{
  DecimalDegree
  DecimalMinutes
  DegreesMinutesSeconds
  Feet
  Meters
}

@enduml