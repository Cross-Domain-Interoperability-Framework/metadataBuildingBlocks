@startuml
title LabeledLink
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "LabeledLink" as LabeledLink #FEFECE {
  +identifier : XsdAnyUri [1]
  +name : string [0..1]
}
class "Dataset" as Dataset #EEEEEE
Dataset "0..*" <-- LabeledLink : license
class "XsdAnyUri" as XsdAnyUri <<dataType>> #FAE5D3
LabeledLink ..> XsdAnyUri : identifier

@enduml