@startuml
title DataStructure
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "DataStructure" as DataStructure #FEFECE {
  +identifier : Identifier [1]
  +semantic : Concept [1..*]
  +specialization : SpecializationRole [1]
}
class "SpecializationRole" as SpecializationRole <<dataType>> #FAE5D3
DataStructure ..> SpecializationRole : specialization

@enduml