@startuml
title PairedControlledVocabularyEntry
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "PairedControlledVocabularyEntry" as PairedControlledVocabularyEntry <<dataType>> #FAE5D3 {
  +extent : ControlledVocabularyEntry [1]
  +term : ControlledVocabularyEntry [1]
}

@enduml