@startuml
title ElectronicMessageSystem
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "ElectronicMessageSystem" as ElectronicMessageSystem <<dataType>> #FAE5D3 {
  +contactAddress : string [1]
  +effectiveDates : DateRange [1]
  +isPreferred : boolean [1]
  +privacy : ControlledVocabularyEntry [1]
  +typeOfService : ControlledVocabularyEntry [1]
}

@enduml