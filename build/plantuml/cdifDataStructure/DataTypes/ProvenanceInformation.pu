@startuml
title ProvenanceInformation
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "ProvenanceInformation" as ProvenanceInformation <<dataType>> #FAE5D3 {
  +funding : FundingInformation [1..*]
  +provenanceStatement : InternationalString [1..*]
  +recordCreationDate : XsdDate [1]
  +recordLastRevisionDate : XsdDate [1]
}

@enduml