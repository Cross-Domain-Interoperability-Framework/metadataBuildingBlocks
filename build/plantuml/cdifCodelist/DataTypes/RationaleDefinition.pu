@startuml
title RationaleDefinition
hide circle
hide empty members
skinparam shadowing false
skinparam ArrowThickness 1.2
skinparam class {
  ArrowColor #404040
  BorderColor #404040
  FontSize 12
}

class "RationaleDefinition" as RationaleDefinition <<dataType>> #FAE5D3 {
  +rationaleCode : ControlledVocabularyEntry [1]
  +rationaleDescription : InternationalString [1]
}

@enduml