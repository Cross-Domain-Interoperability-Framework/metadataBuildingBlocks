  "schema:datePublished": "2025-10-15",
  "schema:license": [
    "https://creativecommons.org/licenses/by/4.0/"
  ],
  "schema:keywords": [
    "ocean temperature",
    "Gulf of Maine",
    "gridded data",
    "reanalysis"
  ],
