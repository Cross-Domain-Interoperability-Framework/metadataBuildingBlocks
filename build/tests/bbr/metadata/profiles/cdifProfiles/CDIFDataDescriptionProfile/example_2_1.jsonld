          "cdif:locator": "/depth",
          "cdif:format": "decimal",
          "cdif:physicalDataType": "float32",
          "cdi:isRequired": true,
          "cdif:formats_InstanceVariable": {
            "@id": "ex:var-depth"
          }
        },
        {
          "cdif:index": 2,
          "cdif:locator": "/lat",
          "cdif:format": "decimal",
          "cdif:physicalDataType": "float32",
          "cdi:isRequired": true,
          "cdif:formats_InstanceVariable": {
            "@id": "ex:var-lat"
          }
        },
        {
          "cdif:index": 3,
          "cdif:locator": "/lon",
          "cdif:format": "decimal",
          "cdif:physicalDataType": "float32",
          "cdi:isRequired": true,
          "cdif:formats_InstanceVariable": {
            "@id": "ex:var-lon"
          }
        },
        {
          "cdif:index": 4,
